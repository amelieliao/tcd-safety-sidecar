+def _tcd_v2_bool(v):
+    if type(v) is bool:
+        return v
+    if v is None:
+        return False
+    if isinstance(v, str):
+        return v.strip().lower() in {"1", "true", "yes", "y", "ok"}
+    return bool(v)
