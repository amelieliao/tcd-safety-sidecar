+def _tcd_v2_scan_for_unsafe_raw_keys(obj, *, path="$"):
+    """
+    Reject genuinely unsafe raw material, but do not reject canonical proof keys.
+    """
+    critical_exact = {
+        "authorization",
+        "proxy-authorization",
+        "cookie",
+        "cookies",
+        "set-cookie",
+        "password",
+        "passwd",
+        "api_key",
+        "apikey",
+        "x-api-key",
+        "access_token",
+        "refresh_token",
+        "id_token",
+        "private_key",
+        "privatekey",
+        "bearer",
+    }
+    # "token" and "secret" can appear as substrings in safe domain terms
+    # such as tokens_delta or policy refs. Treat exact unsafe keys strictly.
+    critical_exact.update({"token", "secret"})
+
+    raw_content_keys = {
+        "detector_text",
+        "prompt",
+        "completion",
+        "messages",
+        "message",
+        "content",
+        "input",
+        "input_text",
+        "query",
+        "instruction",
+        "instructions",
+        "headers",
+        "header",
+        "payload",
+        "request_body",
+        "response_body",
