+def _continuity_gaps(rows: Sequence[ReceiptRow]) -> int:
+    if len(rows) <= 1:
+        return 0
+    gaps = 0
+    for prev, cur in zip(rows[:-1], rows[1:]):
+        if cur.prev_head_hex and cur.prev_head_hex != prev.head_hex:
+            gaps += 1
+    return gaps
