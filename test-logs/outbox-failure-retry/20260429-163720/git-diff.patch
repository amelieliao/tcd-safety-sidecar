+        alpha_spent=float(_coerce_float(payload.get("alpha_spent")) or 0.0),
+        step=max(0, _coerce_int(payload.get("step")) or 0),
+        selected_source=stream.selected_source,
+        controller_mode=payload.get("controller_mode"),
