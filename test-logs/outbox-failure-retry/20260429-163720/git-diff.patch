+def _tcd_v2_is_redacted_or_digest(v):
+    if v is None:
+        return True
+    if _tcd_v2_is_digest_ref(v):
+        return True
+    if isinstance(v, str):
+        s = v.strip()
+        if not s:
+            return True
+        if s in {"[REDACTED]", "<redacted>", "<bytes>"}:
