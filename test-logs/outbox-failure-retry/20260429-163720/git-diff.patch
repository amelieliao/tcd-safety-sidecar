+# =============================================================================
+# Durable receipt env/runtime compatibility final override
+# =============================================================================
+
+def _tcd_sr_bool_final(name: str, default: bool = False) -> bool:
+    try:
+        return _coerce_bool(os.getenv(name), default=default)
+    except Exception:
+        return bool(default)
+
+
+def _tcd_sr_text_final(name: str, default: str = "") -> str:
+    try:
+        return _strip_unsafe_text(os.getenv(name, default), max_len=4096) or default
+    except Exception:
+        return default
+
+
+def _tcd_sr_durable_requested_final() -> bool:
+    """
+    Authoritative durable-receipt staging switch.
+
+    TCD_SECURITY_ROUTER_DURABLE_RECEIPTS=1 intentionally wins over older
+    false/default knobs because this mode is used by readiness tests.
+    """
+    try:
+        if _tcd_sr_bool_final("TCD_SECURITY_ROUTER_LOCAL_LEDGER_DISABLE", False):
+            return False
+        names = (
+            "TCD_SECURITY_ROUTER_DURABLE_RECEIPTS",
+            "TCD_SECURITY_ROUTER_LOCAL_LEDGER_ENABLE",
+            "TCD_SECURITY_ROUTER_LEDGER_ENABLE",
+            "TCD_SECURITY_ROUTER_LEDGER_REQUIRED_ON_DENY",
+            "TCD_SECURITY_ROUTER_REQUIRE_LEDGER_WHEN_REQUIRED",
+            "TCD_SECURITY_ROUTER_REQUIRE_LOCAL_LEDGER",
+            "TCD_SECURITY_ROUTER_REQUIRE_TERMINAL_GOVERNANCE_FOR_RECEIPT",
+            "TCD_SECURITY_ROUTER_REQUIRE_STORAGE_READY_FOR_RECEIPT",
+        )
+        if any(_tcd_sr_bool_final(n, False) for n in names):
+            return True
+        if os.getenv("TCD_SECURITY_ROUTER_LEDGER_DB") or os.getenv("TCD_LEDGER_DB"):
+            return True
+    except Exception:
+        return False
+    return False
+
+
+def _tcd_sr_outbox_requested_final() -> bool:
+    try:
+        if _tcd_sr_bool_final("TCD_SECURITY_ROUTER_LOCAL_OUTBOX_DISABLE", False):
+            return False
+        names = (
+            "TCD_SECURITY_ROUTER_LOCAL_OUTBOX_ENABLE",
+            "TCD_SECURITY_ROUTER_OUTBOX_ENABLE",
+            "TCD_SECURITY_ROUTER_OUTBOX_ENABLED",
+        )
+        if any(_tcd_sr_bool_final(n, False) for n in names):
+            return True
+        if os.getenv("TCD_SECURITY_ROUTER_OUTBOX_AUDIT_PATH") or os.getenv("TCD_AUDIT_LOG"):
+            return True
+    except Exception:
+        return False
+    return False
+
+
+def _tcd_sr_attestor_requested_final() -> bool:
+    try:
+        if _tcd_sr_bool_final("TCD_SECURITY_ROUTER_ATTESTOR_DISABLE", False):
+            return False
+        return bool(
+            _tcd_sr_bool_final("TCD_SECURITY_ROUTER_ATTESTOR_ENABLE", False)
+            or _tcd_sr_durable_requested_final()
+        )
+    except Exception:
+        return False
+
+
+_TCD_SECURITY_ROUTER_ORIG_CONFIG_FROM_ENV_FINAL = _security_router_config_from_env
+
+
+def _security_router_config_from_env() -> "SecurityRouterConfig":
+    """
+    Final env wrapper.
+
+    The previous implementation may already parse some durable envs, but this
+    wrapper makes durable readiness deterministic and avoids stale false values
+    from older shells.
+    """
+    cfg = _TCD_SECURITY_ROUTER_ORIG_CONFIG_FROM_ENV_FINAL()
+
+    # Keep ordinary env knobs functional.
+    cfg.receipt_required_on_deny = _coerce_bool(
+        os.getenv("TCD_SECURITY_ROUTER_RECEIPT_REQUIRED_ON_DENY"),
+        default=cfg.receipt_required_on_deny,
+    )
+    cfg.outbox_enabled = _coerce_bool(
+        os.getenv("TCD_SECURITY_ROUTER_OUTBOX_ENABLED"),
+        default=cfg.outbox_enabled,
+    )
+    cfg.outbox_on_required_sink_failure = _coerce_bool(
+        os.getenv("TCD_SECURITY_ROUTER_OUTBOX_ON_REQUIRED_SINK_FAILURE"),
+        default=cfg.outbox_on_required_sink_failure,
+    )
+    cfg.treat_outbox_enqueue_as_durable = _coerce_bool(
+        os.getenv("TCD_SECURITY_ROUTER_TREAT_OUTBOX_ENQUEUE_AS_DURABLE"),
+        default=cfg.treat_outbox_enqueue_as_durable,
+    )
+    cfg.prepare_before_attestation = _coerce_bool(
+        os.getenv("TCD_SECURITY_ROUTER_PREPARE_BEFORE_ATTESTATION"),
+        default=cfg.prepare_before_attestation,
+    )
+    cfg.require_storage_ready_for_receipt_required = _coerce_bool(
+        os.getenv("TCD_SECURITY_ROUTER_REQUIRE_STORAGE_READY_FOR_RECEIPT"),
+        default=cfg.require_storage_ready_for_receipt_required,
+    )
+
+    if _tcd_sr_durable_requested_final():
+        # Durable receipt readiness mode: all four are required.
+        cfg.receipt_required_on_deny = True
+        cfg.ledger_required_on_deny = True
+        cfg.require_ledger_when_required = True
+        cfg.require_terminal_governance_for_receipt_required = True
+        cfg.require_attestor_when_required = True
+        cfg.prepare_before_attestation = True
+
+    return cfg
+
+
+_TCD_SECURITY_ROUTER_ORIG_INIT_FINAL = SecurityRouter.__init__
+
+
+def _tcd_security_router_init_durable_final(self, *args: Any, **kwargs: Any) -> None:
+    _TCD_SECURITY_ROUTER_ORIG_INIT_FINAL(self, *args, **kwargs)
+
+    durable = _tcd_sr_durable_requested_final()
+
+    # If service_http passed an explicit config object, the env wrapper above may
+    # have been bypassed. Apply durable requirements to the live bundle too.
+    if durable:
+        try:
+            cfg = self.config
+            cfg.receipt_required_on_deny = True
+            cfg.ledger_required_on_deny = True
+            cfg.require_ledger_when_required = True
+            cfg.require_terminal_governance_for_receipt_required = True
+            cfg.require_attestor_when_required = True
+            cfg.prepare_before_attestation = True
