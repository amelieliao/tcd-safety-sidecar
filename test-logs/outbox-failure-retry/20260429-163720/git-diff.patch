+    out: List[str] = []
+    for ch in s:
+        o = ord(ch)
+        if ch in ("\u2028", "\u2029"):
+            continue
+        if o < 0x20 or o == 0x7F or (0x80 <= o <= 0x9F):
+            continue
+        cat = unicodedata.category(ch)
+        if cat in ("Cc", "Cf", "Cs", "Zl", "Zp"):
+            continue
+        out.append(ch)
