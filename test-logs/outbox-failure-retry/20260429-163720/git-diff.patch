+    """
+    E-values in receipt/e-process material must be positive finite numbers.
+    Missing/invalid/zero/negative values are normalized to a conservative neutral default.
+    """
+    for v in values:
+        x = _coerce_float(v)
+        if x is None or x <= 0.0:
