+    duplicates = 0
+    for r in rows:
+        if r.head_hex in seen:
+            duplicates += 1
+        seen[r.head_hex] = seen.get(r.head_hex, 0) + 1
+        if r.triggered_e:
+            triggered += 1
+        try:
+            json.loads(r.body_json)
+        except Exception:
+            parse_errors += 1
+
+    gaps = _continuity_gaps(rows)
