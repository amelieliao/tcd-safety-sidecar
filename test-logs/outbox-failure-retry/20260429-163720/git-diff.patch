+            path = _path_from(obj)
+            if path:
+                evt = _open_path(path)
+                if evt is not None:
+                    return evt
+
+            for name in conn_attrs:
+                try:
+                    candidate = getattr(obj, name, None)
+                except Exception:
+                    continue
+                if isinstance(candidate, sqlite3.Connection):
