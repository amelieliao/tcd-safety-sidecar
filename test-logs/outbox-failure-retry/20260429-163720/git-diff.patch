+    verify: bool = True,
+) -> ReceiptAuditReport:
+    t0 = time.perf_counter()
+    reasons: List[str] = []
+    rows: List[ReceiptRow] = []
+    verify_ok = True
+    try:
+        rows = store.tail(max(0, int(window)))
+    except Exception:
+        rows = []
+        reasons.append("store_tail_failed")
