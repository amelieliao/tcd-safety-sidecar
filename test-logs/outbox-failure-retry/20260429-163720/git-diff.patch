+def _make_parse_int_limiter(max_digits: int):
+    max_digits = max(1, int(max_digits))
+    def _parse_int(s: str) -> int:
+        ss = s[1:] if s.startswith("-") else s
+        if len(ss) > max_digits:
+            raise ValueError("integer too large")
+        return int(s, 10)
+    return _parse_int
+
+
+def _make_parse_float_limiter(max_digits: int):
+    max_digits = max(1, int(max_digits))
+    def _parse_float(s: str) -> float:
+        ss = s.strip()
+        digits = sum(1 for ch in ss if ch.isdigit())
+        if digits > max_digits:
+            raise ValueError("float too large")
+        x = float(ss)
+        if not math.isfinite(x):
+            raise ValueError("non-finite JSON value")
+        return x
+    return _parse_float
+
+
+def _json_loads_strict(s: str, *, max_depth: int, max_int_digits: int) -> Any:
+    if _json_depth_exceeds(s, max_depth=max_depth):
+        raise ValueError("json depth limit exceeded")
+    def _bad_const(_: str) -> Any:
+        raise ValueError("non-finite JSON value")
+    return json.loads(
