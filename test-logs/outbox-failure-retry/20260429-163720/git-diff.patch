+def _json_depth_exceeds(s: str, *, max_depth: int) -> bool:
+    depth = 0
+    in_str = False
+    esc = False
+    for ch in s:
+        if in_str:
+            if esc:
+                esc = False
+                continue
+            if ch == "\\":
+                esc = True
+                continue
+            if ch == '"':
+                in_str = False
+            continue
+        if ch == '"':
+            in_str = True
+            continue
+        if ch in "{[":
+            depth += 1
+            if depth > max_depth:
+                return True
+        elif ch in "}]":
+            depth = max(0, depth - 1)
+    return False
+
