+def _tcd_v2_num(v):
+    import math as _math
+    if type(v) is bool or v is None:
+        return None
+    if isinstance(v, (int, float)):
+        try:
+            x = float(v)
+            return x if _math.isfinite(x) else None
+        except Exception:
+            return None
+    if isinstance(v, str):
+        s = v.strip()
+        if not s or len(s) > 128:
+            return None
+        try:
+            x = float(s)
+            return x if _math.isfinite(x) else None
+        except Exception:
+            return None
