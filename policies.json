{
  "schema_version": 1,
  "policyset_meta": {
    "name": "local_dev_policyset",
    "version": "v1",
    "owner": "local",
    "purpose": "dev_smoke_test"
  },
  "rules": [
    {
      "name": "block_internet_admin",
      "version": "v1",
      "priority": 1000,
      "match": {
        "tenant": "*",
        "user": "*",
        "session": "*",
        "model_id": "*",
        "gpu_id": "*",
        "task": "*",
        "lang": "*",
        "env": "*",
        "trust_zone": "internet",
        "route": "admin",
        "data_class": "*",
        "workload": "*",
        "jurisdiction": "*",
        "regulation": "*",
        "client_app": "*",
        "access_channel": "*"
      },
      "decision": "deny",
      "enforcement": "block",
      "routing": {
        "route_profile": "restricted",
        "action_hint": "block",
        "fallback_decoder": "safe",
        "t_low": 0.2,
        "t_high": 0.5,
        "top_p_low": 0.4,
        "top_p_high": 0.6
      },
      "receipt": {
        "enable_issue": false,
        "enable_verify_metrics": true,
        "attach_policy_refs": true,
        "attach_match_context": true,
        "profile": "local_dev",
        "crypto_profile": null,
        "match_context_level": "coarse"
      },
      "sre": {
        "token_cost_divisor": 10.0,
        "probe_sample_rate": 1.0
      },
      "audit": {
        "audit_label": "admin_block",
        "sample_rate": 1.0,
        "log_level": "error",
        "incident_class": "security",
        "force_audit_on_violation": true,
        "require_full_trace": false
      },
      "compliance_profile": "strict",
      "risk_label": "critical",
      "origin": "local_dev_policy"
    },
