from __future__ import annotations

"""
Receipt stores — governed persistence for verifiable, content-agnostic receipts.

This module is a drop-in replacement for the older receipt_store.py.  It keeps
existing public API compatibility while adding receipt-v2-aware validation,
privacy hardening, richer metadata extraction, stronger SRE metrics, and safer
JSONL / SQLite persistence.

Design constraints
------------------
- The store is signature-scheme agnostic.  It persists head/body/signature/key
  material and validates chain / metadata shape, but it does not interpret or
  verify classical/PQ/hybrid signatures.
- By default the store does NOT mutate `body_json` on append.  Receipt heads are
  usually computed over canonical body bytes by an issuer/attestor.  Silent
  re-canonicalization inside the store can break head/body binding, so it is an
  explicit opt-in (`canonicalize_body_on_append=True`).
- Receipt body metadata must stay content-agnostic.  The validator scans for
  raw prompt/completion/request/response/header/auth/token-like fields and can
  warn or reject depending on config.
- Backends remain thread-safe and stdlib-only except optional prometheus_client.
"""

import dataclasses
import hashlib
import json
import math
import os
import re
import sqlite3
import threading
import time
import unicodedata
from dataclasses import dataclass, field
from pathlib import Path
from typing import Any, Dict, Iterable, Iterator, List, Mapping, Optional, Protocol, Sequence, Tuple, Literal

try:  # pragma: no cover - platform-specific
    import fcntl  # type: ignore
except Exception:  # pragma: no cover
    fcntl = None  # type: ignore[assignment]

try:
    from .verify import verify_chain
except Exception:  # pragma: no cover
    def verify_chain(*_: Any, **__: Any) -> bool:  # type: ignore[no-redef]
        raise RuntimeError("tcd.verify.verify_chain is unavailable")

try:
    from prometheus_client import REGISTRY, Counter, Histogram, Gauge  # type: ignore
    _HAS_PROM = True
except Exception:  # pragma: no cover
    _HAS_PROM = False

__all__ = [
    "ReceiptStoreConfig",
    "ReceiptValidationResult",
    "ReceiptRow",
    "ReceiptSummary",
    "ReceiptAuditReport",
    "ReceiptStore",
    "InMemoryReceiptStore",
