]

# =============================================================================
# Metrics
# =============================================================================

class _Nop:
    def labels(self, *_, **__):
        return self
    def inc(self, *_ , **__):
        pass
    def set(self, *_ , **__):
        pass
    def observe(self, *_ , **__):
        pass


def _mk_counter(name: str, doc: str, labelnames: Sequence[str]) -> Any:
    if not _HAS_PROM:
        return _Nop()
    try:
        return Counter(name, doc, labelnames=list(labelnames), registry=REGISTRY)
    except Exception:  # duplicate registration or custom registry mismatch
        return _Nop()


def _mk_gauge(name: str, doc: str, labelnames: Sequence[str]) -> Any:
    if not _HAS_PROM:
        return _Nop()
    try:
        return Gauge(name, doc, labelnames=list(labelnames), registry=REGISTRY)
    except Exception:
        return _Nop()


def _mk_hist(name: str, doc: str, labelnames: Sequence[str], buckets: Sequence[float]) -> Any:
    if not _HAS_PROM:
        return _Nop()
    try:
        return Histogram(name, doc, labelnames=list(labelnames), buckets=tuple(buckets), registry=REGISTRY)
    except Exception:
        return _Nop()


_RCPT_APPEND = _mk_counter(
    "tcd_receipts_append_total",
    "Receipt append operations",
    ("backend", "status"),
)
_RCPT_BYTES = _mk_counter(
    "tcd_receipts_body_bytes_total",
    "Total appended receipt body bytes",
    ("backend",),
)
_RCPT_COUNT = _mk_gauge(
    "tcd_receipts_count",
    "Approx number of receipts in store",
    ("backend",),
)
_RCPT_APPEND_LAT = _mk_hist(
    "tcd_receipts_append_latency_seconds",
    "Append latency",
    ("backend",),
    (0.0005, 0.001, 0.002, 0.005, 0.01, 0.02, 0.05, 0.1, 0.25, 0.5),
)
_RCPT_VERIFY_LAT = _mk_hist(
    "tcd_receipts_verify_latency_seconds",
    "Verification latency over a window",
    ("backend",),
    (0.0005, 0.001, 0.002, 0.005, 0.01, 0.02, 0.05, 0.1, 0.25, 0.5, 1.0),
)
_RCPT_VERIFY_FAIL = _mk_counter(
    "tcd_receipts_verify_fail_total",
    "Chain verification failures",
    ("backend", "reason"),
)
_RCPT_VALIDATION = _mk_counter(
    "tcd_receipts_validation_total",
    "Receipt body validation outcomes",
    ("backend", "status", "reason"),
)
_RCPT_SUMMARY_TRIGGERED = _mk_gauge(
    "tcd_receipts_recent_triggered",
    "Triggered e-process receipts in the most recent summary window",
