# SQLite helper + schema
# =============================================================================


_SQL_SCHEMA = """
PRAGMA journal_mode=WAL;
PRAGMA foreign_keys=ON;

CREATE TABLE IF NOT EXISTS schema_migrations (
    name TEXT PRIMARY KEY,
    applied_at_unix_ns INTEGER NOT NULL
);

CREATE TABLE IF NOT EXISTS storage_activation_log (
    store_name TEXT NOT NULL,
    schema_version TEXT NOT NULL,
    applied_at_unix_ns INTEGER NOT NULL,
    details_json TEXT NOT NULL DEFAULT '{}'
);

CREATE TABLE IF NOT EXISTS wealth_state_current (
    tenant TEXT NOT NULL,
    user TEXT NOT NULL,
    session TEXT NOT NULL,
    subject_hash TEXT NOT NULL,
    policy_ref TEXT NOT NULL,
    state_domain_id TEXT NOT NULL,
    adapter_registry_fp TEXT,
    wealth REAL NOT NULL,
    alpha0 REAL NOT NULL,
    state_revision INTEGER NOT NULL,
    created_at_unix_ns INTEGER NOT NULL,
    updated_at_unix_ns INTEGER NOT NULL,
    PRIMARY KEY (tenant, user, session, policy_ref, state_domain_id)
);

CREATE TABLE IF NOT EXISTS wealth_event_log (
    store_id INTEGER PRIMARY KEY AUTOINCREMENT,
    event_id TEXT,
    idem_key TEXT,
    tenant TEXT NOT NULL,
    user TEXT NOT NULL,
    session TEXT NOT NULL,
    subject_hash TEXT NOT NULL,
    policy_ref TEXT NOT NULL,
    state_domain_id TEXT NOT NULL,
    adapter_registry_fp TEXT,
    expected_state_revision INTEGER,
    state_revision INTEGER NOT NULL,
    ts_unix_ns INTEGER NOT NULL,
    wealth_before REAL NOT NULL,
    wealth_after REAL NOT NULL,
    alpha_spent REAL NOT NULL,
    earn REAL NOT NULL,
    reward REAL NOT NULL,
    reject_flag INTEGER NOT NULL,
    reason_code TEXT NOT NULL,
    trust_zone TEXT NOT NULL,
    route_profile TEXT NOT NULL,
    route_plan_id TEXT,
    decision_id TEXT,
    signal_digest TEXT,
    context_digest TEXT,
    selected_source TEXT,
    controller_mode TEXT,
    decision_mode TEXT,
    statistical_guarantee_scope TEXT,
    identity_status TEXT,
    audit_ref TEXT,
    receipt_ref TEXT,
    degraded_reasons_json TEXT NOT NULL DEFAULT '[]',
    meta_json TEXT NOT NULL DEFAULT '{}',
    event_fingerprint TEXT NOT NULL
);

CREATE UNIQUE INDEX IF NOT EXISTS idx_wealth_event_id
ON wealth_event_log(event_id) WHERE event_id IS NOT NULL;

CREATE UNIQUE INDEX IF NOT EXISTS idx_wealth_idem
ON wealth_event_log(tenant, user, session, policy_ref, state_domain_id, idem_key)
WHERE idem_key IS NOT NULL;

CREATE INDEX IF NOT EXISTS idx_wealth_subject_policy_ts
ON wealth_event_log(tenant, user, session, policy_ref, state_domain_id, ts_unix_ns, event_id);

CREATE TABLE IF NOT EXISTS receipts_v2 (
    store_id INTEGER PRIMARY KEY AUTOINCREMENT,
    head_hex TEXT NOT NULL,
    chain_head_hex TEXT NOT NULL,
    prev_chain_head_hex TEXT,
    head_semantics TEXT NOT NULL,
    semantic_fingerprint TEXT NOT NULL,
    body_json TEXT NOT NULL,
    body_digest TEXT NOT NULL,
    sig TEXT,
    verify_key TEXT,
    verify_key_fp TEXT,
    verify_key_id TEXT,
    receipt_integrity TEXT,
    schema_id TEXT,
    schema_version INTEGER,
    canonicalization_version TEXT,
    receipt_kind TEXT,
    event_type TEXT,
    body_kind TEXT,
    body_schema TEXT,
    body_canonicalized INTEGER,
    sig_scheme TEXT,
    sig_alg TEXT,
    sig_chain_id TEXT,
    sig_key_id TEXT,
    pq_required INTEGER,
    pq_ok INTEGER,
    pq_signature_required INTEGER,
    pq_signature_ok INTEGER,
    ts REAL,
    ts_ns INTEGER,
    ts_unix_ns INTEGER NOT NULL,
    build_id TEXT,
    image_digest TEXT,
    attestation_id TEXT,
    env_fingerprint TEXT,
    policy_ref TEXT,
    policyset_ref TEXT,
    policy_digest TEXT,
    cfg_fp TEXT,
    config_hash TEXT,
    stream_hash TEXT,
    state_domain_id TEXT,
    adapter_registry_fp TEXT,
    event_id TEXT,
    decision_id TEXT,
    route_plan_id TEXT,
    route_id TEXT,
    audit_ref TEXT,
    receipt_ref TEXT,
    ledger_ref TEXT,
    attestation_ref TEXT,
    chain_namespace TEXT NOT NULL,
    chain_id TEXT NOT NULL,
    chain_seq INTEGER,
    action TEXT,
    reason TEXT,
    selected_source TEXT,
    statistical_guarantee_scope TEXT,
    trigger_flag INTEGER,
    allowed_flag INTEGER,
    prepare_ref TEXT,
    commit_ref TEXT,
    ledger_stage TEXT,
    outbox_ref TEXT,
    outbox_status TEXT,
    outbox_dedupe_key TEXT,
    delivery_attempts INTEGER,
    payload_digest TEXT,
    event_digest TEXT,
    produced_by_json TEXT NOT NULL DEFAULT '[]',
    provenance_path_digest TEXT,
    head_verified INTEGER,
    body_canonical_verified INTEGER,
    integrity_hash_verified INTEGER,
    signature_verified INTEGER,
    verify_key_allowed INTEGER,
    policy_binding_verified INTEGER,
    cfg_binding_verified INTEGER,
    integrity_ok INTEGER NOT NULL DEFAULT 1,
    integrity_errors_json TEXT NOT NULL DEFAULT '[]',
    normalization_warnings_json TEXT NOT NULL DEFAULT '[]',
    compat_warnings_json TEXT NOT NULL DEFAULT '[]',
    meta_json TEXT NOT NULL DEFAULT '{}',
    inserted_at_unix_ns INTEGER NOT NULL,
    updated_at_unix_ns INTEGER NOT NULL
);

CREATE UNIQUE INDEX IF NOT EXISTS idx_receipts_head
ON receipts_v2(head_hex);

CREATE UNIQUE INDEX IF NOT EXISTS idx_receipts_chain_head
ON receipts_v2(chain_head_hex);

CREATE UNIQUE INDEX IF NOT EXISTS idx_receipts_event_id
ON receipts_v2(event_id) WHERE event_id IS NOT NULL;

CREATE UNIQUE INDEX IF NOT EXISTS idx_receipts_decision_id
ON receipts_v2(decision_id) WHERE decision_id IS NOT NULL;

CREATE UNIQUE INDEX IF NOT EXISTS idx_receipts_chain_seq
ON receipts_v2(chain_namespace, chain_id, chain_seq)
WHERE chain_seq IS NOT NULL;

CREATE UNIQUE INDEX IF NOT EXISTS idx_receipts_prev_unique
ON receipts_v2(chain_namespace, chain_id, prev_chain_head_hex)
WHERE prev_chain_head_hex IS NOT NULL;

CREATE UNIQUE INDEX IF NOT EXISTS idx_receipts_single_genesis
ON receipts_v2(chain_namespace, chain_id)
WHERE prev_chain_head_hex IS NULL;

CREATE INDEX IF NOT EXISTS idx_receipts_chain_latest
ON receipts_v2(chain_namespace, chain_id, chain_seq DESC, ts_unix_ns DESC, store_id DESC);

CREATE INDEX IF NOT EXISTS idx_receipts_global_latest
ON receipts_v2(inserted_at_unix_ns DESC, store_id DESC);
"""


_SQL_RECEIPTS_V2_COMPAT_COLUMNS: Mapping[str, str] = {
    "request_id": "TEXT",
    "receipt_surface_kind": "TEXT",
    "receipt_delivery_state": "TEXT",
    "evidence_durable": "INTEGER",
    "evidence_storage_ready": "INTEGER",
    "governance_terminal": "INTEGER",
    "receipt_governance_ready": "INTEGER",
}


def _ensure_receipts_v2_columns(conn: sqlite3.Connection) -> None:
    try:
        rows = list(conn.execute("PRAGMA table_info(receipts_v2)"))
        existing = {str(row["name"] if isinstance(row, sqlite3.Row) else row[1]) for row in rows}
    except Exception:
        return
    for col, decl in _SQL_RECEIPTS_V2_COMPAT_COLUMNS.items():
        if col in existing:
            continue
        conn.execute(f"ALTER TABLE receipts_v2 ADD COLUMN {col} {decl}")

class _SQLite:
    def __init__(self, path: str, *, cfg: StorageConfig) -> None:
        self._path = path
        self._cfg = cfg
        self._lock = threading.RLock()
        self._conn = sqlite3.connect(self._path, check_same_thread=False, isolation_level=None)
        self._conn.row_factory = sqlite3.Row
        try:
            self._conn.execute(f"PRAGMA busy_timeout={int(cfg.sqlite_timeout_s * 1000)};")
            self._conn.execute(f"PRAGMA synchronous={cfg.sqlite_synchronous};")
            self._conn.execute(f"PRAGMA wal_autocheckpoint={int(cfg.sqlite_wal_autocheckpoint)};")
            self._conn.execute(f"PRAGMA journal_size_limit={int(cfg.sqlite_journal_size_limit)};")
        except Exception:
            pass
        with self._conn:
            self._conn.executescript(_SQL_SCHEMA)
            _ensure_receipts_v2_columns(self._conn)
            self._conn.execute(
                "INSERT OR IGNORE INTO schema_migrations(name, applied_at_unix_ns) VALUES(?,?)",
                (_SCHEMA, now_unix_ns()),
            )

    @contextlib.contextmanager
    def tx(self) -> Iterator[sqlite3.Connection]:
        with self._lock:
            self._conn.execute("BEGIN IMMEDIATE;")
            try:
                yield self._conn
                self._conn.execute("COMMIT;")
            except Exception:
                with contextlib.suppress(Exception):
                    self._conn.execute("ROLLBACK;")
                raise

    @contextlib.contextmanager
    def read(self) -> Iterator[sqlite3.Connection]:
        with self._lock:
            yield self._conn

    def close(self) -> None:
        with self._lock:
            with contextlib.suppress(Exception):
                self._conn.close()


# =============================================================================
# SQLite wealth ledger
# =============================================================================


class SQLiteAlphaWealthLedger(AlphaWealthLedger):
    def __init__(self, path: str = "tcd.db", *, config: Optional[StorageConfig] = None) -> None:
        self._cfg = config or StorageConfig()
        self._db = _SQLite(path, cfg=self._cfg)

    def peek(self, subject: Subject, *, policy_ref: str = "default", state_domain_id: str = "default") -> Optional[float]:
        subj, _ = _subject_and_hash(subject, self._cfg)
        pol = _safe_id(policy_ref, default="default", max_len=self._cfg.policy_ref_max_bytes) or "default"
        sd = _safe_id(state_domain_id, default="default", max_len=256) or "default"
        with self._db.read() as conn:
            row = conn.execute(
                "SELECT wealth FROM wealth_state_current WHERE tenant=? AND user=? AND session=? AND policy_ref=? AND state_domain_id=?",
                (subj[0], subj[1], subj[2], pol, sd),
            ).fetchone()
        return None if row is None else float(row["wealth"])

    def get(self, subject: Subject, *, policy_ref: str = "default", state_domain_id: str = "default", default_alpha0: float = 0.05) -> float:
        cur = self.peek(subject, policy_ref=policy_ref, state_domain_id=state_domain_id)
        return float(cur) if cur is not None else max(float(default_alpha0), float(self._cfg.alpha0_floor))

    def get_or_create(self, subject: Subject, *, policy_ref: str = "default", state_domain_id: str = "default", default_alpha0: float = 0.05) -> float:
        subj, subj_hash = _subject_and_hash(subject, self._cfg)
        pol = _safe_id(policy_ref, default="default", max_len=self._cfg.policy_ref_max_bytes) or "default"
        sd = _safe_id(state_domain_id, default="default", max_len=256) or "default"
        alpha0 = max(float(default_alpha0), float(self._cfg.alpha0_floor))
        with self._db.tx() as conn:
            row = conn.execute(
                "SELECT wealth FROM wealth_state_current WHERE tenant=? AND user=? AND session=? AND policy_ref=? AND state_domain_id=?",
                (subj[0], subj[1], subj[2], pol, sd),
            ).fetchone()
            if row is not None:
                return float(row["wealth"])
            payload = {
                "tenant": subj[0],
                "user": subj[1],
                "session": subj[2],
                "subject_hash": subj_hash,
                "policy_ref": pol,
                "state_domain_id": sd,
                "adapter_registry_fp": None,
                "wealth": alpha0,
                "alpha0": alpha0,
                "state_revision": 0,
                "created_at_unix_ns": now_unix_ns(),
                "updated_at_unix_ns": now_unix_ns(),
            }
            _sqlite_insert(conn, "wealth_state_current", payload)
            return alpha0

    def _row_to_event(self, row: sqlite3.Row) -> WealthEventRecord:
        return WealthEventRecord(
            store_id=int(row["store_id"]),
            event_id=row["event_id"],
            idem_key=row["idem_key"],
            subject=(row["tenant"], row["user"], row["session"]),
            subject_hash=row["subject_hash"],
            policy_ref=row["policy_ref"],
            state_domain_id=row["state_domain_id"],
            adapter_registry_fp=row["adapter_registry_fp"],
            ts_unix_ns=int(row["ts_unix_ns"]),
            state_revision=int(row["state_revision"]),
            wealth_before=float(row["wealth_before"]),
            wealth_after=float(row["wealth_after"]),
            alpha_spent=float(row["alpha_spent"]),
            earn=float(row["earn"]),
            reward=float(row["reward"]),
            reject=bool(row["reject_flag"]),
            reason_code=row["reason_code"],
            trust_zone=row["trust_zone"],
            route_profile=row["route_profile"],
            route_plan_id=row["route_plan_id"],
            decision_id=row["decision_id"],
            signal_digest=row["signal_digest"],
            context_digest=row["context_digest"],
            selected_source=row["selected_source"],
            controller_mode=row["controller_mode"],
            decision_mode=row["decision_mode"],
            statistical_guarantee_scope=row["statistical_guarantee_scope"],
            identity_status=row["identity_status"],
            audit_ref=row["audit_ref"],
            receipt_ref=row["receipt_ref"],
            degraded_reasons=_json_tuple_from_text(row["degraded_reasons_json"] or "[]", max_items=32),
            meta=MappingProxyType(_safe_json_mapping(_json_loads_strict(row["meta_json"]) if row["meta_json"] else {})),
            event_fingerprint=row["event_fingerprint"],
        )

    def apply(self, subject: Subject, step: WealthStep, *, default_alpha0: float = 0.05) -> WealthApplyResult:
        subj, subj_hash = _subject_and_hash(subject, self._cfg)
        step_n = step.normalized(cfg=self._cfg)
        fp = step_n.event_fingerprint(subject_hash=subj_hash)
        alpha0 = max(float(default_alpha0), float(self._cfg.alpha0_floor))
        now_ns = step_n.ts_unix_ns or now_unix_ns()

        with self._db.tx() as conn:
            if step_n.event_id:
                row = conn.execute("SELECT * FROM wealth_event_log WHERE event_id=?", (step_n.event_id,)).fetchone()
                if row is not None:
                    old = self._row_to_event(row)
                    if old.event_fingerprint != fp or old.subject != subj or old.policy_ref != step_n.policy_ref or old.state_domain_id != step_n.state_domain_id:
                        raise StorageConflictError("event_id already exists with different fingerprint")
                    return WealthApplyResult(
                        stored=False,
                        idempotent=True,
                        event_id=old.event_id,
                        idem_key=old.idem_key,
                        policy_ref=old.policy_ref,
                        state_domain_id=old.state_domain_id,
                        subject_hash=old.subject_hash,
                        state_revision=old.state_revision,
                        wealth_before=old.wealth_before,
                        wealth_after=old.wealth_after,
                        alpha_spent=old.alpha_spent,
                        earn=old.earn,
                        reward=old.reward,
                        reject=old.reject,
                        reason_code=old.reason_code,
                        event_fingerprint=old.event_fingerprint,
                        ts_unix_ns=old.ts_unix_ns,
                        audit_ref=old.audit_ref,
                        receipt_ref=old.receipt_ref,
                    )

            if step_n.idem_key:
                row = conn.execute(
                    "SELECT * FROM wealth_event_log WHERE tenant=? AND user=? AND session=? AND policy_ref=? AND state_domain_id=? AND idem_key=?",
                    (subj[0], subj[1], subj[2], step_n.policy_ref, step_n.state_domain_id, step_n.idem_key),
                ).fetchone()
                if row is not None:
                    old2 = self._row_to_event(row)
                    if old2.event_fingerprint != fp:
                        raise StorageConflictError("idem_key already exists with different fingerprint")
                    return WealthApplyResult(
                        stored=False,
                        idempotent=True,
                        event_id=old2.event_id,
                        idem_key=old2.idem_key,
                        policy_ref=old2.policy_ref,
                        state_domain_id=old2.state_domain_id,
                        subject_hash=old2.subject_hash,
                        state_revision=old2.state_revision,
                        wealth_before=old2.wealth_before,
                        wealth_after=old2.wealth_after,
                        alpha_spent=old2.alpha_spent,
                        earn=old2.earn,
                        reward=old2.reward,
                        reject=old2.reject,
                        reason_code=old2.reason_code,
                        event_fingerprint=old2.event_fingerprint,
                        ts_unix_ns=old2.ts_unix_ns,
                        audit_ref=old2.audit_ref,
                        receipt_ref=old2.receipt_ref,
                    )

            row = conn.execute(
                "SELECT wealth, alpha0, state_revision, created_at_unix_ns, updated_at_unix_ns FROM wealth_state_current WHERE tenant=? AND user=? AND session=? AND policy_ref=? AND state_domain_id=?",
                (subj[0], subj[1], subj[2], step_n.policy_ref, step_n.state_domain_id),
            ).fetchone()
            if row is None:
                wealth_before = alpha0
                current_revision = 0
                created_ns = now_ns
                payload = {
                    "tenant": subj[0],
                    "user": subj[1],
                    "session": subj[2],
                    "subject_hash": subj_hash,
                    "policy_ref": step_n.policy_ref,
                    "state_domain_id": step_n.state_domain_id,
                    "adapter_registry_fp": step_n.adapter_registry_fp,
                    "wealth": alpha0,
                    "alpha0": alpha0,
                    "state_revision": 0,
                    "created_at_unix_ns": created_ns,
                    "updated_at_unix_ns": now_ns,
                }
                _sqlite_insert(conn, "wealth_state_current", payload)
            else:
                wealth_before = float(row["wealth"])
                current_revision = int(row["state_revision"])
                created_ns = int(row["created_at_unix_ns"])

            if step_n.expected_state_revision is not None and current_revision != step_n.expected_state_revision:
                raise StorageConflictError("state revision mismatch")

            wealth_after = max(0.0, wealth_before - step_n.alpha_spent + (step_n.earn if step_n.reject else 0.0) + step_n.reward)
            new_revision = current_revision + 1
            conn.execute(
                "UPDATE wealth_state_current SET wealth=?, adapter_registry_fp=?, state_revision=?, updated_at_unix_ns=? WHERE tenant=? AND user=? AND session=? AND policy_ref=? AND state_domain_id=?",
                (
                    wealth_after,
                    step_n.adapter_registry_fp,
                    new_revision,
                    now_ns,
                    subj[0],
                    subj[1],
                    subj[2],
                    step_n.policy_ref,
                    step_n.state_domain_id,
                ),
            )

            payload = {
                "event_id": step_n.event_id,
                "idem_key": step_n.idem_key,
                "tenant": subj[0],
                "user": subj[1],
                "session": subj[2],
                "subject_hash": subj_hash,
                "policy_ref": step_n.policy_ref,
                "state_domain_id": step_n.state_domain_id,
                "adapter_registry_fp": step_n.adapter_registry_fp,
                "expected_state_revision": step_n.expected_state_revision,
                "state_revision": new_revision,
                "ts_unix_ns": now_ns,
                "wealth_before": wealth_before,
                "wealth_after": wealth_after,
                "alpha_spent": step_n.alpha_spent,
                "earn": step_n.earn if step_n.reject else 0.0,
                "reward": step_n.reward,
                "reject_flag": 1 if step_n.reject else 0,
                "reason_code": step_n.reason_code,
                "trust_zone": step_n.trust_zone,
                "route_profile": step_n.route_profile,
                "route_plan_id": step_n.route_plan_id,
                "decision_id": step_n.decision_id,
                "signal_digest": step_n.signal_digest,
                "context_digest": step_n.context_digest,
                "selected_source": step_n.selected_source,
                "controller_mode": step_n.controller_mode,
                "decision_mode": step_n.decision_mode,
                "statistical_guarantee_scope": step_n.statistical_guarantee_scope,
                "identity_status": step_n.identity_status,
                "audit_ref": step_n.audit_ref,
                "receipt_ref": step_n.receipt_ref,
                "degraded_reasons_json": _canonical_json_str(list(step_n.degraded_reasons)),
                "meta_json": _canonical_json_str(dict(step_n.meta)),
                "event_fingerprint": fp,
            }
            cur = _sqlite_insert(conn, "wealth_event_log", payload)
            store_id = int(cur.lastrowid)

            return WealthApplyResult(
                stored=True,
                idempotent=False,
                event_id=step_n.event_id,
                idem_key=step_n.idem_key,
                policy_ref=step_n.policy_ref,
                state_domain_id=step_n.state_domain_id,
                subject_hash=subj_hash,
                state_revision=new_revision,
                wealth_before=wealth_before,
                wealth_after=wealth_after,
                alpha_spent=step_n.alpha_spent,
                earn=(step_n.earn if step_n.reject else 0.0),
                reward=step_n.reward,
                reject=step_n.reject,
                reason_code=step_n.reason_code,
                event_fingerprint=fp,
                ts_unix_ns=now_ns,
                audit_ref=step_n.audit_ref,
                receipt_ref=step_n.receipt_ref,
            )

    def get_event(self, event_id: str) -> Optional[WealthEventRecord]:
        eid = _safe_id(event_id, default=None, max_len=256)
        if eid is None:
            return None
        with self._db.read() as conn:
            row = conn.execute("SELECT * FROM wealth_event_log WHERE event_id=?", (eid,)).fetchone()
        return self._row_to_event(row) if row is not None else None

    def page_events(
        self,
        subject: Subject,
        *,
        policy_ref: str = "default",
        state_domain_id: str = "default",
        limit: int = 100,
        after_event_id: Optional[str] = None,
    ) -> List[WealthEventRecord]:
        subj, _ = _subject_and_hash(subject, self._cfg)
        pol = _safe_id(policy_ref, default="default", max_len=self._cfg.policy_ref_max_bytes) or "default"
        sd = _safe_id(state_domain_id, default="default", max_len=256) or "default"
        lim = max(1, min(self._cfg.max_page_size, int(limit)))
        after_ts = None
        after_eid = None
        if after_event_id:
            with self._db.read() as conn:
                row = conn.execute(
                    "SELECT ts_unix_ns, event_id FROM wealth_event_log WHERE event_id=?",
                    (_safe_id(after_event_id, default="", max_len=256),),
                ).fetchone()
            if row is not None:
                after_ts = int(row["ts_unix_ns"])
                after_eid = row["event_id"]

        sql = """
            SELECT * FROM wealth_event_log
            WHERE tenant=? AND user=? AND session=? AND policy_ref=? AND state_domain_id=?
        """
        params: List[Any] = [subj[0], subj[1], subj[2], pol, sd]
        if after_ts is not None:
            sql += " AND (ts_unix_ns > ? OR (ts_unix_ns = ? AND COALESCE(event_id,'') > ?))"
            params.extend([after_ts, after_ts, after_eid or ""])
        sql += " ORDER BY ts_unix_ns ASC, COALESCE(event_id,'' ) ASC, store_id ASC LIMIT ?"
        params.append(lim)

        with self._db.read() as conn:
            rows = list(conn.execute(sql, tuple(params)))
        return [self._row_to_event(r) for r in rows]

    def recompute_subject_state(self, subject: Subject, *, policy_ref: str = "default", state_domain_id: str = "default", default_alpha0: float = 0.05) -> Dict[str, Any]:
        events = self.page_events(subject, policy_ref=policy_ref, state_domain_id=state_domain_id, limit=self._cfg.max_page_size)
        wealth = max(float(default_alpha0), float(self._cfg.alpha0_floor))
        if events:
            wealth = max(0.0, events[0].wealth_before)
            for ev in events:
                wealth = max(0.0, wealth - ev.alpha_spent + (ev.earn if ev.reject else 0.0) + ev.reward)
        return {
            "schema": _WEALTH_SCHEMA,
            "policy_ref": policy_ref,
            "state_domain_id": state_domain_id,
            "event_count": len(events),
            "wealth_recomputed": wealth,
            "last_state_revision": events[-1].state_revision if events else 0,
        }

    def verify_subject_state(self, subject: Subject, *, policy_ref: str = "default", state_domain_id: str = "default", default_alpha0: float = 0.05) -> Dict[str, Any]:
        recomputed = self.recompute_subject_state(subject, policy_ref=policy_ref, state_domain_id=state_domain_id, default_alpha0=default_alpha0)
        current = self.get(subject, policy_ref=policy_ref, state_domain_id=state_domain_id, default_alpha0=default_alpha0)
        ok = abs(float(recomputed["wealth_recomputed"]) - float(current)) <= 1e-12
        return {
            "schema": _WEALTH_SCHEMA,
            "ok": ok,
            "policy_ref": policy_ref,
            "state_domain_id": state_domain_id,
            "wealth_current": current,
            "wealth_recomputed": recomputed["wealth_recomputed"],
            "last_state_revision": recomputed["last_state_revision"],
        }

    def snapshot_subject(self, subject: Subject, *, policy_ref: str = "default", state_domain_id: str = "default", default_alpha0: float = 0.05) -> Dict[str, Any]:
        subj, subj_hash = _subject_and_hash(subject, self._cfg)
        pol = _safe_id(policy_ref, default="default", max_len=self._cfg.policy_ref_max_bytes) or "default"
        sd = _safe_id(state_domain_id, default="default", max_len=256) or "default"
        wealth = self.get(subject, policy_ref=pol, state_domain_id=sd, default_alpha0=default_alpha0)
        events = self.page_events(subject, policy_ref=pol, state_domain_id=sd, limit=50)
        return {
            "schema": _WEALTH_SCHEMA,
            "compatibility_epoch": _STORAGE_COMPATIBILITY_EPOCH,
            "subject": {"subject_hash": subj_hash, "tenant": subj[0], "user": subj[1], "session": subj[2]},
            "policy_ref": pol,
            "state_domain_id": sd,
            "wealth": wealth,
            "events": [e.to_dict() for e in events],
        }

    def stats(self) -> Dict[str, Any]:
        with self._db.read() as conn:
            wealth_subjects = int(conn.execute("SELECT COUNT(*) AS n FROM wealth_state_current").fetchone()["n"])
            wealth_events = int(conn.execute("SELECT COUNT(*) AS n FROM wealth_event_log").fetchone()["n"])
        return {
            "backend": "sqlite",
            "profile": self._cfg.profile,
            "wealth_subjects": wealth_subjects,
            "wealth_events": wealth_events,
            "db_path": self._db._path,
            "compatibility_epoch": _STORAGE_COMPATIBILITY_EPOCH,
        }


# =============================================================================
# Shared receipt planning helpers
# =============================================================================


def _resolve_prev_record(
    ref: str,
    *,
    chain_namespace: str,
    chain_id: str,
    by_receipt_head: Mapping[str, ReceiptRecord],
    by_chain_head: Mapping[str, ReceiptRecord],
) -> Optional[ReceiptRecord]:
    rec = by_chain_head.get(ref)
    if rec is not None and rec.chain_namespace == chain_namespace and rec.chain_id == chain_id:
        return rec
    rec = by_receipt_head.get(ref)
    if rec is not None and rec.chain_namespace == chain_namespace and rec.chain_id == chain_id:
        return rec
    return None


def _chain_rows_sorted(rows: Iterable[ReceiptRecord]) -> List[ReceiptRecord]:
    out = list(rows)
    out.sort(
        key=lambda r: (
            -1 if r.chain_seq is None else int(r.chain_seq),
            0 if r.ts_unix_ns is None else int(r.ts_unix_ns),
            0 if r.store_id is None else int(r.store_id),
        )
    )
    return out


def _chain_leaves(rows: Iterable[ReceiptRecord]) -> List[ReceiptRecord]:
    xs = list(rows)
    prevs = {r.prev_chain_head_hex for r in xs if r.prev_chain_head_hex}
    leaves = [r for r in xs if r.chain_head_hex not in prevs]
    leaves.sort(
        key=lambda r: (
            -1 if r.chain_seq is None else int(r.chain_seq),
            0 if r.ts_unix_ns is None else int(r.ts_unix_ns),
            0 if r.store_id is None else int(r.store_id),
        ),
        reverse=True,
    )
    return leaves


def _latest_chain_row(rows: Iterable[ReceiptRecord]) -> Optional[ReceiptRecord]:
    xs = _chain_rows_sorted(rows)
    return xs[-1] if xs else None


def _verify_receipt_chain_rows(
    chain_rows: Sequence[ReceiptRecord],
    *,
    start: Optional[ReceiptRecord],
    cfg: StorageConfig,
    chain_namespace: str,
    chain_id: str,
    limit: int,
    expected_latest_chain_head_hex: Optional[str] = None,
) -> VerifyWindowReport:
    lim = max(1, min(cfg.max_page_size, int(limit)))
    expected_latest = _safe_text_or_none(expected_latest_chain_head_hex, max_len=512)
    ns = _safe_id(chain_namespace, default=cfg.default_chain_namespace, max_len=_MAX_CHAIN_ID_BYTES) or cfg.default_chain_namespace
    cid = _safe_id(chain_id, default=cfg.default_chain_id, max_len=_MAX_CHAIN_ID_BYTES) or cfg.default_chain_id

    if start is None:
        reasons = ("expected_latest_missing",) if expected_latest else tuple()
        return VerifyWindowReport(
            ok=not bool(reasons),
            checked=0,
            links_checked=0,
            duplicates=0,
            forks=0,
            cycles=0,
            missing_prev=0,
            bad_heads=0,
            bad_rows=0,
            latest_head_hex=None,
            latest_chain_head_hex=None,
            chain_namespace=ns,
            chain_id=cid,
            genesis_count=0,
            tip_count=0,
            unselected=0,
            expected_latest_chain_head_hex=expected_latest,
            latest_matches_expected=False if expected_latest else None,
            reasons=reasons,
            rows=tuple(),
        )

    ns = start.chain_namespace or ns
    cid = start.chain_id or cid
    rows = [
        r for r in list(chain_rows)
        if (r.chain_namespace or ns) == ns and (r.chain_id or cid) == cid
    ]
    if not rows:
        rows = [start]

    by_chain: Dict[str, ReceiptRecord] = {}
    chain_heads: List[str] = []
    receipt_heads: List[str] = []
    seqs: List[int] = []
    reasons: List[str] = []
    bad_heads = 0

    for row in rows:
        rh = _safe_text(row.head_hex, max_len=512)
        ch = _safe_text(row.chain_head_hex, max_len=512)
        if rh:
            receipt_heads.append(rh)
        else:
            reasons.append("receipt_head_missing")
            bad_heads += 1

        if ch:
            chain_heads.append(ch)
            by_chain.setdefault(ch, row)
        else:
            reasons.append("chain_head_missing")
            bad_heads += 1

        if row.chain_seq is not None:
            seqs.append(int(row.chain_seq))

    duplicate_receipt_heads = len(receipt_heads) - len(set(receipt_heads))
    duplicate_chain_heads = len(chain_heads) - len(set(chain_heads))
    duplicate_chain_seqs = len(seqs) - len(set(seqs))
    duplicates = max(0, duplicate_receipt_heads) + max(0, duplicate_chain_heads) + max(0, duplicate_chain_seqs)

    if duplicate_receipt_heads:
        reasons.append("duplicate_receipt_head")
    if duplicate_chain_heads:
        reasons.append("duplicate_chain_head")
    if duplicate_chain_seqs:
        reasons.append("duplicate_chain_seq")

    children_by_prev: Dict[str, List[ReceiptRecord]] = {}
    referenced_prev = set()
    missing_prev = 0

    for row in rows:
        prev = _safe_text(row.prev_chain_head_hex, max_len=512)
        if not prev:
            continue
        referenced_prev.add(prev)
        children_by_prev.setdefault(prev, []).append(row)
        if prev not in by_chain:
            missing_prev += 1
            reasons.append("missing_prev")

    genesis_count = sum(1 for r in rows if not _safe_text(r.prev_chain_head_hex, max_len=512))
    if genesis_count != 1:
        reasons.append("single_genesis_violation")

    forks = len([prev for prev, children in children_by_prev.items() if len(children) > 1])
    if forks:
        reasons.append("fork_detected")

    tip_rows = [
        r for r in rows
        if _safe_text(r.chain_head_hex, max_len=512)
        and _safe_text(r.chain_head_hex, max_len=512) not in referenced_prev
    ]
    tip_count = len(tip_rows)
    if rows and tip_count != 1:
        reasons.append("tip_count_violation")

    latest_rec = _latest_chain_row(rows) or start
    latest_chain_head = _safe_text(latest_rec.chain_head_hex, max_len=512) or None
    latest_matches_expected: Optional[bool] = None

    if expected_latest:
        latest_matches_expected = bool(latest_chain_head and hmac.compare_digest(latest_chain_head, expected_latest))
        if not latest_matches_expected:
            reasons.append("latest_chain_head_mismatch")

    cur: Optional[ReceiptRecord] = start
    seen = set()
    rows_seen: List[str] = []
    links_checked = 0
    cycles = 0
    bad_rows = 0
    steps = 0
    limit_exceeded = False

    while cur is not None:
        if steps >= lim:
            limit_exceeded = True
            reasons.append("window_limit_exceeded")
            break

        steps += 1
        ch = _safe_text(cur.chain_head_hex, max_len=512) or f"missing:{_safe_text(cur.head_hex, max_len=512)}"

        if ch in seen:
            cycles += 1
            reasons.append("cycle_detected")
            break

        seen.add(ch)
        rows_seen.append(cur.head_hex)

        try:
            expected_chain_head = _compute_chain_head(
                chain_namespace=cur.chain_namespace or ns,
                chain_id=cur.chain_id or cid,
                prev_chain_head_hex=cur.prev_chain_head_hex,
                receipt_head_hex=cur.head_hex,
                body_digest=cur.body_digest or _receipt_body_digest(cur.body_json),
                payload_digest=cur.payload_digest or cur.body_digest or _receipt_body_digest(cur.body_json),
                sig_value=cur.sig or "",
                head_semantics=cur.head_semantics,
            )
            if cur.chain_head_hex != expected_chain_head:
                bad_heads += 1
                reasons.append("chain_head_mismatch")
        except Exception:
            bad_heads += 1
            reasons.append("chain_head_compute_error")

        row_issues = _receipt_row_integrity_issues(cur, cfg=cfg)
        if row_issues:
            bad_rows += 1
            reasons.extend(row_issues)

        prev_ref = _safe_text(cur.prev_chain_head_hex, max_len=512)
        if prev_ref:
            prev = by_chain.get(prev_ref)
            if prev is None:
                break
            links_checked += 1
            if prev.chain_seq is not None and cur.chain_seq is not None and int(prev.chain_seq) >= int(cur.chain_seq):
                bad_rows += 1
                reasons.append("prev_seq_not_less_than_current")
            cur = prev
        else:
            cur = None

    unselected = max(0, len(rows) - len(seen))
    if unselected:
        reasons.append("window_contains_unselected_rows")

    ok = (
        bad_heads == 0
        and bad_rows == 0
        and missing_prev == 0
        and cycles == 0
        and duplicates == 0
        and forks == 0
        and genesis_count == 1
        and tip_count == 1
        and unselected == 0
        and not limit_exceeded
        and latest_matches_expected is not False
    )

    return VerifyWindowReport(
        ok=bool(ok),
        checked=steps,
        links_checked=links_checked,
        duplicates=duplicates,
        forks=forks,
        cycles=cycles,
        missing_prev=missing_prev,
        bad_heads=bad_heads,
        bad_rows=bad_rows,
        latest_head_hex=latest_rec.head_hex,
        latest_chain_head_hex=latest_chain_head,
        chain_namespace=ns,
        chain_id=cid,
        genesis_count=genesis_count,
        tip_count=tip_count,
        unselected=unselected,
        expected_latest_chain_head_hex=expected_latest,
        latest_matches_expected=latest_matches_expected,
        reasons=tuple(sorted(set(reasons))),
        rows=tuple(rows_seen),
    )


# =============================================================================
# In-memory receipt store
# =============================================================================


class InMemoryReceiptStore(ReceiptStore):
    def __init__(self, *, config: Optional[StorageConfig] = None) -> None:
        self._cfg = config or StorageConfig()
        self._lock = threading.RLock()
        self._by_head: Dict[str, ReceiptRecord] = {}
        self._by_chain_head: Dict[str, ReceiptRecord] = {}
        self._by_event_id: Dict[str, str] = {}
        self._by_decision_id: Dict[str, str] = {}
        self._global_order: List[str] = []
        self._next_id = 1

    def _rows_for_chain(self, chain_namespace: str, chain_id: str) -> List[ReceiptRecord]:
        rows = [r for r in self._by_head.values() if r.chain_namespace == chain_namespace and r.chain_id == chain_id]
        rows.sort(
            key=lambda r: (
                -1 if r.chain_seq is None else int(r.chain_seq),
                0 if r.ts_unix_ns is None else int(r.ts_unix_ns),
                0 if r.store_id is None else int(r.store_id),
            )
        )
        return rows

    def _plan_batch(self, envs: Sequence[ReceiptEnvelope]) -> Tuple[List[ReceiptRecord], List[PutResult]]:
        staged_by_head = dict(self._by_head)
        staged_by_chain_head = dict(self._by_chain_head)
        staged_by_event = dict(self._by_event_id)
        staged_by_decision = dict(self._by_decision_id)
        planned: List[ReceiptRecord] = []
        results: List[PutResult] = []

        for env in envs:
            existing = staged_by_head.get(env.head_hex)
            if existing is not None:
                if _receipt_input_equivalent(existing, env, cfg=self._cfg):
                    results.append(
                        PutResult(
                            stored=False,
                            idempotent=True,
                            conflict=False,
                            head_hex=existing.head_hex,
                            chain_head_hex=existing.chain_head_hex,
                            store_backend="memory",
                            store_id=existing.store_id,
                            event_id=existing.event_id,
                            decision_id=existing.decision_id,
                            chain_namespace=existing.chain_namespace or self._cfg.default_chain_namespace,
                            chain_id=existing.chain_id or self._cfg.default_chain_id,
                            chain_seq=existing.chain_seq,
                            receipt_ref=existing.receipt_ref,
                            audit_ref=existing.audit_ref,
                            body_digest=existing.body_digest,
                            payload_digest=existing.payload_digest,
                            ledger_ref=existing.ledger_ref,
                            attestation_ref=existing.attestation_ref,
                            prepare_ref=existing.prepare_ref,
                            commit_ref=existing.commit_ref,
                            outbox_ref=existing.outbox_ref,
                            reason="idempotent_head",
                        )
                    )
                    continue
                raise StorageConflictError("receipt head already exists with different semantic fingerprint")

            if env.event_id and env.event_id in staged_by_event:
                old = staged_by_head[staged_by_event[env.event_id]]
                if old.head_hex != env.head_hex:
                    raise StorageConflictError("event_id already exists with different head")
            if env.decision_id and env.decision_id in staged_by_decision:
                old2 = staged_by_head[staged_by_decision[env.decision_id]]
                if old2.head_hex != env.head_hex:
                    raise StorageConflictError("decision_id already exists with different head")

            chain_namespace = env.chain_namespace or self._cfg.default_chain_namespace
            chain_id = env.chain_id or self._cfg.default_chain_id
            chain_rows = self._rows_for_chain(chain_namespace, chain_id) + [r for r in planned if r.chain_namespace == chain_namespace and r.chain_id == chain_id]
            latest = _latest_chain_row(chain_rows)
            leaves = _chain_leaves(chain_rows)

            if self._cfg.fail_closed_on_chain_ambiguity and len(leaves) > 1:
                raise StorageConflictError("chain has ambiguous multiple leaves")

            append_latest_requested = _receipt_append_latest_requested(env)
            server_assign_position = bool(self._cfg.server_assign_receipt_chain_position) and (env.prev_head_hex is None or append_latest_requested)

            resolved_prev: Optional[ReceiptRecord] = None
            if server_assign_position:
                if chain_rows:
                    if self._cfg.fail_closed_on_chain_ambiguity and len(leaves) > 1:
                        raise StorageConflictError("chain has ambiguous multiple leaves")
                    resolved_prev = leaves[0] if leaves else latest
                else:
                    resolved_prev = None
            elif env.prev_head_hex is None:
                if chain_rows and self._cfg.enforce_single_genesis_per_chain:
                    raise StorageConflictError("single genesis per chain violated")
            else:
                resolved_prev = _resolve_prev_record(
                    env.prev_head_hex,
                    chain_namespace=chain_namespace,
                    chain_id=chain_id,
                    by_receipt_head=staged_by_head,
                    by_chain_head=staged_by_chain_head,
                )
                if resolved_prev is None:
                    raise StorageConflictError("prev_head_hex not found in same chain")
                if env.head_hex in {resolved_prev.head_hex, resolved_prev.chain_head_hex}:
                    raise StorageIntegrityError("receipt self-loop not allowed")
                if self._cfg.require_chain_leaf_append:
                    if len(leaves) > 1:
                        raise StorageConflictError("cannot append when chain leaf is ambiguous")
                    if leaves and leaves[0].chain_head_hex != resolved_prev.chain_head_hex:
                        raise StorageConflictError("strict chain append requires prev == current leaf")

            requested_seq = None if server_assign_position else env.chain_seq
            prev_row_seq = resolved_prev.chain_seq if resolved_prev is not None else None
            latest_seq = latest.chain_seq if latest is not None else None
            final_seq = (requested_seq if requested_seq is not None else ((prev_row_seq + 1) if prev_row_seq is not None else ((latest_seq + 1) if latest_seq is not None else 0)))
            if final_seq < 0:
                raise StorageIntegrityError("invalid chain_seq")
            for row in chain_rows:
                if row.chain_seq == final_seq:
                    raise StorageConflictError("chain_seq already exists")
                if resolved_prev is not None and row.prev_chain_head_hex == resolved_prev.chain_head_hex:
                    raise StorageConflictError("fork detected: prev already consumed")
                if (not server_assign_position) and env.prev_head_hex is None and row.prev_chain_head_hex is None and self._cfg.enforce_single_genesis_per_chain:
                    raise StorageConflictError("single genesis per chain violated")

            prev_chain_head_hex = resolved_prev.chain_head_hex if resolved_prev is not None else None
            chain_head_hex = _compute_chain_head(
                chain_namespace=chain_namespace,
                chain_id=chain_id,
                prev_chain_head_hex=prev_chain_head_hex,
                receipt_head_hex=env.head_hex,
                body_digest=env.body_digest or _receipt_body_digest(env.body_json),
                payload_digest=env.payload_digest or env.body_digest or _receipt_body_digest(env.body_json),
                sig_value=env.sig or "",
                head_semantics=env.head_semantics,
            )
            if chain_head_hex in staged_by_chain_head:
                raise StorageConflictError("chain_head already exists")

            semantic_fp = _semantic_fingerprint(env)
            record = ReceiptRecord(
                **{
                    **_dataclass_shallow_dict(env),
                    "chain_head_hex": chain_head_hex,
                    "prev_head_hex": prev_chain_head_hex,
                    "prev_chain_head_hex": prev_chain_head_hex,
                    "chain_namespace": chain_namespace,
                    "chain_id": chain_id,
                    "chain_seq": final_seq,
                    "semantic_fingerprint": semantic_fp,
                    "store_backend": "memory",
                    "store_id": None,
                    "inserted_at_unix_ns": None,
                    "updated_at_unix_ns": None,
                }
            )
            staged_by_head[record.head_hex] = record
            staged_by_chain_head[record.chain_head_hex or ""] = record
            if record.event_id:
                staged_by_event[record.event_id] = record.head_hex
            if record.decision_id:
                staged_by_decision[record.decision_id] = record.head_hex
            planned.append(record)

        return planned, results

    def put_receipt(self, rec: ReceiptEnvelope) -> PutResult:
        result = self.put_chain([rec])
        if result.results:
            return result.results[-1]
        raise StorageError("put_chain returned no result")

    def put_chain(self, records: Sequence[ReceiptEnvelope]) -> PutChainResult:
        envs = [r.normalized(cfg=self._cfg) for r in records]
        with self._lock:
            planned, results = self._plan_batch(envs)
            now_ns = now_unix_ns()
            last_chain_head = None
            first_head = None
            chain_ns = None
            chain_id = None
            for rec in planned:
                store_id = self._next_id
                self._next_id += 1
                stored = rec.with_backend(store_backend="memory", store_id=store_id, inserted_at_unix_ns=now_ns, updated_at_unix_ns=now_ns)
                self._by_head[stored.head_hex] = stored
                if stored.chain_head_hex:
                    self._by_chain_head[stored.chain_head_hex] = stored
                if stored.event_id:
                    self._by_event_id[stored.event_id] = stored.head_hex
                if stored.decision_id:
                    self._by_decision_id[stored.decision_id] = stored.head_hex
                self._global_order.append(stored.head_hex)
                last_chain_head = stored.chain_head_hex
                if first_head is None:
                    first_head = stored.head_hex
                    chain_ns = stored.chain_namespace
                    chain_id = stored.chain_id
                results.append(
                    PutResult(
                        stored=True,
                        idempotent=False,
                        conflict=False,
                        head_hex=stored.head_hex,
                        chain_head_hex=stored.chain_head_hex,
                        store_backend="memory",
                        store_id=stored.store_id,
                        event_id=stored.event_id,
                        decision_id=stored.decision_id,
                        chain_namespace=stored.chain_namespace or self._cfg.default_chain_namespace,
                        chain_id=stored.chain_id or self._cfg.default_chain_id,
                        chain_seq=stored.chain_seq,
                        receipt_ref=stored.receipt_ref,
                        audit_ref=stored.audit_ref,
                        body_digest=stored.body_digest,
                        payload_digest=stored.payload_digest,
                        ledger_ref=stored.ledger_ref,
                        attestation_ref=stored.attestation_ref,
                        prepare_ref=stored.prepare_ref,
                        commit_ref=stored.commit_ref,
                        outbox_ref=stored.outbox_ref,
                        reason="stored",
                        warnings=stored.normalization_warnings + stored.compat_warnings,
                    )
                )
            return PutChainResult(
                stored_count=len([r for r in results if r.stored]),
                idempotent_count=len([r for r in results if r.idempotent]),
                conflict_at_index=None,
                chain_namespace=chain_ns,
                chain_id=chain_id,
                first_head_hex=first_head,
                latest_chain_head_hex=last_chain_head,
                results=tuple(results),
            )

    def get_record_by_head(self, head_hex: str) -> Optional[ReceiptRecord]:
        key = _normalize_head_token(head_hex)
        with self._lock:
            return self._by_head.get(key)

    def get_record_by_chain_head(self, chain_head_hex: str) -> Optional[ReceiptRecord]:
        key = _safe_text_or_none(chain_head_hex, max_len=512)
        if not key:
            return None
        with self._lock:
            return self._by_chain_head.get(key)

    def get_record_by_event_id(self, event_id: str) -> Optional[ReceiptRecord]:
        eid = _safe_id(event_id, default=None, max_len=256)
        if eid is None:
            return None
        with self._lock:
            head = self._by_event_id.get(eid)
            return self._by_head.get(head) if head else None

    def get_record_by_decision_id(self, decision_id: str) -> Optional[ReceiptRecord]:
        did = _safe_id(decision_id, default=None, max_len=256)
        if did is None:
            return None
        with self._lock:
            head = self._by_decision_id.get(did)
            return self._by_head.get(head) if head else None

    def latest(self, *, chain_namespace: Optional[str] = None, chain_id: Optional[str] = None) -> Optional[ReceiptRecord]:
        ns = _safe_id(chain_namespace, default=self._cfg.default_chain_namespace, max_len=_MAX_CHAIN_ID_BYTES) or self._cfg.default_chain_namespace
        cid = _safe_id(chain_id, default=self._cfg.default_chain_id, max_len=_MAX_CHAIN_ID_BYTES) or self._cfg.default_chain_id
        with self._lock:
            rows = self._rows_for_chain(ns, cid)
            return rows[-1] if rows else None

    def page_chain(
        self,
        *,
        chain_namespace: Optional[str] = None,
        chain_id: Optional[str] = None,
        after_seq: Optional[int] = None,
        limit: int = 100,
    ) -> Tuple[List[ReceiptRecord], Optional[str]]:
        ns = _safe_id(chain_namespace, default=self._cfg.default_chain_namespace, max_len=_MAX_CHAIN_ID_BYTES) or self._cfg.default_chain_namespace
        cid = _safe_id(chain_id, default=self._cfg.default_chain_id, max_len=_MAX_CHAIN_ID_BYTES) or self._cfg.default_chain_id
        lim = max(1, min(self._cfg.max_page_size, int(limit)))
        after = _coerce_int(after_seq)
        with self._lock:
            rows = [r for r in self._rows_for_chain(ns, cid) if (after is None or (r.chain_seq is not None and r.chain_seq > after))]
            page = rows[:lim]
            next_cursor = str(page[-1].chain_seq) if page and len(rows) > lim and page[-1].chain_seq is not None else None
            return page, next_cursor


    def verify_window(
        self,
        head_hex: Optional[str] = None,
        *,
        chain_namespace: Optional[str] = None,
        chain_id: Optional[str] = None,
        limit: int = 100,
        expected_latest_chain_head_hex: Optional[str] = None,
    ) -> VerifyWindowReport:
        lim = max(1, min(self._cfg.max_page_size, int(limit)))
        ns = _safe_id(chain_namespace, default=self._cfg.default_chain_namespace, max_len=_MAX_CHAIN_ID_BYTES) or self._cfg.default_chain_namespace
        cid = _safe_id(chain_id, default=self._cfg.default_chain_id, max_len=_MAX_CHAIN_ID_BYTES) or self._cfg.default_chain_id

        with self._lock:
            if head_hex:
                start = self.get_record_by_head(head_hex) or self.get_record_by_chain_head(head_hex)
            else:
                start = self.latest(chain_namespace=ns, chain_id=cid)

            if start is not None:
                ns = start.chain_namespace or ns
                cid = start.chain_id or cid

            chain_rows = self._rows_for_chain(ns, cid) if start is not None else []
            return _verify_receipt_chain_rows(
                chain_rows,
                start=start,
                cfg=self._cfg,
                chain_namespace=ns,
                chain_id=cid,
                limit=lim,
                expected_latest_chain_head_hex=expected_latest_chain_head_hex,
            )

    # legacy interface

    def put(self, head_hex: str, body_json: str) -> None:
        if not self._cfg.allow_legacy_receipt_protocol:
            raise StorageConfigError("legacy receipt protocol disabled")
        try:
            _, parsed = _canonicalize_receipt_body(body_json, cfg=self._cfg)
            fields = _extract_receipt_fields(parsed) if parsed is not None else {}
        except Exception:
            fields = {}
        chain_namespace = _safe_id(fields.get("chain_namespace"), default=None, max_len=_MAX_CHAIN_ID_BYTES)
        chain_id = _safe_id(fields.get("chain_id"), default=None, max_len=_MAX_CHAIN_ID_BYTES)
        prev_head_hex = fields.get("prev_head_hex")
        if not chain_namespace:
            chain_namespace = "legacy"
        if not chain_id:
            # compatibility: each legacy put is isolated unless caller explicitly provides chain info
            chain_id = f"legacy-{_normalize_head_token(head_hex)[:24]}"
        self.put_receipt(
            ReceiptEnvelope(
                head_hex=head_hex,
                body_json=body_json,
                head_semantics="legacy_raw_head",
                chain_namespace=chain_namespace,
                chain_id=chain_id,
                prev_head_hex=prev_head_hex,
            )
        )

    def get(self, head_hex: str) -> Optional[str]:
        rec = self.get_record_by_head(head_hex)
        return rec.body_json if rec else None

    def tail(self, n: int) -> List[Tuple[str, str]]:
        lim = max(1, min(self._cfg.max_tail_size, int(n)))
        with self._lock:
            heads = list(self._global_order[-lim:])
            heads.reverse()
            return [(h, self._by_head[h].body_json) for h in heads if h in self._by_head]

    def page(self, cursor: Optional[str], limit: int) -> Tuple[List[Tuple[str, str]], Optional[str]]:
        lim = max(1, min(self._cfg.max_page_size, int(limit)))
        with self._lock:
            ordered = list(self._global_order)
            ordered.reverse()
            start = 0
            if cursor:
                cur = _normalize_head_token(cursor)
                with contextlib.suppress(ValueError):
                    start = ordered.index(cur) + 1
            page_heads = ordered[start : start + lim]
            next_cursor = page_heads[-1] if page_heads and (start + lim) < len(ordered) else None
            return [(h, self._by_head[h].body_json) for h in page_heads if h in self._by_head], next_cursor

    def stats(self) -> Dict[str, Any]:
        with self._lock:
            chains = {(r.chain_namespace, r.chain_id) for r in self._by_head.values()}
            return {
                "backend": "memory",
                "profile": self._cfg.profile,
                "receipts_total": len(self._by_head),
                "chains_total": len(chains),
                "events_indexed": len(self._by_event_id),
                "decisions_indexed": len(self._by_decision_id),
                "compatibility_epoch": _STORAGE_COMPATIBILITY_EPOCH,
            }


# =============================================================================
# SQLite receipt store
# =============================================================================


class SQLiteReceiptStore(ReceiptStore):
    def __init__(self, path: str = "tcd.db", *, config: Optional[StorageConfig] = None) -> None:
        self._cfg = config or StorageConfig()
        self._db = _SQLite(path, cfg=self._cfg)

    def _row_to_record(self, row: sqlite3.Row) -> ReceiptRecord:
        produced_by = _json_tuple_from_text(
            row["produced_by_json"] or "[]",
            max_items=32,
            max_len=64,
            invalid_marker=None,
        )
        meta = {}
        if row["meta_json"]:
            with contextlib.suppress(Exception):
                meta = _safe_json_mapping(_json_loads_strict(row["meta_json"]))
        return ReceiptRecord(
            head_hex=row["head_hex"],
            body_json=row["body_json"],
            head_semantics=row["head_semantics"],
            sig=row["sig"],
            verify_key=row["verify_key"],
            verify_key_fp=row["verify_key_fp"],
            verify_key_id=row["verify_key_id"],
            receipt_integrity=row["receipt_integrity"],
            schema=row["schema_id"],
            schema_version=int(row["schema_version"]) if row["schema_version"] is not None else None,
            canonicalization_version=row["canonicalization_version"],
            receipt_kind=row["receipt_kind"],
            event_type=row["event_type"],
            body_kind=row["body_kind"],
            body_digest=row["body_digest"],
            body_schema=row["body_schema"],
            body_canonicalized=bool(row["body_canonicalized"]) if row["body_canonicalized"] is not None else None,
            sig_scheme=row["sig_scheme"],
            sig_alg=row["sig_alg"],
            sig_chain_id=row["sig_chain_id"],
            sig_key_id=row["sig_key_id"],
            pq_required=bool(row["pq_required"]) if row["pq_required"] is not None else None,
            pq_ok=bool(row["pq_ok"]) if row["pq_ok"] is not None else None,
            pq_signature_required=bool(row["pq_signature_required"]) if row["pq_signature_required"] is not None else None,
            pq_signature_ok=bool(row["pq_signature_ok"]) if row["pq_signature_ok"] is not None else None,
            ts=float(row["ts"]) if row["ts"] is not None else None,
            ts_ns=int(row["ts_ns"]) if row["ts_ns"] is not None else None,
            ts_unix_ns=int(row["ts_unix_ns"]) if row["ts_unix_ns"] is not None else None,
            build_id=row["build_id"],
            image_digest=row["image_digest"],
            attestation_id=row["attestation_id"],
            env_fingerprint=row["env_fingerprint"],
            policy_ref=row["policy_ref"],
            policyset_ref=row["policyset_ref"],
            policy_digest=row["policy_digest"],
            cfg_fp=row["cfg_fp"],
            config_hash=row["config_hash"],
            stream_hash=row["stream_hash"],
            state_domain_id=row["state_domain_id"],
            adapter_registry_fp=row["adapter_registry_fp"],
            request_id=row["request_id"],
            event_id=row["event_id"],
            decision_id=row["decision_id"],
            route_plan_id=row["route_plan_id"],
            route_id=row["route_id"],
            audit_ref=row["audit_ref"],
            receipt_ref=row["receipt_ref"],
            ledger_ref=row["ledger_ref"],
            attestation_ref=row["attestation_ref"],
            chain_namespace=row["chain_namespace"],
            chain_id=row["chain_id"],
            chain_seq=int(row["chain_seq"]) if row["chain_seq"] is not None else None,
            prev_head_hex=row["prev_chain_head_hex"],
            action=row["action"],
            reason=row["reason"],
            selected_source=row["selected_source"],
            statistical_guarantee_scope=row["statistical_guarantee_scope"],
            trigger=bool(row["trigger_flag"]) if row["trigger_flag"] is not None else None,
            allowed=bool(row["allowed_flag"]) if row["allowed_flag"] is not None else None,
            prepare_ref=row["prepare_ref"],
            commit_ref=row["commit_ref"],
            ledger_stage=row["ledger_stage"],
            outbox_ref=row["outbox_ref"],
            outbox_status=row["outbox_status"],
            outbox_dedupe_key=row["outbox_dedupe_key"],
            delivery_attempts=int(row["delivery_attempts"]) if row["delivery_attempts"] is not None else None,
            receipt_surface_kind=row["receipt_surface_kind"],
            receipt_delivery_state=row["receipt_delivery_state"],
            evidence_durable=bool(row["evidence_durable"]) if row["evidence_durable"] is not None else None,
            evidence_storage_ready=bool(row["evidence_storage_ready"]) if row["evidence_storage_ready"] is not None else None,
            governance_terminal=bool(row["governance_terminal"]) if row["governance_terminal"] is not None else None,
            receipt_governance_ready=bool(row["receipt_governance_ready"]) if row["receipt_governance_ready"] is not None else None,
            payload_digest=row["payload_digest"],
            event_digest=row["event_digest"],
            produced_by=produced_by,
            provenance_path_digest=row["provenance_path_digest"],
            head_verified=bool(row["head_verified"]) if row["head_verified"] is not None else None,
            body_canonical_verified=bool(row["body_canonical_verified"]) if row["body_canonical_verified"] is not None else None,
            integrity_hash_verified=bool(row["integrity_hash_verified"]) if row["integrity_hash_verified"] is not None else None,
            signature_verified=bool(row["signature_verified"]) if row["signature_verified"] is not None else None,
            verify_key_allowed=bool(row["verify_key_allowed"]) if row["verify_key_allowed"] is not None else None,
            policy_binding_verified=bool(row["policy_binding_verified"]) if row["policy_binding_verified"] is not None else None,
            cfg_binding_verified=bool(row["cfg_binding_verified"]) if row["cfg_binding_verified"] is not None else None,
            integrity_ok=bool(row["integrity_ok"]) if row["integrity_ok"] is not None else None,
            integrity_errors=_json_tuple_from_text(row["integrity_errors_json"] or "[]", max_items=64),
            normalization_warnings=_json_tuple_from_text(row["normalization_warnings_json"] or "[]", max_items=32),
            compat_warnings=_json_tuple_from_text(row["compat_warnings_json"] or "[]", max_items=32),
            meta=MappingProxyType(meta),
            chain_head_hex=row["chain_head_hex"],
            prev_chain_head_hex=row["prev_chain_head_hex"],
            semantic_fingerprint=row["semantic_fingerprint"],
            store_backend="sqlite",
            store_id=int(row["store_id"]),
            inserted_at_unix_ns=int(row["inserted_at_unix_ns"]) if row["inserted_at_unix_ns"] is not None else None,
            updated_at_unix_ns=int(row["updated_at_unix_ns"]) if row["updated_at_unix_ns"] is not None else None,
        )

    def _fetch_one(self, conn: sqlite3.Connection, sql: str, params: Tuple[Any, ...]) -> Optional[ReceiptRecord]:
        row = conn.execute(sql, params).fetchone()
        return self._row_to_record(row) if row is not None else None

    def _rows_for_chain(self, conn: sqlite3.Connection, chain_namespace: str, chain_id: str) -> List[ReceiptRecord]:
        rows = list(
            conn.execute(
                "SELECT * FROM receipts_v2 WHERE chain_namespace=? AND chain_id=? ORDER BY chain_seq ASC, ts_unix_ns ASC, store_id ASC",
                (chain_namespace, chain_id),
            )
        )
        return [self._row_to_record(r) for r in rows]

    def _put_batch_tx(self, conn: sqlite3.Connection, envs: Sequence[ReceiptEnvelope]) -> PutChainResult:
        staged_by_head: Dict[str, ReceiptRecord] = {}
        staged_by_chain_head: Dict[str, ReceiptRecord] = {}
        staged_by_event: Dict[str, str] = {}
        staged_by_decision: Dict[str, str] = {}
        existing_chain_cache: Dict[Tuple[str, str], List[ReceiptRecord]] = {}

        def _existing_rows(chain_namespace: str, chain_id: str) -> List[ReceiptRecord]:
            key = (chain_namespace, chain_id)
            if key not in existing_chain_cache:
                existing_chain_cache[key] = self._rows_for_chain(conn, chain_namespace, chain_id)
                for r in existing_chain_cache[key]:
                    staged_by_head.setdefault(r.head_hex, r)
                    if r.chain_head_hex:
                        staged_by_chain_head.setdefault(r.chain_head_hex, r)
                    if r.event_id:
                        staged_by_event.setdefault(r.event_id, r.head_hex)
                    if r.decision_id:
                        staged_by_decision.setdefault(r.decision_id, r.head_hex)
            return list(existing_chain_cache[key])

        planned: List[ReceiptRecord] = []
        results: List[PutResult] = []

        for env in envs:
            existing = self._fetch_one(conn, "SELECT * FROM receipts_v2 WHERE head_hex=?", (env.head_hex,))
            if existing is not None:
                if _receipt_input_equivalent(existing, env, cfg=self._cfg):
                    results.append(
                        PutResult(
                            stored=False,
                            idempotent=True,
                            conflict=False,
                            head_hex=existing.head_hex,
                            chain_head_hex=existing.chain_head_hex,
                            store_backend="sqlite",
                            store_id=existing.store_id,
                            event_id=existing.event_id,
                            decision_id=existing.decision_id,
                            chain_namespace=existing.chain_namespace or self._cfg.default_chain_namespace,
                            chain_id=existing.chain_id or self._cfg.default_chain_id,
                            chain_seq=existing.chain_seq,
                            receipt_ref=existing.receipt_ref,
                            audit_ref=existing.audit_ref,
                            body_digest=existing.body_digest,
                            payload_digest=existing.payload_digest,
                            ledger_ref=existing.ledger_ref,
                            attestation_ref=existing.attestation_ref,
                            prepare_ref=existing.prepare_ref,
                            commit_ref=existing.commit_ref,
                            outbox_ref=existing.outbox_ref,
                            reason="idempotent_head",
                        )
                    )
                    staged_by_head[existing.head_hex] = existing
                    if existing.chain_head_hex:
                        staged_by_chain_head[existing.chain_head_hex] = existing
                    if existing.event_id:
                        staged_by_event[existing.event_id] = existing.head_hex
                    if existing.decision_id:
                        staged_by_decision[existing.decision_id] = existing.head_hex
                    continue
                raise StorageConflictError("receipt head already exists with different semantic fingerprint")

            if env.event_id and env.event_id in staged_by_event:
                old = staged_by_head[staged_by_event[env.event_id]]
                if old.head_hex != env.head_hex:
                    raise StorageConflictError("event_id already exists with different head")
            if env.decision_id and env.decision_id in staged_by_decision:
                old2 = staged_by_head[staged_by_decision[env.decision_id]]
                if old2.head_hex != env.head_hex:
                    raise StorageConflictError("decision_id already exists with different head")

            chain_namespace = env.chain_namespace or self._cfg.default_chain_namespace
            chain_id = env.chain_id or self._cfg.default_chain_id
            chain_rows = _existing_rows(chain_namespace, chain_id) + [r for r in planned if r.chain_namespace == chain_namespace and r.chain_id == chain_id]
            latest = _latest_chain_row(chain_rows)
            leaves = _chain_leaves(chain_rows)

            if self._cfg.fail_closed_on_chain_ambiguity and len(leaves) > 1:
                raise StorageConflictError("chain has ambiguous multiple leaves")

            append_latest_requested = _receipt_append_latest_requested(env)
            server_assign_position = bool(self._cfg.server_assign_receipt_chain_position) and (env.prev_head_hex is None or append_latest_requested)

            resolved_prev: Optional[ReceiptRecord] = None
            if server_assign_position:
                if chain_rows:
                    if self._cfg.fail_closed_on_chain_ambiguity and len(leaves) > 1:
                        raise StorageConflictError("chain has ambiguous multiple leaves")
                    resolved_prev = leaves[0] if leaves else latest
                else:
                    resolved_prev = None
            elif env.prev_head_hex is None:
                if chain_rows and self._cfg.enforce_single_genesis_per_chain:
                    raise StorageConflictError("single genesis per chain violated")
            else:
                resolved_prev = _resolve_prev_record(
                    env.prev_head_hex,
                    chain_namespace=chain_namespace,
                    chain_id=chain_id,
                    by_receipt_head=staged_by_head,
                    by_chain_head=staged_by_chain_head,
                )
                if resolved_prev is None:
                    raise StorageConflictError("prev_head_hex not found in same chain")
                if env.head_hex in {resolved_prev.head_hex, resolved_prev.chain_head_hex}:
                    raise StorageIntegrityError("receipt self-loop not allowed")
                if self._cfg.require_chain_leaf_append:
                    if len(leaves) > 1:
                        raise StorageConflictError("cannot append when chain leaf is ambiguous")
                    if leaves and leaves[0].chain_head_hex != resolved_prev.chain_head_hex:
                        raise StorageConflictError("strict chain append requires prev == current leaf")

            requested_seq = None if server_assign_position else env.chain_seq
            prev_row_seq = resolved_prev.chain_seq if resolved_prev is not None else None
            latest_seq = latest.chain_seq if latest is not None else None
            final_seq = (requested_seq if requested_seq is not None else ((prev_row_seq + 1) if prev_row_seq is not None else ((latest_seq + 1) if latest_seq is not None else 0)))
            if final_seq < 0:
                raise StorageIntegrityError("invalid chain_seq")

            for row in chain_rows:
                if row.chain_seq == final_seq:
                    raise StorageConflictError("chain_seq already exists")
                if resolved_prev is not None and row.prev_chain_head_hex == resolved_prev.chain_head_hex:
                    raise StorageConflictError("fork detected: prev already consumed")
                if (not server_assign_position) and env.prev_head_hex is None and row.prev_chain_head_hex is None and self._cfg.enforce_single_genesis_per_chain:
                    raise StorageConflictError("single genesis per chain violated")

            prev_chain_head_hex = resolved_prev.chain_head_hex if resolved_prev is not None else None
            chain_head_hex = _compute_chain_head(
                chain_namespace=chain_namespace,
                chain_id=chain_id,
                prev_chain_head_hex=prev_chain_head_hex,
                receipt_head_hex=env.head_hex,
                body_digest=env.body_digest or _receipt_body_digest(env.body_json),
                payload_digest=env.payload_digest or env.body_digest or _receipt_body_digest(env.body_json),
                sig_value=env.sig or "",
                head_semantics=env.head_semantics,
            )
            if chain_head_hex in staged_by_chain_head:
                raise StorageConflictError("chain_head already exists")

            record = ReceiptRecord(
                **{
                    **_dataclass_shallow_dict(env),
                    "chain_head_hex": chain_head_hex,
                    "prev_head_hex": prev_chain_head_hex,
                    "prev_chain_head_hex": prev_chain_head_hex,
                    "chain_namespace": chain_namespace,
                    "chain_id": chain_id,
                    "chain_seq": final_seq,
                    "semantic_fingerprint": _semantic_fingerprint(env),
                    "store_backend": "sqlite",
                    "store_id": None,
                    "inserted_at_unix_ns": None,
                    "updated_at_unix_ns": None,
                }
            )
            staged_by_head[record.head_hex] = record
            staged_by_chain_head[record.chain_head_hex or ""] = record
            if record.event_id:
                staged_by_event[record.event_id] = record.head_hex
            if record.decision_id:
                staged_by_decision[record.decision_id] = record.head_hex
            planned.append(record)

        now_ns = now_unix_ns()
        chain_ns = planned[0].chain_namespace if planned else None
        chain_id = planned[0].chain_id if planned else None
        first_head = planned[0].head_hex if planned else None
        last_chain_head = None

        for rec in planned:
            payload = {
                "head_hex": rec.head_hex,
                "chain_head_hex": rec.chain_head_hex,
                "prev_chain_head_hex": rec.prev_chain_head_hex,
                "head_semantics": rec.head_semantics,
                "semantic_fingerprint": rec.semantic_fingerprint,
                "body_json": rec.body_json,
                "body_digest": rec.body_digest,
                "sig": rec.sig,
                "verify_key": rec.verify_key,
                "verify_key_fp": rec.verify_key_fp,
                "verify_key_id": rec.verify_key_id,
                "receipt_integrity": rec.receipt_integrity,
                "schema_id": rec.schema,
                "schema_version": rec.schema_version,
                "canonicalization_version": rec.canonicalization_version,
                "receipt_kind": rec.receipt_kind,
                "event_type": rec.event_type,
                "body_kind": rec.body_kind,
                "body_schema": rec.body_schema,
                "body_canonicalized": _to_bool_int(rec.body_canonicalized),
                "sig_scheme": rec.sig_scheme,
                "sig_alg": rec.sig_alg,
                "sig_chain_id": rec.sig_chain_id,
                "sig_key_id": rec.sig_key_id,
                "pq_required": _to_bool_int(rec.pq_required),
                "pq_ok": _to_bool_int(rec.pq_ok),
                "pq_signature_required": _to_bool_int(rec.pq_signature_required),
                "pq_signature_ok": _to_bool_int(rec.pq_signature_ok),
                "ts": rec.ts,
                "ts_ns": rec.ts_ns,
                "ts_unix_ns": rec.ts_unix_ns,
                "build_id": rec.build_id,
                "image_digest": rec.image_digest,
                "attestation_id": rec.attestation_id,
                "env_fingerprint": rec.env_fingerprint,
                "policy_ref": rec.policy_ref,
                "policyset_ref": rec.policyset_ref,
                "policy_digest": rec.policy_digest,
                "cfg_fp": rec.cfg_fp,
                "config_hash": rec.config_hash,
                "stream_hash": rec.stream_hash,
                "state_domain_id": rec.state_domain_id,
                "adapter_registry_fp": rec.adapter_registry_fp,
                "request_id": rec.request_id,
                "event_id": rec.event_id,
                "decision_id": rec.decision_id,
                "route_plan_id": rec.route_plan_id,
                "route_id": rec.route_id,
                "audit_ref": rec.audit_ref,
                "receipt_ref": rec.receipt_ref,
                "ledger_ref": rec.ledger_ref,
                "attestation_ref": rec.attestation_ref,
                "chain_namespace": rec.chain_namespace,
                "chain_id": rec.chain_id,
                "chain_seq": rec.chain_seq,
                "action": rec.action,
                "reason": rec.reason,
                "selected_source": rec.selected_source,
                "statistical_guarantee_scope": rec.statistical_guarantee_scope,
                "trigger_flag": _to_bool_int(rec.trigger),
                "allowed_flag": _to_bool_int(rec.allowed),
                "prepare_ref": rec.prepare_ref,
                "commit_ref": rec.commit_ref,
                "ledger_stage": rec.ledger_stage,
                "outbox_ref": rec.outbox_ref,
                "outbox_status": rec.outbox_status,
                "outbox_dedupe_key": rec.outbox_dedupe_key,
                "delivery_attempts": rec.delivery_attempts,
                "receipt_surface_kind": rec.receipt_surface_kind,
                "receipt_delivery_state": rec.receipt_delivery_state,
                "evidence_durable": _to_bool_int(rec.evidence_durable),
                "evidence_storage_ready": _to_bool_int(rec.evidence_storage_ready),
                "governance_terminal": _to_bool_int(rec.governance_terminal),
                "receipt_governance_ready": _to_bool_int(rec.receipt_governance_ready),
                "payload_digest": rec.payload_digest,
                "event_digest": rec.event_digest,
                "produced_by_json": _canonical_json_str(list(rec.produced_by)),
                "provenance_path_digest": rec.provenance_path_digest,
                "head_verified": _to_bool_int(rec.head_verified),
                "body_canonical_verified": _to_bool_int(rec.body_canonical_verified),
                "integrity_hash_verified": _to_bool_int(rec.integrity_hash_verified),
                "signature_verified": _to_bool_int(rec.signature_verified),
                "verify_key_allowed": _to_bool_int(rec.verify_key_allowed),
                "policy_binding_verified": _to_bool_int(rec.policy_binding_verified),
                "cfg_binding_verified": _to_bool_int(rec.cfg_binding_verified),
                "integrity_ok": 1 if rec.integrity_ok else 0,
                "integrity_errors_json": _canonical_json_str(list(rec.integrity_errors)),
                "normalization_warnings_json": _canonical_json_str(list(rec.normalization_warnings)),
                "compat_warnings_json": _canonical_json_str(list(rec.compat_warnings)),
                "meta_json": _canonical_json_str(dict(rec.meta)),
                "inserted_at_unix_ns": now_ns,
                "updated_at_unix_ns": now_ns,
            }
            cur = _sqlite_insert(conn, "receipts_v2", payload)
            store_id = int(cur.lastrowid)
            last_chain_head = rec.chain_head_hex
            results.append(
                PutResult(
                    stored=True,
                    idempotent=False,
                    conflict=False,
                    head_hex=rec.head_hex,
                    chain_head_hex=rec.chain_head_hex,
                    store_backend="sqlite",
                    store_id=store_id,
                    event_id=rec.event_id,
                    decision_id=rec.decision_id,
                    chain_namespace=rec.chain_namespace or self._cfg.default_chain_namespace,
                    chain_id=rec.chain_id or self._cfg.default_chain_id,
                    chain_seq=rec.chain_seq,
                    receipt_ref=rec.receipt_ref,
                    audit_ref=rec.audit_ref,
                    body_digest=rec.body_digest,
                    payload_digest=rec.payload_digest,
                    ledger_ref=rec.ledger_ref,
                    attestation_ref=rec.attestation_ref,
                    prepare_ref=rec.prepare_ref,
                    commit_ref=rec.commit_ref,
                    outbox_ref=rec.outbox_ref,
                    reason="stored",
                    warnings=rec.normalization_warnings + rec.compat_warnings,
                )
            )

        return PutChainResult(
            stored_count=len([r for r in results if r.stored]),
            idempotent_count=len([r for r in results if r.idempotent]),
            conflict_at_index=None,
            chain_namespace=chain_ns,
            chain_id=chain_id,
            first_head_hex=first_head,
            latest_chain_head_hex=last_chain_head,
            results=tuple(results),
        )

    def put_receipt(self, rec: ReceiptEnvelope) -> PutResult:
        result = self.put_chain([rec])
        if result.results:
            return result.results[-1]
        raise StorageError("put_chain returned no result")

    def put_chain(self, records: Sequence[ReceiptEnvelope]) -> PutChainResult:
        envs = [r.normalized(cfg=self._cfg) for r in records]
        with self._db.tx() as conn:
            return self._put_batch_tx(conn, envs)

    def get_record_by_head(self, head_hex: str) -> Optional[ReceiptRecord]:
        key = _normalize_head_token(head_hex)
        with self._db.read() as conn:
            return self._fetch_one(conn, "SELECT * FROM receipts_v2 WHERE head_hex=?", (key,))

    def get_record_by_chain_head(self, chain_head_hex: str) -> Optional[ReceiptRecord]:
        key = _safe_text_or_none(chain_head_hex, max_len=512)
        if not key:
            return None
        with self._db.read() as conn:
            return self._fetch_one(conn, "SELECT * FROM receipts_v2 WHERE chain_head_hex=?", (key,))

    def get_record_by_event_id(self, event_id: str) -> Optional[ReceiptRecord]:
        eid = _safe_id(event_id, default=None, max_len=256)
        if eid is None:
            return None
        with self._db.read() as conn:
            return self._fetch_one(conn, "SELECT * FROM receipts_v2 WHERE event_id=?", (eid,))

    def get_record_by_decision_id(self, decision_id: str) -> Optional[ReceiptRecord]:
        did = _safe_id(decision_id, default=None, max_len=256)
        if did is None:
            return None
        with self._db.read() as conn:
            return self._fetch_one(conn, "SELECT * FROM receipts_v2 WHERE decision_id=?", (did,))

    def latest(self, *, chain_namespace: Optional[str] = None, chain_id: Optional[str] = None) -> Optional[ReceiptRecord]:
        ns = _safe_id(chain_namespace, default=self._cfg.default_chain_namespace, max_len=_MAX_CHAIN_ID_BYTES) or self._cfg.default_chain_namespace
        cid = _safe_id(chain_id, default=self._cfg.default_chain_id, max_len=_MAX_CHAIN_ID_BYTES) or self._cfg.default_chain_id
        with self._db.read() as conn:
            row = conn.execute(
                """
                SELECT * FROM receipts_v2
                WHERE chain_namespace=? AND chain_id=?
                ORDER BY chain_seq DESC, ts_unix_ns DESC, store_id DESC
                LIMIT 1
                """,
                (ns, cid),
            ).fetchone()
        return self._row_to_record(row) if row is not None else None

    def page_chain(
        self,
        *,
        chain_namespace: Optional[str] = None,
        chain_id: Optional[str] = None,
        after_seq: Optional[int] = None,
        limit: int = 100,
    ) -> Tuple[List[ReceiptRecord], Optional[str]]:
        ns = _safe_id(chain_namespace, default=self._cfg.default_chain_namespace, max_len=_MAX_CHAIN_ID_BYTES) or self._cfg.default_chain_namespace
        cid = _safe_id(chain_id, default=self._cfg.default_chain_id, max_len=_MAX_CHAIN_ID_BYTES) or self._cfg.default_chain_id
        lim = max(1, min(self._cfg.max_page_size, int(limit)))
        after = _coerce_int(after_seq)
        sql = "SELECT * FROM receipts_v2 WHERE chain_namespace=? AND chain_id=?"
        params: List[Any] = [ns, cid]
        if after is not None:
            sql += " AND chain_seq > ?"
            params.append(after)
        sql += " ORDER BY chain_seq ASC, store_id ASC LIMIT ?"
        params.append(lim + 1)
        with self._db.read() as conn:
            rows = list(conn.execute(sql, tuple(params)))
        recs = [self._row_to_record(r) for r in rows[:lim]]
        next_cursor = str(recs[-1].chain_seq) if len(rows) > lim and recs and recs[-1].chain_seq is not None else None
        return recs, next_cursor


    def verify_window(
        self,
        head_hex: Optional[str] = None,
        *,
        chain_namespace: Optional[str] = None,
        chain_id: Optional[str] = None,
        limit: int = 100,
        expected_latest_chain_head_hex: Optional[str] = None,
    ) -> VerifyWindowReport:
        lim = max(1, min(self._cfg.max_page_size, int(limit)))
        ns = _safe_id(chain_namespace, default=self._cfg.default_chain_namespace, max_len=_MAX_CHAIN_ID_BYTES) or self._cfg.default_chain_namespace
        cid = _safe_id(chain_id, default=self._cfg.default_chain_id, max_len=_MAX_CHAIN_ID_BYTES) or self._cfg.default_chain_id

        with self._db.read() as conn:
            start: Optional[ReceiptRecord] = None
            if head_hex:
                with contextlib.suppress(Exception):
                    start = self._fetch_one(conn, "SELECT * FROM receipts_v2 WHERE head_hex=?", (_normalize_head_token(head_hex),))
                if start is None:
                    key = _safe_text_or_none(head_hex, max_len=512)
                    if key:
                        start = self._fetch_one(conn, "SELECT * FROM receipts_v2 WHERE chain_head_hex=?", (key,))
            else:
                row = conn.execute(
                    """
                    SELECT * FROM receipts_v2
                    WHERE chain_namespace=? AND chain_id=?
                    ORDER BY chain_seq DESC, ts_unix_ns DESC, store_id DESC
                    LIMIT 1
                    """,
                    (ns, cid),
                ).fetchone()
                start = self._row_to_record(row) if row is not None else None

            if start is not None:
                ns = start.chain_namespace or ns
                cid = start.chain_id or cid

            chain_rows = self._rows_for_chain(conn, ns, cid) if start is not None else []

        return _verify_receipt_chain_rows(
            chain_rows,
            start=start,
            cfg=self._cfg,
            chain_namespace=ns,
            chain_id=cid,
            limit=lim,
            expected_latest_chain_head_hex=expected_latest_chain_head_hex,
        )

    # legacy interface

    def put(self, head_hex: str, body_json: str) -> None:
        if not self._cfg.allow_legacy_receipt_protocol:
            raise StorageConfigError("legacy receipt protocol disabled")
        try:
            _, parsed = _canonicalize_receipt_body(body_json, cfg=self._cfg)
            fields = _extract_receipt_fields(parsed) if parsed is not None else {}
        except Exception:
            fields = {}
        chain_namespace = _safe_id(fields.get("chain_namespace"), default=None, max_len=_MAX_CHAIN_ID_BYTES)
        chain_id = _safe_id(fields.get("chain_id"), default=None, max_len=_MAX_CHAIN_ID_BYTES)
        prev_head_hex = fields.get("prev_head_hex")
        if not chain_namespace:
            chain_namespace = "legacy"
        if not chain_id:
            chain_id = f"legacy-{_normalize_head_token(head_hex)[:24]}"
        self.put_receipt(
            ReceiptEnvelope(
                head_hex=head_hex,
                body_json=body_json,
                head_semantics="legacy_raw_head",
                chain_namespace=chain_namespace,
                chain_id=chain_id,
                prev_head_hex=prev_head_hex,
            )
        )

    def get(self, head_hex: str) -> Optional[str]:
        rec = self.get_record_by_head(head_hex)
        return rec.body_json if rec else None

    def tail(self, n: int) -> List[Tuple[str, str]]:
        lim = max(1, min(self._cfg.max_tail_size, int(n)))
        with self._db.read() as conn:
            rows = list(
                conn.execute(
                    "SELECT head_hex, body_json FROM receipts_v2 ORDER BY inserted_at_unix_ns DESC, store_id DESC LIMIT ?",
                    (lim,),
                )
            )
        return [(str(r["head_hex"]), str(r["body_json"])) for r in rows]

    def page(self, cursor: Optional[str], limit: int) -> Tuple[List[Tuple[str, str]], Optional[str]]:
        lim = max(1, min(self._cfg.max_page_size, int(limit)))
        if cursor:
            cur = self.get_record_by_head(cursor)
            if cur is None:
                after_ts = None
                after_id = None
            else:
                after_ts = cur.inserted_at_unix_ns
                after_id = cur.store_id
        else:
            after_ts = None
            after_id = None

        sql = "SELECT store_id, head_hex, body_json, inserted_at_unix_ns FROM receipts_v2"
        params: List[Any] = []
        if after_ts is not None and after_id is not None:
            sql += " WHERE (inserted_at_unix_ns < ? OR (inserted_at_unix_ns = ? AND store_id < ?))"
            params.extend([after_ts, after_ts, after_id])
        sql += " ORDER BY inserted_at_unix_ns DESC, store_id DESC LIMIT ?"
        params.append(lim + 1)
        with self._db.read() as conn:
            rows = list(conn.execute(sql, tuple(params)))
        page_rows = rows[:lim]
        next_cursor = str(page_rows[-1]["head_hex"]) if len(rows) > lim and page_rows else None
        return ([(str(r["head_hex"]), str(r["body_json"])) for r in page_rows], next_cursor)

    def stats(self) -> Dict[str, Any]:
        with self._db.read() as conn:
            total = int(conn.execute("SELECT COUNT(*) AS n FROM receipts_v2").fetchone()["n"])
            event_idx = int(conn.execute("SELECT COUNT(*) AS n FROM receipts_v2 WHERE event_id IS NOT NULL").fetchone()["n"])
            decision_idx = int(conn.execute("SELECT COUNT(*) AS n FROM receipts_v2 WHERE decision_id IS NOT NULL").fetchone()["n"])
            chains = int(conn.execute("SELECT COUNT(DISTINCT chain_namespace || '|' || chain_id) AS n FROM receipts_v2").fetchone()["n"])
        db_bytes = 0
        with contextlib.suppress(Exception):
            db_bytes = int(os.path.getsize(self._db._path))
        return {
            "backend": "sqlite",
            "profile": self._cfg.profile,
            "receipts_total": total,
            "events_indexed": event_idx,
            "decisions_indexed": decision_idx,
            "chains_total": chains,
            "db_path": self._db._path,
            "db_bytes": db_bytes,
            "compatibility_epoch": _STORAGE_COMPATIBILITY_EPOCH,
        }


# =============================================================================
# Factories
# =============================================================================


def make_ledger(dsn: Optional[str], *, config: Optional[StorageConfig] = None) -> AlphaWealthLedger:
    cfg = config or StorageConfig()
    if not dsn or dsn.strip().lower().startswith("mem://"):
        return InMemoryAlphaWealthLedger(config=cfg)
    dsn_l = dsn.strip().lower()
    if dsn_l.startswith("sqlite:///"):
        return SQLiteAlphaWealthLedger(path=dsn[len("sqlite:///") :], config=cfg)
    if dsn_l.startswith("sqlite:///:memory:") or dsn_l.startswith("sqlite:///:mem:"):
        return SQLiteAlphaWealthLedger(path=":memory:", config=cfg)
    raise StorageConfigError(f"unsupported ledger dsn: {dsn}")


def make_receipt_store(dsn: Optional[str], *, config: Optional[StorageConfig] = None) -> ReceiptStore:
    cfg = config or StorageConfig()
    if not dsn or dsn.strip().lower().startswith("mem://"):
        return InMemoryReceiptStore(config=cfg)
    dsn_l = dsn.strip().lower()
    if dsn_l.startswith("sqlite:///"):
        return SQLiteReceiptStore(path=dsn[len("sqlite:///") :], config=cfg)
    if dsn_l.startswith("sqlite:///:memory:") or dsn_l.startswith("sqlite:///:mem:"):
        return SQLiteReceiptStore(path=":memory:", config=cfg)
    raise StorageConfigError(f"unsupported receipt store dsn: {dsn}")


