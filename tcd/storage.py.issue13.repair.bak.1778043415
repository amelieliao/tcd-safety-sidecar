        return out


class AlphaWealthLedger(Protocol):
    def peek(self, subject: Subject, *, policy_ref: str = "default", state_domain_id: str = "default") -> Optional[float]:
        ...
    def get(self, subject: Subject, *, policy_ref: str = "default", state_domain_id: str = "default", default_alpha0: float = 0.05) -> float:
        ...
    def get_or_create(self, subject: Subject, *, policy_ref: str = "default", state_domain_id: str = "default", default_alpha0: float = 0.05) -> float:
        ...
    def apply(self, subject: Subject, step: WealthStep, *, default_alpha0: float = 0.05) -> WealthApplyResult:
        ...
    def get_event(self, event_id: str) -> Optional[WealthEventRecord]:
        ...
    def page_events(
        self,
        subject: Subject,
        *,
        policy_ref: str = "default",
        state_domain_id: str = "default",
        limit: int = 100,
        after_event_id: Optional[str] = None,
    ) -> List[WealthEventRecord]:
        ...
    def recompute_subject_state(self, subject: Subject, *, policy_ref: str = "default", state_domain_id: str = "default", default_alpha0: float = 0.05) -> Dict[str, Any]:
        ...
    def verify_subject_state(self, subject: Subject, *, policy_ref: str = "default", state_domain_id: str = "default", default_alpha0: float = 0.05) -> Dict[str, Any]:
        ...
    def snapshot_subject(self, subject: Subject, *, policy_ref: str = "default", state_domain_id: str = "default", default_alpha0: float = 0.05) -> Dict[str, Any]:
        ...
    def stats(self) -> Dict[str, Any]:
        ...


