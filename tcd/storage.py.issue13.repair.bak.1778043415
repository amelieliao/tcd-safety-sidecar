def now_ts() -> float:
    return float(time.time())


def now_unix_ns() -> int:
    return int(time.time_ns())


def _profile_is_strict(profile: str) -> bool:
    return str(profile).upper() in {"PROD", "FINREG", "LOCKDOWN"}


def _has_unsafe_unicode(s: str) -> bool:
    for ch in s:
        if ch in ("\u2028", "\u2029"):
            return True
        cat = unicodedata.category(ch)
        if cat in ("Cc", "Cf", "Cs", "Zl", "Zp"):
            return True
    return False


def _strip_unsafe_text(v: Any, *, max_len: int) -> str:
    if not isinstance(v, str):
        return ""
    s = unicodedata.normalize("NFC", v[:max_len])
    if s.isascii():
        if _ASCII_CTRL_RE.search(s):
            s = _ASCII_CTRL_RE.sub("", s)
        return s.strip()
    if not _ASCII_CTRL_RE.search(s) and not _has_unsafe_unicode(s):
        if any(0x80 <= ord(ch) <= 0x9F for ch in s):
            pass
        else:
            return s.strip()
    out: List[str] = []
    for ch in s:
        o = ord(ch)
        if ch in ("\u2028", "\u2029"):
            continue
        if o < 0x20 or o == 0x7F:
            continue
        if 0x80 <= o <= 0x9F:
            continue
        cat = unicodedata.category(ch)
        if cat in ("Cc", "Cf", "Cs", "Zl", "Zp"):
            continue
        out.append(ch)
    return "".join(out).strip()


def _scalar_text(v: Any) -> str:
    if v is None:
        return ""
    if isinstance(v, str):
        return v
    if isinstance(v, bool):
        return "true" if v else "false"
    if isinstance(v, int):
        return str(v)
    if isinstance(v, float):
        if not math.isfinite(v):
            return ""
        return f"{v:.12g}"
    if isinstance(v, (bytes, bytearray, memoryview)):
        return "<bytes>"
    return f"<{type(v).__name__}>"


def _safe_text(v: Any, *, max_len: int = 256, redact_mode: str = "none") -> str:
    s = _strip_unsafe_text(_scalar_text(v), max_len=max_len)
    if not s:
        return ""
    mode = (redact_mode or "none").lower()
    if mode in {"token", "log", "strict"} and _looks_like_secret_token(s):
        return "[redacted]"
    if mode == "strict" and _looks_like_high_entropy(s):
        return "[redacted]"
    return s[:max_len]


def _safe_text_or_none(v: Any, *, max_len: int = 256, redact_mode: str = "none") -> Optional[str]:
    s = _safe_text(v, max_len=max_len, redact_mode=redact_mode)
    return s or None


def _safe_label(v: Any, *, default: str) -> str:
    s = _safe_text(v, max_len=64).lower()
    if not s or not _SAFE_LABEL_RE.fullmatch(s):
        return default
    return s


def _safe_name(v: Any, *, default: str) -> str:
    s = _safe_text(v, max_len=128)
    if not s or not _SAFE_NAME_RE.fullmatch(s):
        return default
    return s


def _safe_id(v: Any, *, default: Optional[str] = None, max_len: int = 256) -> Optional[str]:
    s = _safe_text(v, max_len=max_len)
    if not s or not _SAFE_ID_RE.fullmatch(s):
        return default
    return s


def _safe_reason_code(v: Any, *, default: Optional[str] = None) -> Optional[str]:
    s = _safe_text(v, max_len=128).upper()
    if not s or not _SAFE_REASON_CODE_RE.fullmatch(s):
        return default
    return s if s in _ALLOWED_REASON_CODES else default


def _looks_like_secret_token(s: str) -> bool:
    if not s:
        return False
    if _JWT_RE.search(s):
        return True
    if _PRIVKEY_RE.search(s):
        return True
    if _BEARER_RE.search(s):
        return True
    if _BASIC_RE.search(s):
        return True
    if _OPENAI_SK_RE.search(s):
        return True
    if _AWS_AKIA_RE.search(s):
        return True
    if _GOOGLE_AIZA_RE.search(s):
        return True
    if _KV_SECRET_RE.search(s):
        return True
    return False


def _looks_like_high_entropy(s: str) -> bool:
    return bool(s) and (_ENTROPY_B64URL_RE.search(s) is not None)


def _normalize_digest_token(v: Any, *, kind: str = "any", default: Optional[str] = None) -> Optional[str]:
    s = _safe_text(v, max_len=1024)
    if not s:
        return default
    if kind == "cfg_fp":
        return s if _CFG_FP_RE.fullmatch(s) else default
    if kind == "integrity":
        return s if _RECEIPT_INTEGRITY_RE.fullmatch(s) else default
    if kind == "receipt_head":
        if _DIGEST_HEX_RE.fullmatch(s):
            return s.lower()
        if _DIGEST_HEX_0X_RE.fullmatch(s):
            return s.lower()
        if _DIGEST_ALG_HEX_RE.fullmatch(s):
            algo, _, rest = s.partition(":")
            return f"{algo}:{rest.lower()}"
        return default
    if _DIGEST_HEX_RE.fullmatch(s):
        return s.lower()
    if _DIGEST_HEX_0X_RE.fullmatch(s):
        return s.lower()
    if _DIGEST_ALG_HEX_RE.fullmatch(s):
        algo, _, rest = s.partition(":")
        return f"{algo}:{rest.lower()}"
    return default


def _coerce_float(v: Any) -> Optional[float]:
    if type(v) is bool:
        return None
    if isinstance(v, (int, float)):
        try:
            x = float(v)
        except Exception:
            return None
        return x if math.isfinite(x) else None
    if isinstance(v, str):
        s = v.strip()
        if not s or len(s) > 128:
            return None
        try:
            x = float(s)
        except Exception:
            return None
        return x if math.isfinite(x) else None
    return None


def _coerce_int(v: Any) -> Optional[int]:
    if type(v) is int:
        return int(v)
    if isinstance(v, str):
        s = v.strip()
        if not s or len(s) > 128:
            return None
        if s.startswith(("+", "-")):
            sign, digits = s[0], s[1:]
        else:
            sign, digits = "", s
        if not digits.isdigit():
            return None
        try:
            return int(sign + digits, 10)
        except Exception:
            return None
    return None


def _coerce_bool(v: Any) -> Optional[bool]:
    if type(v) is bool:
        return v
    if type(v) is int:
        if v == 0:
            return False
        if v == 1:
            return True
        return None
    if isinstance(v, str):
        s = v.strip().lower()
        if s in {"1", "true", "yes", "y", "on"}:
            return True
        if s in {"0", "false", "no", "n", "off"}:
            return False
    return None


def _stable_float(x: float) -> str:
    if not math.isfinite(float(x)):
        return "0"
    s = f"{float(x):.12f}".rstrip("0").rstrip(".")
    return s or "0"


def _stable_jsonable(obj: Any) -> Any:
    if obj is None or isinstance(obj, (bool, int)):
        return obj
    if isinstance(obj, float):
        return _stable_float(obj)
    if isinstance(obj, str):
        return obj
    if isinstance(obj, Mapping):
        return {str(k): _stable_jsonable(obj[k]) for k in sorted(obj.keys(), key=lambda x: str(x))}
    if isinstance(obj, (list, tuple)):
        return [_stable_jsonable(x) for x in obj]
    if isinstance(obj, (set, frozenset)):
        xs = [_stable_jsonable(x) for x in obj]
        try:
            return sorted(xs)
        except Exception:
            return xs
    return _safe_name(type(obj).__name__, default="object")


def _canonical_json_bytes(obj: Any) -> bytes:
    return json.dumps(
        _stable_jsonable(obj),
        sort_keys=True,
        ensure_ascii=False,
        separators=(",", ":"),
        allow_nan=False,
    ).encode("utf-8", errors="strict")


def _canonical_json_str(obj: Any) -> str:
    return _canonical_json_bytes(obj).decode("utf-8", errors="strict")


def _hash_hex(*, ctx: str, payload: Mapping[str, Any], out_hex: int = 32) -> str:
    raw = ctx.encode("utf-8", errors="strict") + b"\x00" + _canonical_json_bytes(payload)
    if Blake3Hash is not None:
        with contextlib.suppress(Exception):
            return Blake3Hash().hex(raw, ctx=ctx)[:out_hex]
    return hashlib.sha256(raw).hexdigest()[:out_hex]


def _parse_key_material(v: Any) -> Optional[bytes]:
    if isinstance(v, bytes):
        return bytes(v) if 1 <= len(v) <= 4096 else None
    if not isinstance(v, str):
        return None
    s = _safe_text(v, max_len=4096)
    if not s:
        return None
    if s.lower().startswith("hex:"):
        hx = s[4:].strip()
        if len(hx) % 2 != 0 or not _HEX_RE.fullmatch(hx):
            return None
        with contextlib.suppress(Exception):
            return bytes.fromhex(hx)
        return None
    if s.lower().startswith("b64:"):
        import base64
        raw = s[4:].strip()
        try:
            pad = "=" * ((4 - (len(raw) % 4)) % 4)
            return base64.urlsafe_b64decode((raw + pad).encode("utf-8", errors="strict"))
        except Exception:
            return None
    if s.lower().startswith("raw:"):
        return s[4:].encode("utf-8", errors="ignore")
    if _HEX_RE.fullmatch(s) and len(s) % 2 == 0:
        with contextlib.suppress(Exception):
            return bytes.fromhex(s)
    return None


class _JsonBudget:
    __slots__ = ("max_nodes", "max_items", "max_depth", "max_str_total", "nodes", "str_used")

    def __init__(self, *, max_nodes: int, max_items: int, max_depth: int, max_str_total: int) -> None:
        self.max_nodes = max_nodes
        self.max_items = max_items
        self.max_depth = max_depth
        self.max_str_total = max_str_total
        self.nodes = 0
        self.str_used = 0

    def take_node(self) -> bool:
        self.nodes += 1
        return self.nodes <= self.max_nodes

    def take_str(self, n: int) -> bool:
        self.str_used += n
        return self.str_used <= self.max_str_total


def _key_tokens(k: str) -> Tuple[str, ...]:
    s = _strip_unsafe_text(k, max_len=128)
    if not s:
        return tuple()
    s = re.sub(r"(?<=[a-z0-9])(?=[A-Z])", " ", s)
    s = re.sub(r"(?<=[A-Za-z])(?=\d)|(?<=\d)(?=[A-Za-z])", " ", s)
    s = re.sub(r"[^A-Za-z0-9]+", " ", s).strip().lower()
    if not s:
        return tuple()
    parts = tuple(p for p in s.split(" ") if p)
    fused = "".join(parts)
    return parts + ((fused,) if fused and fused not in parts else tuple())


def _json_sanitize(obj: Any, *, budget: _JsonBudget, depth: int) -> Any:
    if not budget.take_node():
        return "[truncated]"
    t = type(obj)
    if obj is None:
        return None
    if t is bool:
        return bool(obj)
    if t is int:
        if obj.bit_length() > 256:
            return "[int:oversize]"
        return int(obj)
    if t is float:
        return float(obj) if math.isfinite(obj) else None
    if t is str:
        s = _safe_text(obj, max_len=_MAX_JSON_STR_LEN)
        if not budget.take_str(len(s)):
            return "[truncated]"
        return s
    if t in (bytes, bytearray, memoryview):
        return f"[bytes:{len(obj)}]"
    if depth >= budget.max_depth:
        return "[truncated-depth]"
    if isinstance(obj, Mapping):
        out: Dict[str, Any] = {}
        n = 0
        for k, v in obj.items():
            if n >= budget.max_items:
                out["_tcd_truncated"] = True
                break
            if type(k) is not str:
                continue
            kk = _safe_id(k, default=None, max_len=128)
            if kk is None:
                continue
            toks = _key_tokens(kk)
            if any(tok in _FORBIDDEN_KEY_TOKENS for tok in toks):
                continue
            out[kk] = _json_sanitize(v, budget=budget, depth=depth + 1)
            n += 1
        return out
    if t in (list, tuple):
        out_list: List[Any] = []
        for i, item in enumerate(obj):
            if i >= budget.max_items:
                out_list.append("[truncated]")
                break
            out_list.append(_json_sanitize(item, budget=budget, depth=depth + 1))
        return out_list
    if t in (set, frozenset):
        xs = [_json_sanitize(x, budget=budget, depth=depth + 1) for x in list(obj)[: budget.max_items]]
        try:
            return sorted(xs, key=lambda x: _canonical_json_str(x))
        except Exception:
            return xs
    return f"[type:{t.__name__}]"


def _safe_json_mapping(v: Any) -> Dict[str, Any]:
    if not isinstance(v, Mapping):
        return {}
    budget = _JsonBudget(
        max_nodes=_MAX_JSON_NODES,
        max_items=_MAX_JSON_ITEMS,
        max_depth=_MAX_JSON_DEPTH,
        max_str_total=_MAX_JSON_STR_TOTAL,
    )
    out = _json_sanitize(dict(v), budget=budget, depth=0)
    return out if isinstance(out, dict) else {}


def _normalize_reason_codes(values: Any, *, max_items: int = 32) -> Tuple[str, ...]:
    if values is None:
        return tuple()
    if isinstance(values, str):
        seq: Sequence[Any] = [values]
    elif isinstance(values, (list, tuple, set, frozenset)):
        seq = list(values)
    else:
        return tuple()
    out: List[str] = []
    seen = set()
    for item in seq:
        if len(out) >= max_items:
            break
        code = _safe_reason_code(item, default=None)
        if not code or code in seen:
            continue
        seen.add(code)
        out.append(code)
    return tuple(out)


def _normalize_str_tuple(values: Any, *, max_len: int = 128, max_items: int = 32, lower: bool = False) -> Tuple[str, ...]:
    if values is None:
        return tuple()
    if isinstance(values, str):
        seq: Sequence[Any] = [values]
    elif isinstance(values, (list, tuple, set, frozenset)):
        seq = list(values)
    else:
        return tuple()
    out: List[str] = []
    seen = set()
    for item in seq:
        if len(out) >= max_items:
            break
        s = _safe_text(item, max_len=max_len)
        if lower:
            s = s.lower()
        if not s or s in seen:
            continue
        seen.add(s)
        out.append(s)
    return tuple(out)


def _json_loads_strict(s: str) -> Any:
    def _bad_const(_: str) -> Any:
        raise ValueError("non-finite json constant")
    return json.loads(s, parse_constant=_bad_const)


def _json_depth_exceeds(raw: str, *, max_depth: int) -> bool:
    depth = 0
    in_str = False
    esc = False
    for ch in raw:
        if in_str:
            if esc:
                esc = False
                continue
            if ch == "\\":
                esc = True
                continue
            if ch == '"':
                in_str = False
            continue
        if ch == '"':
            in_str = True
            continue
        if ch in "{[":
            depth += 1
            if depth > max_depth:
                return True
        elif ch in "}]":
            depth = max(0, depth - 1)
    return False


def _body_contains_forbidden_keys(obj: Any, *, path: Tuple[str, ...] = ()) -> bool:
    if isinstance(obj, dict):
        for k, v in obj.items():
            if isinstance(k, str):
                toks = _key_tokens(k)
                if any(tok in _FORBIDDEN_KEY_TOKENS for tok in toks):
                    if _strip_unsafe_text(k, max_len=64).lower() not in _RECEIPT_STRUCTURAL_KEYS:
                        return True
            if _body_contains_forbidden_keys(v, path=path + (str(k),)):
                return True
    elif isinstance(obj, list):
        for item in obj:
            if _body_contains_forbidden_keys(item, path=path):
                return True
    return False


def _view_instance(view_cls: Any, payload: Dict[str, Any]) -> Any:
    if view_cls is None:
        return dict(payload)
    try:
        if hasattr(view_cls, "model_validate"):
            return view_cls.model_validate(dict(payload))
        return view_cls(**payload)
    except Exception:
        return dict(payload)


def _to_bool_int(v: Optional[bool]) -> Optional[int]:
    if v is None:
        return None
    return 1 if v else 0


def _sqlite_insert(conn: sqlite3.Connection, table: str, payload: Mapping[str, Any]) -> sqlite3.Cursor:
    cols = list(payload.keys())
    placeholders = ",".join("?" for _ in cols)
    sql = f"INSERT INTO {table} ({','.join(cols)}) VALUES ({placeholders})"
    return conn.execute(sql, tuple(payload[c] for c in cols))


def _dataclass_shallow_dict(obj: Any) -> Dict[str, Any]:
    """
    Shallow dataclass projection.

    dataclasses.asdict() deep-copies every field. That breaks normalized
    storage objects because meta is intentionally a MappingProxyType.
    """
    if not dataclasses.is_dataclass(obj) or isinstance(obj, type):
        raise TypeError("expected dataclass instance")
    return {f.name: getattr(obj, f.name) for f in dataclasses.fields(obj)}


def _json_tuple_from_text(
    raw: Any,
    *,
    max_items: int = 64,
    max_len: int = 256,
    invalid_marker: Optional[str] = "INTEGRITY_ERROR",
) -> Tuple[str, ...]:
    """
    Corruption-tolerant parser for JSON array columns.

    Storage verification should mark a bad row as bad; it should not crash
    before VerifyWindowReport can report bad_rows/reasons.
    """
    if raw is None or raw == "":
        return tuple()
    if not isinstance(raw, str):
        return (invalid_marker,) if invalid_marker else tuple()
    try:
        val = _json_loads_strict(raw)
    except Exception:
        return (invalid_marker,) if invalid_marker else tuple()
    if not isinstance(val, list):
        return (invalid_marker,) if invalid_marker else tuple()

    out: List[str] = []
    seen = set()
    for item in val[: max(0, int(max_items))]:
        ss = _safe_text(item, max_len=max_len)
        if not ss or ss in seen:
            continue
        seen.add(ss)
        out.append(ss)
    return tuple(out)


def _body_digest_matches(body_json: Any, stored_digest: Any) -> bool:
    """
    Verify that body_digest still binds persisted body_json.

    Accepts the storage-native pd2:sha256:<hex> form, sha256:<hex>, and raw
    sha256 hex for compatibility.
    """
    if not isinstance(body_json, str) or not isinstance(stored_digest, str):
        return False
    s = stored_digest.strip().lower()
    if not s:
        return False
    if s.startswith("0x"):
        s = s[2:]

    try:
        sha = hashlib.sha256(body_json.encode("utf-8", errors="strict")).hexdigest()
    except Exception:
        return False

    if s == sha:
        return True

    parts = s.split(":")
    if parts and parts[-1] == sha and ("sha256" in parts[:-1]):
        return True

    return False


def _receipt_row_integrity_issues(rec: "ReceiptRecord", *, cfg: "StorageConfig") -> Tuple[str, ...]:
    """
    Read-path row integrity checks for verify_window().

    This catches direct row corruption such as body_json mutation, invalid JSON,
    oversized stored body, and rows already carrying integrity errors.
    """
    issues: List[str] = []
    body = rec.body_json

    if not isinstance(body, str):
        issues.append("body_json_invalid")
    else:
        try:
            body_bytes = body.encode("utf-8", errors="strict")
        except Exception:
            body_bytes = b""
            issues.append("body_json_invalid")

        if body_bytes and len(body_bytes) > cfg.max_receipt_body_bytes:
            issues.append("body_json_oversized")

        if cfg.validate_receipt_json:
            if _json_depth_exceeds(body, max_depth=_MAX_JSON_DEPTH):
                issues.append("body_json_depth_exceeded")
            else:
                try:
                    parsed = _json_loads_strict(body)
                except Exception:
                    issues.append("body_json_invalid")
                else:
                    if cfg.strict_dict_top_level_external and _profile_is_strict(cfg.profile) and not isinstance(parsed, dict):
                        issues.append("body_json_not_object")
                    if cfg.reject_forbidden_body_keys and _body_contains_forbidden_keys(parsed):
                        issues.append("body_json_forbidden_key")

    if not _body_digest_matches(body, rec.body_digest):
        issues.append("body_digest_mismatch")

    if rec.integrity_ok is False or bool(rec.integrity_errors):
        issues.append("row_integrity_error")

    return tuple(sorted(set(issues)))


# =============================================================================
# Storage config
# =============================================================================


@dataclass(frozen=True)
class StorageConfig:
    profile: Profile = "PROD"

    allow_legacy_receipt_protocol: bool = True

    # subject / identity governance
    hash_subject_ids: bool = True
    external_hash_all_subject_fields: bool = True
    subject_hash_key: Optional[bytes] = None
    subject_hash_key_id: Optional[str] = None
    min_subject_hash_key_bytes: int = 16
    subject_hash_hex_chars: int = 32
    subject_part_max_bytes: int = 128
    forbid_subject_delim: bool = True

    # wealth governance
    alpha0_floor: float = 0.000001
    reject_negative_values_external: bool = True
    policy_ref_max_bytes: int = _MAX_POLICY_REF_BYTES
    strict_policy_ref_taglike: bool = True
    max_wealth_events_in_memory: int = 200_000

    # receipt governance
    validate_receipt_json: bool = True
    canonicalize_receipt_body: bool = False
    strict_dict_top_level_external: bool = False
    reject_forbidden_body_keys: bool = True

    verify_receipt_head: bool = True
    verify_attestation_semantics_if_possible: bool = False

    enforce_single_genesis_per_chain: bool = True
    require_chain_leaf_append: bool = True
    fail_closed_on_chain_ambiguity: bool = True
    server_assign_receipt_chain_position: bool = True

    default_chain_namespace: str = "default"
    default_chain_id: str = "default"

    max_receipt_body_bytes: int = _MAX_RECEIPT_BODY_BYTES
    max_verify_key_bytes: int = _MAX_VERIFY_KEY_BYTES
    max_sig_bytes: int = _MAX_SIG_BYTES
    max_page_size: int = _MAX_PAGE_SIZE
    max_tail_size: int = _MAX_PAGE_SIZE

    # sqlite
    sqlite_timeout_s: float = 30.0
    sqlite_synchronous: Literal["NORMAL", "FULL"] = "FULL"
    sqlite_wal_autocheckpoint: int = 1000
    sqlite_journal_size_limit: int = 64 * 1024 * 1024

    def __post_init__(self) -> None:
        prof = _safe_text(self.profile, max_len=32).upper() or "PROD"
        object.__setattr__(self, "profile", prof if prof in _ALLOWED_PROFILES else "PROD")
        object.__setattr__(self, "allow_legacy_receipt_protocol", bool(self.allow_legacy_receipt_protocol))
        object.__setattr__(self, "hash_subject_ids", bool(self.hash_subject_ids))
        object.__setattr__(self, "external_hash_all_subject_fields", bool(self.external_hash_all_subject_fields))

        key = self.subject_hash_key
        if isinstance(key, str):
            key = _parse_key_material(key)
        if key is not None and len(key) < max(8, int(self.min_subject_hash_key_bytes)):
            key = None
        object.__setattr__(self, "subject_hash_key", key)
        object.__setattr__(self, "subject_hash_key_id", _safe_text_or_none(self.subject_hash_key_id, max_len=32))
        object.__setattr__(self, "min_subject_hash_key_bytes", max(8, min(4096, int(self.min_subject_hash_key_bytes))))
        object.__setattr__(self, "subject_hash_hex_chars", max(8, min(64, int(self.subject_hash_hex_chars))))
        object.__setattr__(self, "subject_part_max_bytes", max(16, min(1024, int(self.subject_part_max_bytes))))
        object.__setattr__(self, "forbid_subject_delim", bool(self.forbid_subject_delim))

        object.__setattr__(self, "alpha0_floor", max(0.0, float(self.alpha0_floor)))
        object.__setattr__(self, "reject_negative_values_external", bool(self.reject_negative_values_external))
        object.__setattr__(self, "policy_ref_max_bytes", max(16, min(512, int(self.policy_ref_max_bytes))))
        object.__setattr__(self, "strict_policy_ref_taglike", bool(self.strict_policy_ref_taglike))
        object.__setattr__(self, "max_wealth_events_in_memory", max(1024, min(2_000_000, int(self.max_wealth_events_in_memory))))

        object.__setattr__(self, "validate_receipt_json", bool(self.validate_receipt_json))
        object.__setattr__(self, "canonicalize_receipt_body", bool(self.canonicalize_receipt_body))
        object.__setattr__(self, "strict_dict_top_level_external", bool(self.strict_dict_top_level_external))
        object.__setattr__(self, "reject_forbidden_body_keys", bool(self.reject_forbidden_body_keys))
        object.__setattr__(self, "verify_receipt_head", bool(self.verify_receipt_head))
        object.__setattr__(self, "verify_attestation_semantics_if_possible", bool(self.verify_attestation_semantics_if_possible))
        object.__setattr__(self, "enforce_single_genesis_per_chain", bool(self.enforce_single_genesis_per_chain))
        object.__setattr__(self, "require_chain_leaf_append", bool(self.require_chain_leaf_append))
        object.__setattr__(self, "fail_closed_on_chain_ambiguity", bool(self.fail_closed_on_chain_ambiguity))
        object.__setattr__(self, "server_assign_receipt_chain_position", bool(self.server_assign_receipt_chain_position))

        object.__setattr__(self, "default_chain_namespace", _safe_id(self.default_chain_namespace, default="default", max_len=_MAX_CHAIN_ID_BYTES) or "default")
        object.__setattr__(self, "default_chain_id", _safe_id(self.default_chain_id, default="default", max_len=_MAX_CHAIN_ID_BYTES) or "default")

        object.__setattr__(self, "max_receipt_body_bytes", max(1024, min(10_000_000, int(self.max_receipt_body_bytes))))
        object.__setattr__(self, "max_verify_key_bytes", max(256, min(1_000_000, int(self.max_verify_key_bytes))))
        object.__setattr__(self, "max_sig_bytes", max(256, min(1_000_000, int(self.max_sig_bytes))))
        object.__setattr__(self, "max_page_size", max(1, min(10_000, int(self.max_page_size))))
        object.__setattr__(self, "max_tail_size", max(1, min(10_000, int(self.max_tail_size))))

        object.__setattr__(self, "sqlite_timeout_s", max(0.1, min(300.0, float(self.sqlite_timeout_s))))
        sync = _safe_text(self.sqlite_synchronous, max_len=16).upper() or "FULL"
        object.__setattr__(self, "sqlite_synchronous", sync if sync in {"NORMAL", "FULL"} else "FULL")
        object.__setattr__(self, "sqlite_wal_autocheckpoint", max(100, min(1_000_000, int(self.sqlite_wal_autocheckpoint))))
        object.__setattr__(self, "sqlite_journal_size_limit", max(1024 * 1024, min(2_000_000_000, int(self.sqlite_journal_size_limit))))

    @classmethod
    def from_env(cls) -> "StorageConfig":
        def _env(name: str, default: str) -> str:
            raw = os.getenv(name)
            return default if raw is None else str(raw).strip()

        def _env_bool(name: str, default: bool) -> bool:
            raw = os.getenv(name)
            if raw is None:
                return default
            return str(raw).strip().lower() in {"1", "true", "yes", "y", "on"}

        def _env_int(name: str, default: int) -> int:
            raw = os.getenv(name)
            if raw is None:
                return default
            try:
                return int(str(raw).strip())
            except Exception:
                return default

        def _env_float(name: str, default: float) -> float:
            raw = os.getenv(name)
            if raw is None:
                return default
            try:
                return float(str(raw).strip())
            except Exception:
                return default

        return cls(
            profile=_env("TCD_STORAGE_PROFILE", "PROD"),
            allow_legacy_receipt_protocol=_env_bool("TCD_STORAGE_ALLOW_LEGACY_PROTOCOL", True),
            hash_subject_ids=_env_bool("TCD_STORAGE_HASH_SUBJECT_IDS", True),
            external_hash_all_subject_fields=_env_bool("TCD_STORAGE_EXTERNAL_HASH_ALL_SUBJECT_FIELDS", True),
            subject_hash_key=_parse_key_material(_env("TCD_STORAGE_SUBJECT_HASH_KEY", "")),
            subject_hash_key_id=_env("TCD_STORAGE_SUBJECT_HASH_KEY_ID", "") or None,
            min_subject_hash_key_bytes=_env_int("TCD_STORAGE_MIN_SUBJECT_HASH_KEY_BYTES", 16),
            subject_hash_hex_chars=_env_int("TCD_STORAGE_SUBJECT_HASH_HEX_CHARS", 32),
            subject_part_max_bytes=_env_int("TCD_STORAGE_SUBJECT_PART_MAX_BYTES", 128),
            forbid_subject_delim=_env_bool("TCD_STORAGE_FORBID_SUBJECT_DELIM", True),
            alpha0_floor=_env_float("TCD_STORAGE_ALPHA0_FLOOR", 0.000001),
            reject_negative_values_external=_env_bool("TCD_STORAGE_REJECT_NEGATIVE_EXTERNAL", True),
            policy_ref_max_bytes=_env_int("TCD_STORAGE_POLICY_REF_MAX_BYTES", _MAX_POLICY_REF_BYTES),
            strict_policy_ref_taglike=_env_bool("TCD_STORAGE_STRICT_POLICY_REF_TAGLIKE", True),
            max_wealth_events_in_memory=_env_int("TCD_STORAGE_MAX_WEALTH_EVENTS_IN_MEMORY", 200_000),
            validate_receipt_json=_env_bool("TCD_STORAGE_VALIDATE_RECEIPT_JSON", True),
            canonicalize_receipt_body=_env_bool("TCD_STORAGE_CANONICALIZE_RECEIPT_BODY", False),
            strict_dict_top_level_external=_env_bool("TCD_STORAGE_STRICT_RECEIPT_DICT_TOPLEVEL_EXTERNAL", False),
            reject_forbidden_body_keys=_env_bool("TCD_STORAGE_REJECT_FORBIDDEN_BODY_KEYS", True),
            verify_receipt_head=_env_bool("TCD_STORAGE_VERIFY_RECEIPT_HEAD", True),
            verify_attestation_semantics_if_possible=_env_bool("TCD_STORAGE_VERIFY_ATTESTATION_SEMANTICS", False),
            enforce_single_genesis_per_chain=_env_bool("TCD_STORAGE_ENFORCE_SINGLE_GENESIS", True),
            require_chain_leaf_append=_env_bool("TCD_STORAGE_REQUIRE_CHAIN_LEAF_APPEND", True),
            fail_closed_on_chain_ambiguity=_env_bool("TCD_STORAGE_FAIL_CLOSED_CHAIN_AMBIGUITY", True),
            server_assign_receipt_chain_position=_env_bool("TCD_STORAGE_SERVER_ASSIGN_RECEIPT_CHAIN_POSITION", True),
            default_chain_namespace=_env("TCD_STORAGE_DEFAULT_CHAIN_NAMESPACE", "default"),
            default_chain_id=_env("TCD_STORAGE_DEFAULT_CHAIN_ID", "default"),
            max_receipt_body_bytes=_env_int("TCD_STORAGE_MAX_RECEIPT_BODY_BYTES", _MAX_RECEIPT_BODY_BYTES),
            max_verify_key_bytes=_env_int("TCD_STORAGE_MAX_VERIFY_KEY_BYTES", _MAX_VERIFY_KEY_BYTES),
            max_sig_bytes=_env_int("TCD_STORAGE_MAX_SIG_BYTES", _MAX_SIG_BYTES),
            max_page_size=_env_int("TCD_STORAGE_MAX_PAGE_SIZE", _MAX_PAGE_SIZE),
            max_tail_size=_env_int("TCD_STORAGE_MAX_TAIL_SIZE", _MAX_PAGE_SIZE),
            sqlite_timeout_s=_env_float("TCD_STORAGE_SQLITE_TIMEOUT_S", 30.0),
            sqlite_synchronous=_env("TCD_STORAGE_SQLITE_SYNCHRONOUS", "FULL"),
            sqlite_wal_autocheckpoint=_env_int("TCD_STORAGE_SQLITE_WAL_AUTOCHECKPOINT", 1000),
            sqlite_journal_size_limit=_env_int("TCD_STORAGE_SQLITE_JOURNAL_SIZE_LIMIT", 64 * 1024 * 1024),
        )


# =============================================================================
# Subject normalization
# =============================================================================


def _subject_component_hash(label: str, value: str, *, cfg: StorageConfig) -> str:
    raw = value.encode("utf-8", errors="ignore")
    ctx = f"tcd:storage:{label}:v2".encode("utf-8", errors="strict")
    if cfg.subject_hash_key is not None:
        dig = hmac.new(cfg.subject_hash_key, ctx + b"\x00" + raw, hashlib.sha256).hexdigest()[: cfg.subject_hash_hex_chars]
        kid = cfg.subject_hash_key_id or "hmac"
        return f"{label}-h-{kid}-{dig}"
    dig = hashlib.sha256(ctx + b"\x00" + raw).hexdigest()[: cfg.subject_hash_hex_chars]
    return f"{label}-h-sha256-{dig}"


def _subject_hash(subject: Subject, *, cfg: StorageConfig) -> str:
    payload = {"tenant": subject[0], "user": subject[1], "session": subject[2]}
    if cfg.subject_hash_key is not None:
        raw = _canonical_json_bytes(payload)
        dig = hmac.new(cfg.subject_hash_key, b"tcd:storage:subject\x00" + raw, hashlib.sha256).hexdigest()[: cfg.subject_hash_hex_chars]
        kid = cfg.subject_hash_key_id or "hmac"
        return f"{_SUBJECT_HASH_VERSION}:{kid}:{dig}"
    return f"{_SUBJECT_HASH_VERSION}:sha256:{_hash_hex(ctx='tcd:storage:subject', payload=payload, out_hex=cfg.subject_hash_hex_chars)}"


def sanitize_subject(subject: Subject, cfg: Optional[StorageConfig] = None) -> Subject:
    cfg = cfg or StorageConfig()
    if not isinstance(subject, tuple) or len(subject) != 3:
        raise StorageIntegrityError("subject must be a 3-tuple")
    out: List[str] = []
    labels = ("tenant", "user", "session")
    strict = _profile_is_strict(cfg.profile)
    for idx, raw in enumerate(subject):
        label = labels[idx]
        s = _safe_text(raw, max_len=cfg.subject_part_max_bytes)
        if not s:
            s = f"{label}0"
        pii_like = ("@" in s) or (" " in s)
        bad_delim = cfg.forbid_subject_delim and ("|" in s or ":" in s)
        safe = bool(_SAFE_TAGLIKE_RE.fullmatch(s))
        if cfg.hash_subject_ids and strict and cfg.external_hash_all_subject_fields:
            out.append(_subject_component_hash(label, s, cfg=cfg))
            continue
        if pii_like or bad_delim or not safe:
            if cfg.hash_subject_ids:
                out.append(_subject_component_hash(label, s, cfg=cfg))
            else:
                out.append(f"{label}0")
            continue
        out.append(s)
    return (out[0], out[1], out[2])


def _subject_and_hash(subject: Subject, cfg: StorageConfig) -> Tuple[Subject, str]:
    subj = sanitize_subject(subject, cfg=cfg)
    return subj, _subject_hash(subj, cfg=cfg)


# =============================================================================
# Wealth models / protocol
# =============================================================================


@dataclass(frozen=True)
class WealthStep:
    event_id: Optional[str] = None
    idem_key: Optional[str] = None
    ts_unix_ns: Optional[int] = None

    policy_ref: str = "default"
    state_domain_id: str = "default"
    adapter_registry_fp: Optional[str] = None

    alpha_spent: float = 0.0
    reject: bool = False
    earn: float = 0.0
    reward: float = 0.0

    reason_code: str = "DEFAULT_ALLOW"
    trust_zone: str = "internet"
    route_profile: str = "inference"

    route_plan_id: Optional[str] = None
    decision_id: Optional[str] = None
    signal_digest: Optional[str] = None
    context_digest: Optional[str] = None

    selected_source: Optional[str] = None
    controller_mode: Optional[str] = None
    decision_mode: Optional[str] = None
    statistical_guarantee_scope: Optional[str] = None
    expected_state_revision: Optional[int] = None
    identity_status: Optional[str] = None

    audit_ref: Optional[str] = None
    receipt_ref: Optional[str] = None

    degraded_reasons: Tuple[str, ...] = field(default_factory=tuple)
    meta: Mapping[str, Any] = field(default_factory=dict)

    def normalized(self, *, cfg: StorageConfig) -> "WealthStep":
        event_id = _safe_id(self.event_id, default=None, max_len=256)
        idem_key = _safe_id(self.idem_key, default=None, max_len=256)
        if _profile_is_strict(cfg.profile) and not event_id and not idem_key:
            raise StorageIntegrityError("strict profiles require event_id or idem_key")
        ts_unix_ns = _coerce_int(self.ts_unix_ns)
        if ts_unix_ns is None:
            ts_unix_ns = now_unix_ns()

        policy_ref = _safe_id(self.policy_ref, default="default", max_len=cfg.policy_ref_max_bytes) or "default"
        if cfg.strict_policy_ref_taglike and not _SAFE_TAGLIKE_RE.fullmatch(policy_ref):
            raise StorageIntegrityError("invalid policy_ref")

        state_domain_id = _safe_id(self.state_domain_id, default="default", max_len=256) or "default"

        alpha_spent = float(_coerce_float(self.alpha_spent) or 0.0)
        earn = float(_coerce_float(self.earn) or 0.0)
        reward = float(_coerce_float(self.reward) or 0.0)
        if _profile_is_strict(cfg.profile) and cfg.reject_negative_values_external:
            if alpha_spent < 0.0 or earn < 0.0 or reward < 0.0:
                raise StorageIntegrityError("negative wealth values are not allowed in strict profiles")
        alpha_spent = max(0.0, alpha_spent)
        earn = max(0.0, earn)
        reward = max(0.0, reward)

        rc = _safe_reason_code(self.reason_code, default="DEFAULT_ALLOW") or "DEFAULT_ALLOW"
        cm = _safe_label(self.controller_mode, default="") or None if self.controller_mode is not None else None
        dm = _safe_label(self.decision_mode, default="") or None if self.decision_mode is not None else None
        gs = _safe_text_or_none(self.statistical_guarantee_scope, max_len=128)

        if cm is not None and cm not in _ALLOWED_CONTROLLER_MODES:
            raise StorageIntegrityError("invalid controller_mode")
        if dm is not None and dm not in _ALLOWED_DECISION_MODES:
            raise StorageIntegrityError("invalid decision_mode")
        if gs is not None and gs not in _ALLOWED_GUARANTEE_SCOPES:
            raise StorageIntegrityError("invalid statistical_guarantee_scope")

        esr = _coerce_int(self.expected_state_revision)
        if esr is not None and esr < 0:
            raise StorageIntegrityError("expected_state_revision must be >=0")

        return WealthStep(
            event_id=event_id,
            idem_key=idem_key,
            ts_unix_ns=max(0, ts_unix_ns),
            policy_ref=policy_ref,
            state_domain_id=state_domain_id,
            adapter_registry_fp=_safe_id(self.adapter_registry_fp, default=None, max_len=256),
            alpha_spent=alpha_spent,
            reject=bool(self.reject),
            earn=earn,
            reward=reward,
            reason_code=rc,
            trust_zone=_safe_label(self.trust_zone, default="internet"),
            route_profile=_safe_label(self.route_profile, default="inference"),
            route_plan_id=_safe_id(self.route_plan_id, default=None, max_len=256),
            decision_id=_safe_id(self.decision_id, default=None, max_len=256),
            signal_digest=_normalize_digest_token(self.signal_digest, kind="any", default=None),
            context_digest=_normalize_digest_token(self.context_digest, kind="any", default=None),
            selected_source=_safe_label(self.selected_source, default="") or None if self.selected_source is not None else None,
            controller_mode=cm,
            decision_mode=dm,
            statistical_guarantee_scope=gs,
            expected_state_revision=esr,
            identity_status=_safe_label(self.identity_status, default="") or None if self.identity_status is not None else None,
            audit_ref=_safe_id(self.audit_ref, default=None, max_len=256),
            receipt_ref=_safe_id(self.receipt_ref, default=None, max_len=256),
            degraded_reasons=_normalize_reason_codes(self.degraded_reasons, max_items=32),
            meta=MappingProxyType(_safe_json_mapping(self.meta)),
        )

    def event_fingerprint(self, *, subject_hash: str) -> str:
        payload = {
            "subject_hash": subject_hash,
            "policy_ref": self.policy_ref,
            "state_domain_id": self.state_domain_id,
            "adapter_registry_fp": self.adapter_registry_fp,
            "alpha_spent": _stable_float(self.alpha_spent),
            "reject": bool(self.reject),
            "earn": _stable_float(self.earn),
            "reward": _stable_float(self.reward),
            "reason_code": self.reason_code,
            "trust_zone": self.trust_zone,
            "route_profile": self.route_profile,
            "route_plan_id": self.route_plan_id,
            "decision_id": self.decision_id,
            "signal_digest": self.signal_digest,
            "context_digest": self.context_digest,
            "selected_source": self.selected_source,
            "controller_mode": self.controller_mode,
            "decision_mode": self.decision_mode,
            "statistical_guarantee_scope": self.statistical_guarantee_scope,
            "identity_status": self.identity_status,
            "audit_ref": self.audit_ref,
            "receipt_ref": self.receipt_ref,
            "degraded_reasons": list(self.degraded_reasons),
            "meta": dict(self.meta),
        }
        return f"{_EVENT_FP_VERSION}:{_hash_hex(ctx='tcd:storage:wealth_event', payload=payload, out_hex=32)}"


@dataclass(frozen=True)
class WealthApplyResult:
    stored: bool
