    ts_unix_ns: int
    state_revision: int
    wealth_before: float
    wealth_after: float
    alpha_spent: float
    earn: float
    reward: float
    reject: bool
    reason_code: str
    trust_zone: str
    route_profile: str
    route_plan_id: Optional[str]
    decision_id: Optional[str]
    signal_digest: Optional[str]
    context_digest: Optional[str]
    selected_source: Optional[str]
    controller_mode: Optional[str]
