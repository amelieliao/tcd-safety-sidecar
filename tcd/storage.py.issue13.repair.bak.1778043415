def _extract_receipt_fields(body_obj: Any) -> Dict[str, Any]:
    if not isinstance(body_obj, dict):
        return {}
    get = body_obj.get
    return {
        "schema": get("schema"),
        "schema_version": get("schema_version"),
        "canonicalization_version": get("canonicalization_version"),
        "receipt_kind": get("receipt_kind"),
        "event_type": get("event_type"),
        "request_id": get("request_id"),
        "head": get("head") or get("receipt_head") or get("receipt") or get("receiptHead"),
        "body": get("body") or get("receipt_body") or get("receiptBody"),
        "sig": get("sig") or get("receipt_sig") or get("receiptSig"),
        "verify_key": get("verify_key") or get("verifyKey"),
        "receipt_integrity": get("receipt_integrity"),
        "body_kind": get("body_kind"),
        "body_digest": get("body_digest"),
        "body_schema": get("body_schema"),
        "body_canonicalized": get("body_canonicalized"),
        "sig_scheme": get("sig_scheme"),
        "sig_alg": get("sig_alg"),
        "sig_chain_id": get("sig_chain_id"),
        "sig_key_id": get("sig_key_id"),
        "verify_key_fp": get("verify_key_fp"),
        "verify_key_id": get("verify_key_id"),
        "pq_required": get("pq_required"),
        "pq_ok": get("pq_ok"),
        "pq_signature_required": get("pq_signature_required"),
        "pq_signature_ok": get("pq_signature_ok"),
        "ts": get("ts"),
        "ts_ns": get("ts_ns"),
        "ts_unix_ns": get("ts_unix_ns"),
        "build_id": get("build_id"),
        "image_digest": get("image_digest"),
        "attestation_id": get("attestation_id"),
        "env_fingerprint": get("env_fingerprint"),
        "policy_ref": get("policy_ref"),
        "policyset_ref": get("policyset_ref"),
        "policy_digest": get("policy_digest"),
        "cfg_fp": get("cfg_fp") or get("config_fingerprint"),
        "config_hash": get("config_hash"),
        "stream_hash": get("stream_hash"),
        "state_domain_id": get("state_domain_id"),
        "adapter_registry_fp": get("adapter_registry_fp"),
        "event_id": get("event_id"),
        "decision_id": get("decision_id"),
        "route_plan_id": get("route_plan_id"),
        "route_id": get("route_id"),
        "audit_ref": get("audit_ref"),
        "receipt_ref": get("receipt_ref"),
        "ledger_ref": get("ledger_ref"),
        "attestation_ref": get("attestation_ref"),
        "chain_namespace": get("chain_namespace"),
        "chain_id": get("chain_id"),
        "chain_seq": get("chain_seq"),
        "prev_head_hex": get("prev_head_hex"),
        "action": get("action"),
        "reason": get("reason"),
        "selected_source": get("selected_source"),
        "statistical_guarantee_scope": get("statistical_guarantee_scope"),
        "trigger": get("trigger"),
        "allowed": get("allowed"),
        "produced_by": get("produced_by"),
        "provenance_path_digest": get("provenance_path_digest"),
        "head_verified": get("head_verified"),
        "body_canonical_verified": get("body_canonical_verified"),
        "integrity_hash_verified": get("integrity_hash_verified"),
        "signature_verified": get("signature_verified"),
        "verify_key_allowed": get("verify_key_allowed"),
        "policy_binding_verified": get("policy_binding_verified"),
        "cfg_binding_verified": get("cfg_binding_verified"),
        "integrity_ok": get("integrity_ok"),
        "integrity_errors": get("integrity_errors"),
        "normalization_warnings": get("normalization_warnings"),
        "compat_warnings": get("compat_warnings") or get("compatibility_warnings"),
        "meta": get("meta"),
        "prepare_ref": get("prepare_ref"),
        "commit_ref": get("commit_ref"),
        "outbox_ref": get("outbox_ref"),
        "outbox_status": get("outbox_status"),
        "outbox_dedupe_key": get("outbox_dedupe_key"),
        "delivery_attempts": get("delivery_attempts"),
        "ledger_stage": get("ledger_stage"),
        "receipt_surface_kind": get("receipt_surface_kind"),
        "receipt_delivery_state": get("receipt_delivery_state"),
        "evidence_durable": get("evidence_durable"),
        "evidence_storage_ready": get("evidence_storage_ready"),
        "governance_terminal": get("governance_terminal"),
        "receipt_governance_ready": get("receipt_governance_ready"),
        "payload_digest": get("payload_digest"),
        "event_digest": get("event_digest"),
    }


def _canonicalize_receipt_body(body_json: str, *, cfg: StorageConfig) -> Tuple[str, Any]:
    if not isinstance(body_json, str):
        raise StorageIntegrityError("receipt body_json must be a string")
    body = body_json
    try:
        body_bytes = body.encode("utf-8", errors="strict")
    except UnicodeEncodeError as exc:
        raise StorageIntegrityError("receipt body_json must be strict UTF-8 encodable") from exc
    if len(body_bytes) > cfg.max_receipt_body_bytes:
        raise StorageIntegrityError("receipt body exceeds configured byte budget")
    if cfg.validate_receipt_json:
        if _json_depth_exceeds(body, max_depth=_MAX_JSON_DEPTH):
            raise StorageIntegrityError("receipt body exceeds max JSON depth")
        try:
            parsed = _json_loads_strict(body)
        except Exception as exc:
            raise StorageIntegrityError("receipt body_json must be valid strict JSON") from exc
        if cfg.strict_dict_top_level_external and _profile_is_strict(cfg.profile) and not isinstance(parsed, dict):
            raise StorageIntegrityError("strict profiles require dict-like receipt body")
        if cfg.reject_forbidden_body_keys and _body_contains_forbidden_keys(parsed):
            raise StorageIntegrityError("receipt body contains forbidden content-bearing keys")
        body_norm = _canonical_json_str(parsed) if cfg.canonicalize_receipt_body else body
        if len(body_norm.encode("utf-8", errors="strict")) > cfg.max_receipt_body_bytes:
            raise StorageIntegrityError("canonical receipt body exceeds configured byte budget")
        return body_norm, parsed
    return body, None


def _normalize_head_token(head: Any) -> str:
    s = _normalize_digest_token(head, kind="receipt_head", default=None)
    if s is None:
        raise StorageIntegrityError("invalid receipt head")
    if s.startswith("0x"):
        return s[2:]
    if _DIGEST_ALG_HEX_RE.fullmatch(s):
        algo, _, rest = s.partition(":")
        return f"{algo}:{rest.lower()}"
    return s.lower()


def _normalize_prev_head_token(prev: Any) -> Optional[str]:
    if prev is None:
        return None
    s = _normalize_digest_token(prev, kind="receipt_head", default=None)
    if s is None:
        raise StorageIntegrityError("invalid prev_head_hex")
    if s.startswith("0x"):
        return s[2:]
    if _DIGEST_ALG_HEX_RE.fullmatch(s):
        algo, _, rest = s.partition(":")
        return f"{algo}:{rest.lower()}"
    return s.lower()


def _receipt_body_digest(body_json: str) -> str:
    return f"{_PAYLOAD_DIGEST_VERSION}:sha256:{hashlib.sha256(body_json.encode('utf-8', errors='strict')).hexdigest()}"


def _derive_attestation_ref(
    *,
    head_hex: Optional[str],
    receipt_ref: Optional[str],
    candidate: Optional[str],
) -> Optional[str]:
    cand = _safe_id(candidate, default=None, max_len=512)
    if cand:
        return cand
    base = _safe_id(receipt_ref, default=None, max_len=512) or _safe_id(head_hex, default=None, max_len=512)
    if not base:
        return None
    if base.startswith("attest:"):
        return base
    return f"attest:{base}"


def _compute_storage_receipt_head(
    *,
    chain_namespace: str,
    chain_id: str,
    prev_head_hex: Optional[str],
    body_json: str,
    sig_value: str,
) -> str:
    h = hashlib.blake2s(digest_size=32)
    h.update(b"tcd:storage:receipt_head:v1\x00")
    h.update(chain_namespace.encode("utf-8", errors="strict"))
    h.update(b"\x00")
    h.update(chain_id.encode("utf-8", errors="strict"))
    h.update(b"\x00")
    h.update((prev_head_hex or "").encode("utf-8", errors="strict"))
    h.update(b"\x00")
    h.update(body_json.encode("utf-8", errors="strict"))
    h.update(b"\x00")
    h.update(sig_value.encode("utf-8", errors="strict"))
    return h.hexdigest()


def _compute_chain_head(
    *,
    chain_namespace: str,
    chain_id: str,
    prev_chain_head_hex: Optional[str],
    receipt_head_hex: str,
    body_digest: str,
    payload_digest: str,
    sig_value: str,
    head_semantics: str,
) -> str:
    h = hashlib.blake2s(digest_size=32)
    h.update(b"tcd:storage:chain_head:v2\x00")
    h.update(chain_namespace.encode("utf-8", errors="strict"))
    h.update(b"\x00")
    h.update(chain_id.encode("utf-8", errors="strict"))
    h.update(b"\x00")
    h.update((prev_chain_head_hex or "").encode("utf-8", errors="strict"))
    h.update(b"\x00")
    h.update(receipt_head_hex.encode("utf-8", errors="strict"))
    h.update(b"\x00")
    h.update(body_digest.encode("utf-8", errors="strict"))
    h.update(b"\x00")
    h.update(payload_digest.encode("utf-8", errors="strict"))
    h.update(b"\x00")
    h.update(sig_value.encode("utf-8", errors="strict"))
    h.update(b"\x00")
    h.update(head_semantics.encode("utf-8", errors="strict"))
    return f"{_CHAIN_HEAD_VERSION}:blake2s:{h.hexdigest()}"


def _semantic_fingerprint(env: "ReceiptEnvelope") -> str:
    payload = {
        "head_hex": env.head_hex,
        "head_semantics": env.head_semantics,
        "body_json": env.body_json,
        "body_digest": env.body_digest,
        "sig": env.sig,
        "verify_key_fp": env.verify_key_fp,
        "verify_key_id": env.verify_key_id,
        "receipt_integrity": env.receipt_integrity,
        "request_id": env.request_id,
        "event_id": env.event_id,
        "decision_id": env.decision_id,
        "route_plan_id": env.route_plan_id,
        "policy_ref": env.policy_ref,
        "policyset_ref": env.policyset_ref,
        "policy_digest": env.policy_digest,
        "cfg_fp": env.cfg_fp,
        "state_domain_id": env.state_domain_id,
        "adapter_registry_fp": env.adapter_registry_fp,
        "audit_ref": env.audit_ref,
        "receipt_ref": env.receipt_ref,
        "ledger_ref": env.ledger_ref,
        "attestation_ref": env.attestation_ref,
        "prepare_ref": env.prepare_ref,
        "commit_ref": env.commit_ref,
        "outbox_ref": env.outbox_ref,
        "outbox_status": env.outbox_status,
        "ledger_stage": env.ledger_stage,
        "chain_namespace": env.chain_namespace,
        "chain_id": env.chain_id,
        "chain_seq": env.chain_seq,
        "prev_head_hex": env.prev_head_hex,
        "payload_digest": env.payload_digest,
        "event_digest": env.event_digest,
        "receipt_surface_kind": env.receipt_surface_kind,
        "receipt_delivery_state": env.receipt_delivery_state,
        "evidence_durable": env.evidence_durable,
        "evidence_storage_ready": env.evidence_storage_ready,
        "governance_terminal": env.governance_terminal,
        "receipt_governance_ready": env.receipt_governance_ready,
    }
    return f"rsf1:{_hash_hex(ctx='tcd:storage:receipt_semantic', payload=payload, out_hex=32)}"


@dataclass(frozen=True)
class ReceiptEnvelope:
    head_hex: str
    body_json: str

    head_semantics: str = "external_receipt_passthrough"

    sig: Optional[str] = None
    verify_key: Optional[str] = None
    verify_key_fp: Optional[str] = None
    verify_key_id: Optional[str] = None
    receipt_integrity: Optional[str] = None

    schema: Optional[str] = None
    schema_version: Optional[int] = None
    canonicalization_version: Optional[str] = None
    receipt_kind: Optional[str] = None
    event_type: Optional[str] = None
    body_kind: Optional[str] = None
    body_digest: Optional[str] = None
    body_schema: Optional[str] = None
    body_canonicalized: Optional[bool] = None

    sig_scheme: Optional[str] = None
    sig_alg: Optional[str] = None
    sig_chain_id: Optional[str] = None
    sig_key_id: Optional[str] = None

    pq_required: Optional[bool] = None
    pq_ok: Optional[bool] = None
    pq_signature_required: Optional[bool] = None
    pq_signature_ok: Optional[bool] = None

    ts: Optional[float] = None
    ts_ns: Optional[int] = None
    ts_unix_ns: Optional[int] = None

    build_id: Optional[str] = None
    image_digest: Optional[str] = None
    attestation_id: Optional[str] = None
    env_fingerprint: Optional[str] = None

    policy_ref: Optional[str] = None
    policyset_ref: Optional[str] = None
    policy_digest: Optional[str] = None
    cfg_fp: Optional[str] = None
    config_hash: Optional[str] = None

    stream_hash: Optional[str] = None
    state_domain_id: Optional[str] = None
    adapter_registry_fp: Optional[str] = None

    request_id: Optional[str] = None
    event_id: Optional[str] = None
    decision_id: Optional[str] = None
    route_plan_id: Optional[str] = None
    route_id: Optional[str] = None
    audit_ref: Optional[str] = None
    receipt_ref: Optional[str] = None
    ledger_ref: Optional[str] = None
    attestation_ref: Optional[str] = None

    chain_namespace: Optional[str] = None
    chain_id: Optional[str] = None
    chain_seq: Optional[int] = None
    prev_head_hex: Optional[str] = None

    action: Optional[str] = None
    reason: Optional[str] = None
    selected_source: Optional[str] = None
    statistical_guarantee_scope: Optional[str] = None
    trigger: Optional[bool] = None
    allowed: Optional[bool] = None

    prepare_ref: Optional[str] = None
    commit_ref: Optional[str] = None
    ledger_stage: Optional[str] = None
    outbox_ref: Optional[str] = None
    outbox_status: Optional[str] = None
    outbox_dedupe_key: Optional[str] = None
    delivery_attempts: Optional[int] = None

    receipt_surface_kind: Optional[str] = None
    receipt_delivery_state: Optional[str] = None
    evidence_durable: Optional[bool] = None
    evidence_storage_ready: Optional[bool] = None
    governance_terminal: Optional[bool] = None
    receipt_governance_ready: Optional[bool] = None

    payload_digest: Optional[str] = None
    event_digest: Optional[str] = None

    produced_by: Tuple[str, ...] = field(default_factory=tuple)
    provenance_path_digest: Optional[str] = None

    head_verified: Optional[bool] = None
    body_canonical_verified: Optional[bool] = None
    integrity_hash_verified: Optional[bool] = None
    signature_verified: Optional[bool] = None
    verify_key_allowed: Optional[bool] = None
    policy_binding_verified: Optional[bool] = None
    cfg_binding_verified: Optional[bool] = None

    integrity_ok: Optional[bool] = None
    integrity_errors: Tuple[str, ...] = field(default_factory=tuple)
    normalization_warnings: Tuple[str, ...] = field(default_factory=tuple)
    compat_warnings: Tuple[str, ...] = field(default_factory=tuple)

    meta: Mapping[str, Any] = field(default_factory=dict)

    def normalized(self, *, cfg: StorageConfig) -> "ReceiptEnvelope":
        body_json, parsed = _canonicalize_receipt_body(self.body_json, cfg=cfg)
        body_fields = _extract_receipt_fields(parsed) if parsed is not None else {}

        head_semantics = _safe_label(self.head_semantics, default="external_receipt_passthrough")
        if head_semantics not in _ALLOWED_HEAD_SEMANTICS:
            head_semantics = "external_receipt_passthrough"

        head_hex = _normalize_head_token(self.head_hex or body_fields.get("head"))
        sig = _safe_text_or_none(self.sig or body_fields.get("sig"), max_len=cfg.max_sig_bytes)
        verify_key = _safe_text_or_none(self.verify_key or body_fields.get("verify_key"), max_len=cfg.max_verify_key_bytes)
        verify_key_fp = _normalize_digest_token(self.verify_key_fp or body_fields.get("verify_key_fp"), kind="any", default=None)
        verify_key_id = _safe_id(self.verify_key_id or body_fields.get("verify_key_id") or body_fields.get("sig_key_id"), default=None, max_len=256)
        receipt_integrity = _normalize_digest_token(self.receipt_integrity or body_fields.get("receipt_integrity"), kind="integrity", default=None)

        chain_namespace = _safe_id(self.chain_namespace or body_fields.get("chain_namespace") or cfg.default_chain_namespace, default=cfg.default_chain_namespace, max_len=_MAX_CHAIN_ID_BYTES) or cfg.default_chain_namespace
        chain_id = _safe_id(self.chain_id or body_fields.get("chain_id") or cfg.default_chain_id, default=cfg.default_chain_id, max_len=_MAX_CHAIN_ID_BYTES) or cfg.default_chain_id
        prev_head_hex = _normalize_prev_head_token(self.prev_head_hex or body_fields.get("prev_head_hex"))
        chain_seq = _coerce_int(self.chain_seq if self.chain_seq is not None else body_fields.get("chain_seq"))

        ts_unix_ns = _coerce_int(self.ts_unix_ns if self.ts_unix_ns is not None else body_fields.get("ts_unix_ns"))
        if ts_unix_ns is None:
            ts_ns = _coerce_int(self.ts_ns if self.ts_ns is not None else body_fields.get("ts_ns"))
            ts = _coerce_float(self.ts if self.ts is not None else body_fields.get("ts"))
            if ts_ns is not None:
                ts_unix_ns = max(0, ts_ns)
            elif ts is not None:
                ts_unix_ns = max(0, int(ts * 1_000_000_000))
            else:
                ts_unix_ns = now_unix_ns()

        body_digest = _normalize_digest_token(self.body_digest or body_fields.get("body_digest"), kind="any", default=None) or _receipt_body_digest(body_json)
        payload_digest = _normalize_digest_token(self.payload_digest or body_fields.get("payload_digest"), kind="any", default=None) or body_digest

        produced_by = _normalize_str_tuple(self.produced_by if self.produced_by else body_fields.get("produced_by"), max_len=64, max_items=32)
        provenance_path_digest = _normalize_digest_token(self.provenance_path_digest or body_fields.get("provenance_path_digest"), kind="any", default=None)
        if provenance_path_digest is None and produced_by:
            provenance_path_digest = f"sha256:{_hash_hex(ctx='tcd:storage:produced_by', payload={'produced_by': list(produced_by)}, out_hex=64)}"

        meta_src = self.meta or body_fields.get("meta")
        meta_map = _safe_json_mapping(meta_src)
        meta = MappingProxyType(meta_map)
        integrity_errors = list(_normalize_str_tuple(self.integrity_errors or body_fields.get("integrity_errors"), max_len=256, max_items=64))
        normalization_warnings = _normalize_str_tuple(self.normalization_warnings or body_fields.get("normalization_warnings"), max_len=256, max_items=32)
        compat_warnings = _normalize_str_tuple(self.compat_warnings or body_fields.get("compat_warnings"), max_len=256, max_items=32)

        head_verified = _coerce_bool(self.head_verified if self.head_verified is not None else body_fields.get("head_verified"))
        if cfg.verify_receipt_head:
            if head_semantics == "storage_chain_v1":
                expected_head = _compute_storage_receipt_head(
                    chain_namespace=chain_namespace,
                    chain_id=chain_id,
                    prev_head_hex=prev_head_hex,
                    body_json=body_json,
                    sig_value=sig or "",
                )
                if ":" in head_hex:
                    _alg, _, rest = head_hex.partition(":")
                    head_verified = (rest == expected_head)
                else:
                    head_verified = (head_hex == expected_head)
                if not head_verified:
                    integrity_errors.append("INTEGRITY_ERROR")
            elif parsed is not None and isinstance(parsed, dict):
                embedded = body_fields.get("head")
                if isinstance(embedded, str):
                    with contextlib.suppress(Exception):
                        head_verified = (_normalize_head_token(embedded) == head_hex)

        integrity_ok = _coerce_bool(self.integrity_ok if self.integrity_ok is not None else body_fields.get("integrity_ok"))
        if integrity_ok is None:
            integrity_ok = len(integrity_errors) == 0
        if integrity_errors:
            integrity_ok = False

        gs = _safe_text_or_none(self.statistical_guarantee_scope or body_fields.get("statistical_guarantee_scope"), max_len=128)
        if gs is not None and gs not in _ALLOWED_GUARANTEE_SCOPES:
            raise StorageIntegrityError("invalid statistical_guarantee_scope")

        ledger_stage = _safe_label(self.ledger_stage or body_fields.get("ledger_stage"), default="") or None if (self.ledger_stage or body_fields.get("ledger_stage")) is not None else None
        if ledger_stage is not None and ledger_stage not in _ALLOWED_LEDGER_STAGE:
            raise StorageIntegrityError("invalid ledger_stage")

        outbox_status = _safe_label(self.outbox_status or body_fields.get("outbox_status"), default="") or None if (self.outbox_status or body_fields.get("outbox_status")) is not None else None
        if outbox_status is not None and outbox_status not in _ALLOWED_OUTBOX_STATUS:
            raise StorageIntegrityError("invalid outbox_status")

        audit_ref = _safe_id(self.audit_ref or body_fields.get("audit_ref"), default=None, max_len=512)
        receipt_ref = _safe_id(self.receipt_ref or body_fields.get("receipt_ref"), default=None, max_len=512) or f"receipt@1#{head_hex[:16]}"
        ledger_ref = _safe_id(self.ledger_ref or body_fields.get("ledger_ref"), default=None, max_len=512)
        attestation_ref = _derive_attestation_ref(
            head_hex=head_hex,
            receipt_ref=receipt_ref,
            candidate=self.attestation_ref or body_fields.get("attestation_ref"),
        )
        prepare_ref = _safe_id(self.prepare_ref or body_fields.get("prepare_ref"), default=None, max_len=512)
        commit_ref = _safe_id(self.commit_ref or body_fields.get("commit_ref"), default=None, max_len=512)
        outbox_ref = _safe_id(self.outbox_ref or body_fields.get("outbox_ref"), default=None, max_len=512)

        return ReceiptEnvelope(
            head_hex=head_hex,
            body_json=body_json,
            head_semantics=head_semantics,
            sig=sig,
            verify_key=verify_key,
            verify_key_fp=verify_key_fp,
            verify_key_id=verify_key_id,
            receipt_integrity=receipt_integrity,
            schema=_safe_id(self.schema or body_fields.get("schema") or _RECEIPT_SCHEMA, default=_RECEIPT_SCHEMA, max_len=128),
            schema_version=max(0, _coerce_int(self.schema_version if self.schema_version is not None else body_fields.get("schema_version")) or 0) or None,
            canonicalization_version=_safe_text_or_none(self.canonicalization_version or body_fields.get("canonicalization_version"), max_len=64) or _CANONICALIZATION_VERSION,
            receipt_kind=_safe_id(self.receipt_kind or body_fields.get("receipt_kind"), default=None, max_len=128),
            event_type=_safe_id(self.event_type or body_fields.get("event_type"), default=None, max_len=128),
            body_kind=_safe_label(self.body_kind or body_fields.get("body_kind"), default="") or None if (self.body_kind or body_fields.get("body_kind")) is not None else None,
            body_digest=body_digest,
            body_schema=_safe_id(self.body_schema or body_fields.get("body_schema"), default=None, max_len=128),
            body_canonicalized=True if cfg.canonicalize_receipt_body else (_coerce_bool(self.body_canonicalized if self.body_canonicalized is not None else body_fields.get("body_canonicalized"))),
            sig_scheme=_safe_id(self.sig_scheme or body_fields.get("sig_scheme"), default=None, max_len=128),
            sig_alg=_safe_id(self.sig_alg or body_fields.get("sig_alg"), default=None, max_len=128),
            sig_chain_id=_safe_id(self.sig_chain_id or body_fields.get("sig_chain_id"), default=None, max_len=128),
            sig_key_id=_safe_id(self.sig_key_id or body_fields.get("sig_key_id"), default=None, max_len=128),
            pq_required=_coerce_bool(self.pq_required if self.pq_required is not None else body_fields.get("pq_required")),
            pq_ok=_coerce_bool(self.pq_ok if self.pq_ok is not None else body_fields.get("pq_ok")),
            pq_signature_required=_coerce_bool(self.pq_signature_required if self.pq_signature_required is not None else body_fields.get("pq_signature_required")),
            pq_signature_ok=_coerce_bool(self.pq_signature_ok if self.pq_signature_ok is not None else body_fields.get("pq_signature_ok")),
            ts=_coerce_float(self.ts if self.ts is not None else body_fields.get("ts")),
            ts_ns=_coerce_int(self.ts_ns if self.ts_ns is not None else body_fields.get("ts_ns")),
            ts_unix_ns=ts_unix_ns,
            build_id=_safe_id(self.build_id or body_fields.get("build_id"), default=None, max_len=256),
            image_digest=_safe_id(self.image_digest or body_fields.get("image_digest"), default=None, max_len=256),
            attestation_id=_safe_id(self.attestation_id or body_fields.get("attestation_id"), default=None, max_len=256),
            env_fingerprint=_safe_id(self.env_fingerprint or body_fields.get("env_fingerprint"), default=None, max_len=256),
            policy_ref=_safe_id(self.policy_ref or body_fields.get("policy_ref"), default=None, max_len=256),
            policyset_ref=_safe_id(self.policyset_ref or body_fields.get("policyset_ref"), default=None, max_len=256),
            policy_digest=_normalize_digest_token(self.policy_digest or body_fields.get("policy_digest"), kind="any", default=None),
            cfg_fp=_normalize_digest_token(self.cfg_fp or body_fields.get("cfg_fp"), kind="cfg_fp", default=None),
            config_hash=_normalize_digest_token(self.config_hash or body_fields.get("config_hash"), kind="any", default=None),
            stream_hash=_safe_id(self.stream_hash or body_fields.get("stream_hash"), default=None, max_len=256),
            state_domain_id=_safe_id(self.state_domain_id or body_fields.get("state_domain_id"), default=None, max_len=256),
            adapter_registry_fp=_safe_id(self.adapter_registry_fp or body_fields.get("adapter_registry_fp"), default=None, max_len=256),
            request_id=_safe_id(self.request_id or body_fields.get("request_id") or meta_map.get("request_id"), default=None, max_len=256),
            event_id=_safe_id(self.event_id or body_fields.get("event_id"), default=None, max_len=256),
            decision_id=_safe_id(self.decision_id or body_fields.get("decision_id"), default=None, max_len=256),
            route_plan_id=_safe_id(self.route_plan_id or body_fields.get("route_plan_id"), default=None, max_len=256),
            route_id=_safe_id(self.route_id or body_fields.get("route_id") or self.route_plan_id or body_fields.get("route_plan_id"), default=None, max_len=256),
            audit_ref=audit_ref,
            receipt_ref=receipt_ref,
            ledger_ref=ledger_ref,
            attestation_ref=attestation_ref,
            chain_namespace=chain_namespace,
            chain_id=chain_id,
            chain_seq=max(0, chain_seq) if chain_seq is not None else None,
            prev_head_hex=prev_head_hex,
            action=_safe_label(self.action or body_fields.get("action"), default="") or None if (self.action or body_fields.get("action")) is not None else None,
            reason=_safe_text_or_none(self.reason or body_fields.get("reason"), max_len=256, redact_mode="log"),
            selected_source=_safe_id(self.selected_source or body_fields.get("selected_source"), default=None, max_len=256),
            statistical_guarantee_scope=gs,
            trigger=_coerce_bool(self.trigger if self.trigger is not None else body_fields.get("trigger")),
            allowed=_coerce_bool(self.allowed if self.allowed is not None else body_fields.get("allowed")),
            prepare_ref=prepare_ref,
            commit_ref=commit_ref,
            ledger_stage=ledger_stage,
            outbox_ref=outbox_ref,
            outbox_status=outbox_status,
            outbox_dedupe_key=_safe_id(self.outbox_dedupe_key or body_fields.get("outbox_dedupe_key"), default=None, max_len=256),
            delivery_attempts=max(0, _coerce_int(self.delivery_attempts if self.delivery_attempts is not None else body_fields.get("delivery_attempts")) or 0) or None,
            receipt_surface_kind=_safe_label(self.receipt_surface_kind or body_fields.get("receipt_surface_kind"), default="") or None if (self.receipt_surface_kind or body_fields.get("receipt_surface_kind")) is not None else None,
            receipt_delivery_state=_safe_label(self.receipt_delivery_state or body_fields.get("receipt_delivery_state"), default="") or None if (self.receipt_delivery_state or body_fields.get("receipt_delivery_state")) is not None else None,
            evidence_durable=_coerce_bool(self.evidence_durable if self.evidence_durable is not None else body_fields.get("evidence_durable")),
            evidence_storage_ready=_coerce_bool(self.evidence_storage_ready if self.evidence_storage_ready is not None else body_fields.get("evidence_storage_ready")),
            governance_terminal=_coerce_bool(self.governance_terminal if self.governance_terminal is not None else body_fields.get("governance_terminal")),
            receipt_governance_ready=_coerce_bool(self.receipt_governance_ready if self.receipt_governance_ready is not None else body_fields.get("receipt_governance_ready")),
            payload_digest=payload_digest,
            event_digest=_normalize_digest_token(self.event_digest or body_fields.get("event_digest"), kind="any", default=None),
            produced_by=produced_by,
            provenance_path_digest=provenance_path_digest,
            head_verified=head_verified,
            body_canonical_verified=_coerce_bool(self.body_canonical_verified if self.body_canonical_verified is not None else body_fields.get("body_canonical_verified")),
            integrity_hash_verified=_coerce_bool(self.integrity_hash_verified if self.integrity_hash_verified is not None else body_fields.get("integrity_hash_verified")),
            signature_verified=_coerce_bool(self.signature_verified if self.signature_verified is not None else body_fields.get("signature_verified")),
            verify_key_allowed=_coerce_bool(self.verify_key_allowed if self.verify_key_allowed is not None else body_fields.get("verify_key_allowed")),
            policy_binding_verified=_coerce_bool(self.policy_binding_verified if self.policy_binding_verified is not None else body_fields.get("policy_binding_verified")),
            cfg_binding_verified=_coerce_bool(self.cfg_binding_verified if self.cfg_binding_verified is not None else body_fields.get("cfg_binding_verified")),
            integrity_ok=bool(integrity_ok),
            integrity_errors=tuple(integrity_errors[:64]),
            normalization_warnings=normalization_warnings,
            compat_warnings=compat_warnings,
            meta=meta,
        )

    def to_receipt_view(self) -> Any:
        payload = {
            "schema": self.schema,
            "schema_version": self.schema_version,
            "canonicalization_version": self.canonicalization_version,
            "receipt_kind": self.receipt_kind,
            "event_type": self.event_type,
            "request_id": self.request_id,
            "head": self.head_hex,
            "body": self.body_json,
            "sig": self.sig,
            "verify_key": self.verify_key,
            "receipt_integrity": self.receipt_integrity,
            "body_kind": self.body_kind,
            "body_digest": self.body_digest,
            "body_schema": self.body_schema,
            "body_canonicalized": self.body_canonicalized,
            "sig_scheme": self.sig_scheme,
            "sig_alg": self.sig_alg,
            "sig_chain_id": self.sig_chain_id,
            "sig_key_id": self.sig_key_id,
            "verify_key_fp": self.verify_key_fp,
            "verify_key_id": self.verify_key_id,
            "pq_required": self.pq_required,
            "pq_ok": self.pq_ok,
            "pq_signature_required": self.pq_signature_required,
            "pq_signature_ok": self.pq_signature_ok,
            "store_backend": None,
            "store_id": None,
            "ts": self.ts,
            "ts_ns": self.ts_ns,
            "ts_unix_ns": self.ts_unix_ns,
            "build_id": self.build_id,
            "image_digest": self.image_digest,
            "attestation_id": self.attestation_id,
            "env_fingerprint": self.env_fingerprint,
            "policy_ref": self.policy_ref,
            "policyset_ref": self.policyset_ref,
            "policy_digest": self.policy_digest,
            "cfg_fp": self.cfg_fp,
            "config_hash": self.config_hash,
            "stream_hash": self.stream_hash,
            "state_domain_id": self.state_domain_id,
            "adapter_registry_fp": self.adapter_registry_fp,
            "event_id": self.event_id,
            "decision_id": self.decision_id,
            "route_plan_id": self.route_plan_id,
            "route_id": self.route_id,
            "audit_ref": self.audit_ref,
            "receipt_ref": self.receipt_ref,
            "ledger_ref": self.ledger_ref,
            "attestation_ref": self.attestation_ref,
            "chain_namespace": self.chain_namespace,
            "chain_id": self.chain_id,
            "chain_seq": self.chain_seq,
            "prev_head_hex": self.prev_head_hex,
            "action": self.action,
            "reason": self.reason,
            "selected_source": self.selected_source,
            "statistical_guarantee_scope": self.statistical_guarantee_scope,
            "trigger": self.trigger,
            "allowed": self.allowed,
            "prepare_ref": self.prepare_ref,
            "commit_ref": self.commit_ref,
            "ledger_stage": self.ledger_stage,
            "outbox_ref": self.outbox_ref,
            "outbox_status": self.outbox_status,
            "outbox_dedupe_key": self.outbox_dedupe_key,
            "delivery_attempts": self.delivery_attempts,
            "payload_digest": self.payload_digest,
            "event_digest": self.event_digest,
            "receipt_surface_kind": self.receipt_surface_kind,
            "receipt_delivery_state": self.receipt_delivery_state,
            "evidence_durable": self.evidence_durable,
            "evidence_storage_ready": self.evidence_storage_ready,
            "governance_terminal": self.governance_terminal,
            "receipt_governance_ready": self.receipt_governance_ready,
            "produced_by": list(self.produced_by),
            "provenance_path_digest": self.provenance_path_digest,
            "head_verified": self.head_verified,
            "body_canonical_verified": self.body_canonical_verified,
            "integrity_hash_verified": self.integrity_hash_verified,
            "signature_verified": self.signature_verified,
            "verify_key_allowed": self.verify_key_allowed,
            "policy_binding_verified": self.policy_binding_verified,
            "cfg_binding_verified": self.cfg_binding_verified,
            "integrity_ok": self.integrity_ok,
            "integrity_errors": list(self.integrity_errors),
            "normalization_warnings": list(self.normalization_warnings),
            "compat_warnings": list(self.compat_warnings),
            "meta": dict(self.meta),
        }
        return _view_instance(ReceiptView, payload)

    def to_public_view(self) -> Any:
        rv = self.to_receipt_view()
        if hasattr(rv, "to_public_view"):
            with contextlib.suppress(Exception):
                return rv.to_public_view(strict=False)
        if hasattr(rv, "to_public_dict"):
            with contextlib.suppress(Exception):
                return rv.to_public_dict(strict=False)
        payload = {
            "schema": self.schema,
            "head": self.head_hex,
            "receipt_ref": self.receipt_ref,
            "audit_ref": self.audit_ref,
            "attestation_ref": self.attestation_ref,
            "ledger_ref": self.ledger_ref,
            "prepare_ref": self.prepare_ref,
            "commit_ref": self.commit_ref,
            "outbox_ref": self.outbox_ref,
            "event_id": self.event_id,
            "decision_id": self.decision_id,
            "route_plan_id": self.route_plan_id,
            "policy_ref": self.policy_ref,
            "policyset_ref": self.policyset_ref,
            "cfg_fp": self.cfg_fp,
            "verify_key_id": self.verify_key_id or self.sig_key_id,
            "verify_key_fp": self.verify_key_fp,
            "receipt_integrity": self.receipt_integrity,
            "pq_required": self.pq_required,
            "pq_ok": self.pq_ok,
            "pq_signature_required": self.pq_signature_required,
            "pq_signature_ok": self.pq_signature_ok,
            "ledger_stage": self.ledger_stage,
            "outbox_status": self.outbox_status,
            "receipt_surface_kind": self.receipt_surface_kind,
            "receipt_delivery_state": self.receipt_delivery_state,
            "evidence_durable": self.evidence_durable,
            "evidence_storage_ready": self.evidence_storage_ready,
            "governance_terminal": self.governance_terminal,
            "receipt_governance_ready": self.receipt_governance_ready,
            "integrity_ok": bool(self.integrity_ok),
            "integrity_errors": list(self.integrity_errors),
        }
        return _view_instance(ReceiptPublicView, payload)

    def to_audit_view(self) -> Any:
        rv = self.to_receipt_view()
        if hasattr(rv, "to_audit_view"):
            with contextlib.suppress(Exception):
                return rv.to_audit_view(strict=False)
        if hasattr(rv, "to_audit_dict"):
            with contextlib.suppress(Exception):
                return rv.to_audit_dict(strict=False)
        payload = {
            "schema": self.schema,
            "request_id": self.request_id,
            "head": self.head_hex,
            "body_digest": self.body_digest,
            "receipt_ref": self.receipt_ref,
            "audit_ref": self.audit_ref,
            "attestation_ref": self.attestation_ref,
            "ledger_ref": self.ledger_ref,
            "prepare_ref": self.prepare_ref,
            "commit_ref": self.commit_ref,
            "outbox_ref": self.outbox_ref,
            "event_id": self.event_id,
            "decision_id": self.decision_id,
            "route_plan_id": self.route_plan_id,
            "policy_ref": self.policy_ref,
            "policyset_ref": self.policyset_ref,
            "policy_digest": self.policy_digest,
            "cfg_fp": self.cfg_fp,
            "state_domain_id": self.state_domain_id,
            "adapter_registry_fp": self.adapter_registry_fp,
            "receipt_surface_kind": self.receipt_surface_kind,
            "receipt_delivery_state": self.receipt_delivery_state,
            "evidence_durable": self.evidence_durable,
            "evidence_storage_ready": self.evidence_storage_ready,
            "governance_terminal": self.governance_terminal,
            "receipt_governance_ready": self.receipt_governance_ready,
            "verify_key_id": self.verify_key_id or self.sig_key_id,
            "verify_key_fp": self.verify_key_fp,
            "receipt_integrity": self.receipt_integrity,
            "integrity_ok": bool(self.integrity_ok),
            "integrity_errors": list(self.integrity_errors),
            "meta": dict(self.meta),
        }
        return _view_instance(ReceiptAuditView, payload)

    def to_verification_view(self, *, include_verify_key: bool = True) -> Any:
        rv = self.to_receipt_view()
        if hasattr(rv, "to_verification_view"):
            with contextlib.suppress(Exception):
                return rv.to_verification_view(strict=False, include_verify_key=include_verify_key)
        if hasattr(rv, "to_verification_dict"):
            with contextlib.suppress(Exception):
                return rv.to_verification_dict(strict=False, include_verify_key=include_verify_key)
        payload = {
            "schema": self.schema,
            "head": self.head_hex,
            "body": self.body_json,
            "sig": self.sig,
            "verify_key": self.verify_key if include_verify_key else None,
            "verify_key_id": self.verify_key_id or self.sig_key_id,
            "verify_key_fp": self.verify_key_fp,
            "receipt_integrity": self.receipt_integrity,
            "body_kind": self.body_kind,
            "body_digest": self.body_digest,
            "receipt_ref": self.receipt_ref,
            "audit_ref": self.audit_ref,
            "attestation_ref": self.attestation_ref,
            "ledger_ref": self.ledger_ref,
            "prepare_ref": self.prepare_ref,
            "commit_ref": self.commit_ref,
            "outbox_ref": self.outbox_ref,
            "ledger_stage": self.ledger_stage,
            "outbox_status": self.outbox_status,
            "receipt_surface_kind": self.receipt_surface_kind,
            "receipt_delivery_state": self.receipt_delivery_state,
            "evidence_durable": self.evidence_durable,
            "evidence_storage_ready": self.evidence_storage_ready,
            "head_verified": self.head_verified,
            "body_canonical_verified": self.body_canonical_verified,
            "integrity_hash_verified": self.integrity_hash_verified,
            "signature_verified": self.signature_verified,
            "verify_key_allowed": self.verify_key_allowed,
            "policy_binding_verified": self.policy_binding_verified,
            "cfg_binding_verified": self.cfg_binding_verified,
            "integrity_ok": bool(self.integrity_ok),
            "integrity_errors": list(self.integrity_errors),
        }
        return _view_instance(ReceiptVerificationView, payload)

    def evidence_identity_dict(self) -> Dict[str, Any]:
        payload = {
            "request_id": self.request_id,
            "event_id": self.event_id,
            "event_id_kind": "event",
            "decision_id": self.decision_id,
            "decision_id_kind": "decision",
            "route_plan_id": self.route_plan_id,
            "route_id": self.route_id or self.route_plan_id,
            "route_id_kind": "plan",
            "config_fingerprint": self.cfg_fp,
            "bundle_version": None,
            "policy_ref": self.policy_ref,
            "policyset_ref": self.policyset_ref,
            "state_domain_id": self.state_domain_id,
            "activation_id": None,
            "patch_id": None,
            "change_ticket_id": None,
            "audit_ref": self.audit_ref,
            "receipt_ref": self.receipt_ref,
            "attestation_ref": self.attestation_ref,
            "ledger_ref": self.ledger_ref,
            "prepare_ref": self.prepare_ref,
            "commit_ref": self.commit_ref,
            "outbox_ref": self.outbox_ref,
        }
        if EvidenceIdentityView is not None:
            with contextlib.suppress(Exception):
                obj = EvidenceIdentityView(**payload)
                if hasattr(obj, "model_dump"):
                    return dict(obj.model_dump())
        return payload

    def artifact_refs_dict(self) -> Dict[str, Any]:
        payload = {
            "audit_ref": self.audit_ref,
            "receipt_ref": self.receipt_ref,
            "ledger_ref": self.ledger_ref,
            "attestation_ref": self.attestation_ref,
            "event_digest": self.event_digest,
            "body_digest": self.body_digest,
            "payload_digest": self.payload_digest,
            "prepare_ref": self.prepare_ref,
            "commit_ref": self.commit_ref,
            "ledger_stage": self.ledger_stage,
            "outbox_ref": self.outbox_ref,
            "outbox_status": self.outbox_status,
            "outbox_dedupe_key": self.outbox_dedupe_key,
            "delivery_attempts": self.delivery_attempts,
            "chain_id": self.chain_id,
            "chain_head": getattr(self, "chain_head_hex", None),
            "produced_by": list(self.produced_by),
            "provenance_path_digest": self.provenance_path_digest,
        }
        if ArtifactRefsView is not None:
            with contextlib.suppress(Exception):
                obj = ArtifactRefsView(**payload)
                if hasattr(obj, "model_dump"):
                    return dict(obj.model_dump())
        return payload


@dataclass(frozen=True)
class ReceiptRecord(ReceiptEnvelope):
    chain_head_hex: Optional[str] = None
    prev_chain_head_hex: Optional[str] = None
    semantic_fingerprint: Optional[str] = None
    store_backend: str = "memory"
    store_id: Optional[int] = None
    inserted_at_unix_ns: Optional[int] = None
    updated_at_unix_ns: Optional[int] = None

    def with_backend(
        self,
        *,
        store_backend: str,
        store_id: Optional[int],
        inserted_at_unix_ns: int,
        updated_at_unix_ns: int,
    ) -> "ReceiptRecord":
        return ReceiptRecord(
            **{
                **_dataclass_shallow_dict(self),
                "store_backend": store_backend,
                "store_id": store_id,
                "inserted_at_unix_ns": inserted_at_unix_ns,
                "updated_at_unix_ns": updated_at_unix_ns,
            }
        )


def _equivalent_receipt_record(a: ReceiptRecord, b: ReceiptRecord) -> bool:
    keys = (
        "head_hex",
        "head_semantics",
        "body_json",
        "body_digest",
        "sig",
        "verify_key_fp",
        "verify_key_id",
        "receipt_integrity",
        "event_id",
        "decision_id",
        "route_plan_id",
        "audit_ref",
        "receipt_ref",
        "ledger_ref",
        "attestation_ref",
        "prepare_ref",
        "commit_ref",
        "outbox_ref",
        "outbox_status",
        "ledger_stage",
        "policy_ref",
        "policyset_ref",
        "policy_digest",
        "cfg_fp",
        "stream_hash",
        "state_domain_id",
        "adapter_registry_fp",
        "chain_namespace",
        "chain_id",
        "chain_seq",
        "prev_head_hex",
        "payload_digest",
        "event_digest",
    )
    for k in keys:
        if getattr(a, k) != getattr(b, k):
            return False
    return True



def _receipt_append_latest_requested(env: ReceiptEnvelope) -> bool:
    meta = env.meta if isinstance(env.meta, Mapping) else {}
    mode = _safe_label(meta.get("chain_append_mode"), default="")
    return mode in {"latest", "server_latest", "auto", "append_latest"}


def _receipt_input_equivalent(existing: ReceiptRecord, env: ReceiptEnvelope, *, cfg: StorageConfig) -> bool:
    keys = (
        "head_hex",
        "head_semantics",
        "body_json",
        "body_digest",
        "sig",
        "verify_key_fp",
        "verify_key_id",
        "receipt_integrity",
        "event_id",
        "decision_id",
        "route_plan_id",
        "audit_ref",
        "receipt_ref",
        "ledger_ref",
        "attestation_ref",
        "prepare_ref",
        "commit_ref",
        "outbox_ref",
        "outbox_status",
        "ledger_stage",
        "policy_ref",
        "policyset_ref",
        "policy_digest",
        "cfg_fp",
        "stream_hash",
        "state_domain_id",
        "adapter_registry_fp",
        "chain_namespace",
        "chain_id",
        "payload_digest",
        "event_digest",
    )
    for k in keys:
        if getattr(existing, k) != getattr(env, k):
            return False
    server_assign_position = bool(getattr(cfg, "server_assign_receipt_chain_position", False)) and (
        env.prev_head_hex is None or _receipt_append_latest_requested(env)
    )
    if env.chain_seq is not None and not server_assign_position and existing.chain_seq != env.chain_seq:
        return False
    if env.prev_head_hex is not None and not server_assign_position:
        prev = env.prev_head_hex
        if existing.prev_chain_head_hex != prev and existing.prev_head_hex != prev:
            return False
    return True

@dataclass(frozen=True)
class PutResult:
    stored: bool
    idempotent: bool
    conflict: bool
    head_hex: str
    chain_head_hex: Optional[str]
    store_backend: str
    store_id: Optional[int]
    event_id: Optional[str]
    decision_id: Optional[str]
    chain_namespace: str
    chain_id: str
    chain_seq: Optional[int]
    receipt_ref: Optional[str]
    audit_ref: Optional[str]
    body_digest: Optional[str]
    payload_digest: Optional[str]
    ledger_ref: Optional[str] = None
    attestation_ref: Optional[str] = None
    prepare_ref: Optional[str] = None
    commit_ref: Optional[str] = None
    outbox_ref: Optional[str] = None
    reason: Optional[str] = None
    warnings: Tuple[str, ...] = field(default_factory=tuple)

    def to_dict(self) -> Dict[str, Any]:
        return dataclasses.asdict(self)


@dataclass(frozen=True)
class PutChainResult:
    stored_count: int
    idempotent_count: int
    conflict_at_index: Optional[int]
    chain_namespace: Optional[str]
    chain_id: Optional[str]
    first_head_hex: Optional[str]
    latest_chain_head_hex: Optional[str]
    results: Tuple[PutResult, ...] = field(default_factory=tuple)

    def to_dict(self) -> Dict[str, Any]:
        return dataclasses.asdict(self)


@dataclass(frozen=True)
class VerifyWindowReport:
    ok: bool
    checked: int
    links_checked: int
    duplicates: int
    forks: int
    cycles: int
    missing_prev: int
    bad_heads: int
    bad_rows: int
    latest_head_hex: Optional[str]
    latest_chain_head_hex: Optional[str]
    chain_namespace: Optional[str]
    chain_id: Optional[str]
    genesis_count: int = 0
    tip_count: int = 0
    unselected: int = 0
    expected_latest_chain_head_hex: Optional[str] = None
    latest_matches_expected: Optional[bool] = None
    reasons: Tuple[str, ...] = field(default_factory=tuple)
    rows: Tuple[str, ...] = field(default_factory=tuple)

    def to_dict(self) -> Dict[str, Any]:
        return dataclasses.asdict(self)


class ReceiptStore(Protocol):
    def put_receipt(self, rec: ReceiptEnvelope) -> PutResult:
        ...
    def put_chain(self, records: Sequence[ReceiptEnvelope]) -> PutChainResult:
        ...
    def get_record_by_head(self, head_hex: str) -> Optional[ReceiptRecord]:
        ...
    def get_record_by_chain_head(self, chain_head_hex: str) -> Optional[ReceiptRecord]:
        ...
    def get_record_by_event_id(self, event_id: str) -> Optional[ReceiptRecord]:
        ...
    def get_record_by_decision_id(self, decision_id: str) -> Optional[ReceiptRecord]:
        ...
    def latest(self, *, chain_namespace: Optional[str] = None, chain_id: Optional[str] = None) -> Optional[ReceiptRecord]:
        ...
    def page_chain(
        self,
        *,
        chain_namespace: Optional[str] = None,
        chain_id: Optional[str] = None,
        after_seq: Optional[int] = None,
        limit: int = 100,
    ) -> Tuple[List[ReceiptRecord], Optional[str]]:
        ...
    def verify_window(
        self,
        head_hex: Optional[str] = None,
        *,
        chain_namespace: Optional[str] = None,
        chain_id: Optional[str] = None,
        limit: int = 100,
        expected_latest_chain_head_hex: Optional[str] = None,
    ) -> VerifyWindowReport:
        ...
    # legacy
    def put(self, head_hex: str, body_json: str) -> None:
        ...
    def get(self, head_hex: str) -> Optional[str]:
        ...
    def tail(self, n: int) -> List[Tuple[str, str]]:
        ...
    def page(self, cursor: Optional[str], limit: int) -> Tuple[List[Tuple[str, str]], Optional[str]]:
        ...
    def stats(self) -> Dict[str, Any]:
        ...


# =============================================================================
# In-memory wealth ledger
# =============================================================================


@dataclass
class _WealthStateRow:
    wealth: float
    alpha0: float
    state_revision: int
    created_at_unix_ns: int
    updated_at_unix_ns: int


class InMemoryAlphaWealthLedger(AlphaWealthLedger):
    def __init__(self, *, config: Optional[StorageConfig] = None) -> None:
        self._cfg = config or StorageConfig()
        self._lock = threading.RLock()
        self._state: Dict[Tuple[Subject, str, str], _WealthStateRow] = {}
        self._events_by_store_id: "OrderedDict[int, WealthEventRecord]" = OrderedDict()
        self._event_id_index: Dict[str, int] = {}
        self._idem_index: Dict[Tuple[Subject, str, str, str], int] = {}
        self._subject_event_index: Dict[Tuple[Subject, str, str], Deque[int]] = {}
        self._next_store_id = 1

    def _evict_if_needed(self) -> None:
        cap = self._cfg.max_wealth_events_in_memory
        while len(self._events_by_store_id) > cap:
            store_id, rec = self._events_by_store_id.popitem(last=False)
            if rec.event_id:
                self._event_id_index.pop(rec.event_id, None)
            if rec.idem_key:
                self._idem_index.pop((rec.subject, rec.policy_ref, rec.state_domain_id, rec.idem_key), None)
            idx_key = (rec.subject, rec.policy_ref, rec.state_domain_id)
            dq = self._subject_event_index.get(idx_key)
            if dq is not None:
                while dq and dq[0] == store_id:
                    dq.popleft()
                if not dq:
                    self._subject_event_index.pop(idx_key, None)

    def peek(self, subject: Subject, *, policy_ref: str = "default", state_domain_id: str = "default") -> Optional[float]:
        subj, _ = _subject_and_hash(subject, self._cfg)
        pol = _safe_id(policy_ref, default="default", max_len=self._cfg.policy_ref_max_bytes) or "default"
        sd = _safe_id(state_domain_id, default="default", max_len=256) or "default"
        with self._lock:
            row = self._state.get((subj, pol, sd))
            return None if row is None else float(row.wealth)

    def get(self, subject: Subject, *, policy_ref: str = "default", state_domain_id: str = "default", default_alpha0: float = 0.05) -> float:
        cur = self.peek(subject, policy_ref=policy_ref, state_domain_id=state_domain_id)
        return float(cur) if cur is not None else max(float(default_alpha0), float(self._cfg.alpha0_floor))

    def get_or_create(self, subject: Subject, *, policy_ref: str = "default", state_domain_id: str = "default", default_alpha0: float = 0.05) -> float:
        subj, _ = _subject_and_hash(subject, self._cfg)
        pol = _safe_id(policy_ref, default="default", max_len=self._cfg.policy_ref_max_bytes) or "default"
        sd = _safe_id(state_domain_id, default="default", max_len=256) or "default"
        alpha0 = max(float(default_alpha0), float(self._cfg.alpha0_floor))
        with self._lock:
            key = (subj, pol, sd)
            row = self._state.get(key)
            if row is None:
                now_ns = now_unix_ns()
                self._state[key] = _WealthStateRow(
                    wealth=alpha0,
                    alpha0=alpha0,
                    state_revision=0,
                    created_at_unix_ns=now_ns,
                    updated_at_unix_ns=now_ns,
                )
                return alpha0
            return float(row.wealth)

    def apply(self, subject: Subject, step: WealthStep, *, default_alpha0: float = 0.05) -> WealthApplyResult:
        subj, subj_hash = _subject_and_hash(subject, self._cfg)
        step_n = step.normalized(cfg=self._cfg)
        key = (subj, step_n.policy_ref, step_n.state_domain_id)
        fp = step_n.event_fingerprint(subject_hash=subj_hash)

        with self._lock:
            if step_n.event_id:
                sid = self._event_id_index.get(step_n.event_id)
                if sid is not None:
                    old = self._events_by_store_id[sid]
                    if old.event_fingerprint != fp or old.subject != subj or old.policy_ref != step_n.policy_ref or old.state_domain_id != step_n.state_domain_id:
                        raise StorageConflictError("event_id already exists with different fingerprint")
                    return WealthApplyResult(
                        stored=False,
                        idempotent=True,
                        event_id=old.event_id,
                        idem_key=old.idem_key,
                        policy_ref=old.policy_ref,
                        state_domain_id=old.state_domain_id,
                        subject_hash=old.subject_hash,
                        state_revision=old.state_revision,
                        wealth_before=old.wealth_before,
                        wealth_after=old.wealth_after,
                        alpha_spent=old.alpha_spent,
                        earn=old.earn,
                        reward=old.reward,
                        reject=old.reject,
                        reason_code=old.reason_code,
                        event_fingerprint=old.event_fingerprint,
                        ts_unix_ns=old.ts_unix_ns,
                        audit_ref=old.audit_ref,
                        receipt_ref=old.receipt_ref,
                    )

            if step_n.idem_key:
                legacy_sid = self._idem_index.get((subj, step_n.policy_ref, step_n.state_domain_id, step_n.idem_key))
                if legacy_sid is not None:
                    old2 = self._events_by_store_id[legacy_sid]
                    if old2.event_fingerprint != fp:
                        raise StorageConflictError("idem_key already exists with different fingerprint")
                    return WealthApplyResult(
                        stored=False,
                        idempotent=True,
                        event_id=old2.event_id,
                        idem_key=old2.idem_key,
                        policy_ref=old2.policy_ref,
                        state_domain_id=old2.state_domain_id,
                        subject_hash=old2.subject_hash,
                        state_revision=old2.state_revision,
                        wealth_before=old2.wealth_before,
                        wealth_after=old2.wealth_after,
                        alpha_spent=old2.alpha_spent,
                        earn=old2.earn,
                        reward=old2.reward,
                        reject=old2.reject,
                        reason_code=old2.reason_code,
                        event_fingerprint=old2.event_fingerprint,
                        ts_unix_ns=old2.ts_unix_ns,
                        audit_ref=old2.audit_ref,
                        receipt_ref=old2.receipt_ref,
                    )

            alpha0 = max(float(default_alpha0), float(self._cfg.alpha0_floor))
            row = self._state.get(key)
            if row is None:
                now_ns = step_n.ts_unix_ns or now_unix_ns()
                row = _WealthStateRow(
                    wealth=alpha0,
                    alpha0=alpha0,
                    state_revision=0,
                    created_at_unix_ns=now_ns,
                    updated_at_unix_ns=now_ns,
                )
                self._state[key] = row

            if step_n.expected_state_revision is not None and row.state_revision != step_n.expected_state_revision:
                raise StorageConflictError("state revision mismatch")

            wealth_before = float(row.wealth)
            wealth_after = max(0.0, wealth_before - step_n.alpha_spent + (step_n.earn if step_n.reject else 0.0) + step_n.reward)
            new_revision = int(row.state_revision) + 1
            now_ns = step_n.ts_unix_ns or now_unix_ns()
            self._state[key] = _WealthStateRow(
                wealth=wealth_after,
                alpha0=row.alpha0,
                state_revision=new_revision,
                created_at_unix_ns=row.created_at_unix_ns,
                updated_at_unix_ns=now_ns,
            )

            rec = WealthEventRecord(
                store_id=self._next_store_id,
                event_id=step_n.event_id,
                idem_key=step_n.idem_key,
                subject=subj,
                subject_hash=subj_hash,
                policy_ref=step_n.policy_ref,
                state_domain_id=step_n.state_domain_id,
                adapter_registry_fp=step_n.adapter_registry_fp,
                ts_unix_ns=now_ns,
                state_revision=new_revision,
                wealth_before=wealth_before,
                wealth_after=wealth_after,
                alpha_spent=step_n.alpha_spent,
                earn=(step_n.earn if step_n.reject else 0.0),
                reward=step_n.reward,
                reject=bool(step_n.reject),
                reason_code=step_n.reason_code,
                trust_zone=step_n.trust_zone,
                route_profile=step_n.route_profile,
                route_plan_id=step_n.route_plan_id,
                decision_id=step_n.decision_id,
                signal_digest=step_n.signal_digest,
                context_digest=step_n.context_digest,
                selected_source=step_n.selected_source,
                controller_mode=step_n.controller_mode,
                decision_mode=step_n.decision_mode,
                statistical_guarantee_scope=step_n.statistical_guarantee_scope,
                identity_status=step_n.identity_status,
                audit_ref=step_n.audit_ref,
                receipt_ref=step_n.receipt_ref,
                degraded_reasons=step_n.degraded_reasons,
                meta=step_n.meta,
                event_fingerprint=fp,
            )
            self._events_by_store_id[rec.store_id] = rec
            if rec.event_id:
                self._event_id_index[rec.event_id] = rec.store_id
            if rec.idem_key:
                self._idem_index[(subj, rec.policy_ref, rec.state_domain_id, rec.idem_key)] = rec.store_id
            self._subject_event_index.setdefault((subj, rec.policy_ref, rec.state_domain_id), deque()).append(rec.store_id)
            self._next_store_id += 1
            self._evict_if_needed()

            return WealthApplyResult(
                stored=True,
                idempotent=False,
                event_id=rec.event_id,
                idem_key=rec.idem_key,
                policy_ref=rec.policy_ref,
                state_domain_id=rec.state_domain_id,
                subject_hash=rec.subject_hash,
                state_revision=rec.state_revision,
                wealth_before=rec.wealth_before,
                wealth_after=rec.wealth_after,
                alpha_spent=rec.alpha_spent,
                earn=rec.earn,
                reward=rec.reward,
                reject=rec.reject,
                reason_code=rec.reason_code,
                event_fingerprint=rec.event_fingerprint,
                ts_unix_ns=rec.ts_unix_ns,
                audit_ref=rec.audit_ref,
                receipt_ref=rec.receipt_ref,
            )

    def get_event(self, event_id: str) -> Optional[WealthEventRecord]:
        eid = _safe_id(event_id, default=None, max_len=256)
        if eid is None:
            return None
        with self._lock:
            sid = self._event_id_index.get(eid)
            return self._events_by_store_id.get(sid) if sid is not None else None

    def page_events(
        self,
        subject: Subject,
        *,
        policy_ref: str = "default",
        state_domain_id: str = "default",
        limit: int = 100,
        after_event_id: Optional[str] = None,
    ) -> List[WealthEventRecord]:
        subj, _ = _subject_and_hash(subject, self._cfg)
        pol = _safe_id(policy_ref, default="default", max_len=self._cfg.policy_ref_max_bytes) or "default"
        sd = _safe_id(state_domain_id, default="default", max_len=256) or "default"
        lim = max(1, min(self._cfg.max_page_size, int(limit)))
        with self._lock:
            ids = list(self._subject_event_index.get((subj, pol, sd), deque()))
            recs = [self._events_by_store_id[sid] for sid in ids if sid in self._events_by_store_id]
            recs.sort(key=lambda r: (r.ts_unix_ns, r.event_id or f"legacy:{r.store_id}", r.store_id))
            if after_event_id:
                start = 0
                for i, rec in enumerate(recs):
                    if rec.event_id == after_event_id:
                        start = i + 1
                        break
                recs = recs[start:]
            return recs[:lim]

    def recompute_subject_state(self, subject: Subject, *, policy_ref: str = "default", state_domain_id: str = "default", default_alpha0: float = 0.05) -> Dict[str, Any]:
        events = self.page_events(subject, policy_ref=policy_ref, state_domain_id=state_domain_id, limit=self._cfg.max_page_size)
        wealth = max(float(default_alpha0), float(self._cfg.alpha0_floor))
        if events:
            first = events[0]
            wealth = max(0.0, first.wealth_before)
            for ev in events:
                wealth = max(0.0, wealth - ev.alpha_spent + (ev.earn if ev.reject else 0.0) + ev.reward)
        return {
            "schema": _WEALTH_SCHEMA,
            "policy_ref": policy_ref,
            "state_domain_id": state_domain_id,
            "event_count": len(events),
            "wealth_recomputed": wealth,
            "last_state_revision": events[-1].state_revision if events else 0,
        }

    def verify_subject_state(self, subject: Subject, *, policy_ref: str = "default", state_domain_id: str = "default", default_alpha0: float = 0.05) -> Dict[str, Any]:
        recomputed = self.recompute_subject_state(subject, policy_ref=policy_ref, state_domain_id=state_domain_id, default_alpha0=default_alpha0)
        current = self.get(subject, policy_ref=policy_ref, state_domain_id=state_domain_id, default_alpha0=default_alpha0)
        ok = abs(float(recomputed["wealth_recomputed"]) - float(current)) <= 1e-12
        return {
            "schema": _WEALTH_SCHEMA,
            "ok": ok,
            "policy_ref": policy_ref,
            "state_domain_id": state_domain_id,
            "wealth_current": current,
            "wealth_recomputed": recomputed["wealth_recomputed"],
            "last_state_revision": recomputed["last_state_revision"],
        }

    def snapshot_subject(self, subject: Subject, *, policy_ref: str = "default", state_domain_id: str = "default", default_alpha0: float = 0.05) -> Dict[str, Any]:
        subj, subj_hash = _subject_and_hash(subject, self._cfg)
        pol = _safe_id(policy_ref, default="default", max_len=self._cfg.policy_ref_max_bytes) or "default"
        sd = _safe_id(state_domain_id, default="default", max_len=256) or "default"
        wealth = self.get(subject, policy_ref=pol, state_domain_id=sd, default_alpha0=default_alpha0)
        events = self.page_events(subject, policy_ref=pol, state_domain_id=sd, limit=50)
        return {
            "schema": _WEALTH_SCHEMA,
            "compatibility_epoch": _STORAGE_COMPATIBILITY_EPOCH,
            "subject": {"subject_hash": subj_hash, "tenant": subj[0], "user": subj[1], "session": subj[2]},
            "policy_ref": pol,
            "state_domain_id": sd,
            "wealth": wealth,
            "events": [e.to_dict() for e in events],
        }

    def stats(self) -> Dict[str, Any]:
        with self._lock:
            return {
                "backend": "memory",
                "profile": self._cfg.profile,
                "wealth_subjects": len(self._state),
                "wealth_events": len(self._events_by_store_id),
                "compatibility_epoch": _STORAGE_COMPATIBILITY_EPOCH,
            }


