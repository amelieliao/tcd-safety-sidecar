        elif source is not None:
            produced_by_inputs.append(source)
    produced_by = _safe_tag_list(
        produced_by_inputs,
        max_items=16,
        max_len=64,
    )
    claims["produced_by"] = produced_by
    return claims


def _receipt_view_model(payload: Mapping[str, Any]) -> Any:
    if ReceiptView is None:
        return None
    try:
        if hasattr(ReceiptView, "model_validate"):
            return ReceiptView.model_validate(dict(payload))  # type: ignore[attr-defined]
        return ReceiptView(**dict(payload))  # type: ignore[misc]
    except Exception:
        return None


def _normalize_issue_payload(payload: Dict[str, Any]) -> Dict[str, Any]:
    """
    Normalize through ReceiptView if available, then restore legacy aliases.
    """
    use_receipt_view_normalize = _coerce_bool(os.getenv("TCD_ATTEST_RECEIPT_VIEW_NORMALIZE", "0")) is True
    rv = _receipt_view_model(payload) if use_receipt_view_normalize else None
    if rv is not None:
        try:
            if hasattr(rv, "model_dump"):
                out = dict(rv.model_dump(exclude_none=True))  # type: ignore[attr-defined]
            else:
                out = dict(payload)
        except Exception:
            out = dict(payload)
    else:
        out = dict(payload)

    head = out.get("head") or out.get("receipt")
    body = out.get("body") or out.get("receipt_body")
    sig = out.get("sig") or out.get("receipt_sig")

    out["receipt"] = head
    out["receipt_body"] = body
    out["receipt_sig"] = sig
    if not out.get("receipt_ref"):
        out["receipt_ref"] = head
    if not out.get("attestation_ref"):
        out["attestation_ref"] = _make_attestation_ref(
            head=head if isinstance(head, str) else None,
            receipt_ref=out.get("receipt_ref") if isinstance(out.get("receipt_ref"), str) else None,
            candidate=None,
        )
    if not out.get("attestation_id"):
        out["attestation_id"] = out.get("attestation_ref") or out.get("receipt_ref")
    if "body_kind" not in out:
        out["body_kind"] = "canonical_json" if isinstance(body, str) else "opaque"
    if "body_digest" not in out and isinstance(body, str):
        out["body_digest"] = "sha256:" + hashlib.sha256(body.encode("utf-8", errors="strict")).hexdigest()
    if "integrity_ok" not in out:
        out["integrity_ok"] = True
    if "integrity_errors" not in out:
        out["integrity_errors"] = []
    if "receipt_surface_kind" not in out:
        out["receipt_surface_kind"] = "ephemeral_attestation"
    if "receipt_delivery_state" not in out:
        out["receipt_delivery_state"] = "issued_only"
    if "evidence_durable" not in out:
        out["evidence_durable"] = False
    if "evidence_storage_ready" not in out:
        out["evidence_storage_ready"] = False
    if "ledger_stage" not in out:
        out["ledger_stage"] = "skipped"
    if "outbox_status" not in out:
        out["outbox_status"] = "none"
    return out


# ---------------------------------------------------------------------------
# Attestor
# ---------------------------------------------------------------------------


class Attestor:
    """
    Structured attestation generator.

    Legacy required keys remain:
      - receipt
      - receipt_body
      - receipt_sig
      - verify_key

    But the returned mapping is now also ReceiptView-compatible.
    """

    def __init__(self, hash_alg: str = "blake3", *, cfg: Optional[AttestorConfig] = None):
        if cfg is None:
            cfg = AttestorConfig(hash_alg=hash_alg)
        self._cfg = cfg
        self.hash_alg = cfg.hash_alg
        self._policy_digest = cfg.policy_digest()

    def issue(
        self,
        *,
        req_obj: Any,
        comp_obj: Any,
        e_obj: Any,
        witness_segments: Optional[Sequence[Any]],
        witness_tags: Optional[Iterable[str]],
        meta: Dict[str, Any],
    ) -> Dict[str, Any]:
        cfg = self._cfg

        # 1) normalize meta + extract control keys
        meta_in = meta or {}
        if cfg.normalize_meta:
            try:
                meta_in = cfg.normalize_meta(meta_in)
            except Exception as e:
                raise SerializationError(f"normalize_meta failed: {e}") from e

        meta_clean, ctrl = _extract_control_meta(meta_in, cfg=cfg)
        event_id = _coalesce_text(
            ctrl.get("event_id"),
            meta_clean.get("event_id"),
            meta_clean.get("_tcd_event_id"),
            max_len=128,
        )
        ts_ns = int(ctrl.get("ts_ns") or time.time_ns())
        if "nonce" in ctrl:
            nonce = str(ctrl["nonce"])
        elif event_id and cfg.deterministic_nonce_from_event_id:
            nonce = _derive_nonce_from_event_id(event_id)
        else:
            nonce = secrets.token_hex(16)

        # 2) hook-based normalization
        try:
            req_in = cfg.normalize_req(req_obj) if cfg.normalize_req else req_obj
            comp_in = cfg.normalize_comp(comp_obj) if cfg.normalize_comp else comp_obj
            e_in = cfg.normalize_e(e_obj) if cfg.normalize_e else e_obj
        except Exception as e:
            raise SerializationError(f"normalization hook failed: {e}") from e

        # 3) sanitize all objects
        req_s, req_info = _sanitize_obj(req_in, cfg=cfg, path="req")
        comp_s, comp_info = _sanitize_obj(comp_in, cfg=cfg, path="comp")
        e_s, e_info = _sanitize_obj(e_in, cfg=cfg, path="e")
        meta_s, meta_info = _sanitize_obj(meta_clean, cfg=cfg, path="meta")

        # 4) witness governance
        segments_full = _normalize_segments(witness_segments, cfg=cfg)
        _enforce_core_witness_requirements(segments_full, cfg=cfg)
        tags = _normalize_tags(witness_tags, cfg=cfg)

        # 5) field budgets
        truncations: List[Dict[str, Any]] = []
        meta_cap, tr = _cap_field(meta_s, cfg=cfg, budget_bytes=cfg.meta_budget_bytes, ctx="tcd:attest:meta", path="meta")
        if tr:
            truncations.append(tr)
        req_cap, tr = _cap_field(req_s, cfg=cfg, budget_bytes=cfg.req_budget_bytes, ctx="tcd:attest:req", path="req")
        if tr:
            truncations.append(tr)
        comp_cap, tr = _cap_field(comp_s, cfg=cfg, budget_bytes=cfg.comp_budget_bytes, ctx="tcd:attest:comp", path="comp")
        if tr:
            truncations.append(tr)
        e_cap, tr = _cap_field(e_s, cfg=cfg, budget_bytes=cfg.e_budget_bytes, ctx="tcd:attest:e", path="e")
        if tr:
            truncations.append(tr)

        segments = segments_full
        witness_full_info: Optional[Dict[str, Any]] = None
        if cfg.witness_budget_bytes > 0:
            full_bytes = _canonical_json_bytes({"segments": segments_full})
            if len(full_bytes) > cfg.witness_budget_bytes:
                if cfg.strict_mode:
                    raise WitnessError("witness segments exceed witness_budget_bytes in strict_mode")
                full_digest = _hash_bytes(full_bytes, alg=cfg.hash_alg, ctx="tcd:attest:witness_full", digest_size=cfg.digest_size)
                keep_n = min(len(segments_full), max(1, min(16, cfg.max_witness_segments or 16)))
                segments = segments_full[:keep_n]
                witness_full_info = {
                    "ctx": "tcd:attest:witness_full",
                    "alg": cfg.hash_alg,
                    "digest_size": int(cfg.digest_size),
                    "digest": full_digest,
                    "count": len(segments_full),
                    "bytes": len(full_bytes),
                }
                truncations.append(
                    {
                        "path": "witness.segments",
                        "bytes": len(full_bytes),
                        "digest": full_digest,
                        "ctx": "tcd:attest:witness_full",
                    }
                )

        segments_json = _canonical_json_bytes({"segments": segments})
        witness_digest = _hash_bytes(
            segments_json,
            alg=cfg.hash_alg,
            ctx="tcd:attest:witness",
            digest_size=cfg.digest_size,
        )

        # 6) attestor block
        attestor_block: Dict[str, Any] = {
            "id": cfg.attestor_id,
            "proc_id": cfg.proc_id,
            "policy_digest": self._policy_digest,
            "build_digest": cfg.build_digest,
            "runtime_env_digest": cfg.runtime_env_digest,
            "hw_root_id": cfg.hw_root_id,
            "tpm_quote_digest": cfg.tpm_quote_digest,
            "strict": bool(cfg.strict_mode),
            "hash_alg": cfg.hash_alg,
            "hash_ctx": cfg.hash_ctx,
            "digest_size": int(cfg.digest_size),
            "deployment_tier": cfg.deployment_tier,
            "engine_version": _ATTEST_ENGINE_VERSION,
        }
        if cfg.secondary_hash_alg:
            attestor_block["hash_secondary_alg"] = cfg.secondary_hash_alg
            attestor_block["hash_secondary_ctx"] = cfg.secondary_hash_ctx
            attestor_block["hash_secondary_digest_size"] = int(cfg.secondary_digest_size)

        policy_block: Dict[str, Any] = {}
        if cfg.include_policy_block:
            if cfg.default_auth_policy:
                policy_block["auth_policy"] = cfg.default_auth_policy
            if cfg.default_chain_policy:
                policy_block["chain_policy"] = cfg.default_chain_policy
            if cfg.default_ledger_policy:
                policy_block["ledger_policy"] = cfg.default_ledger_policy
            if cfg.default_cfg_digest:
                policy_block["cfg_digest"] = cfg.default_cfg_digest
            if cfg.runtime_env_digest:
                policy_block["runtime_env_digest"] = cfg.runtime_env_digest
            if cfg.tpm_quote_digest:
                policy_block["tpm_quote_digest"] = cfg.tpm_quote_digest

        claims = _extract_receipt_claims(
            cfg=cfg,
            req_obj=_m(req_in),
            comp_obj=_m(comp_in),
            e_obj=_m(e_in),
            meta_obj=_m(meta_clean),
            policy_digest=self._policy_digest,
        )

        # 7) body object
        body_obj: Dict[str, Any] = {
            "v": 2,
            "ts_ns": int(ts_ns),
            "nonce": nonce,
            "schema": cfg.body_schema,
            "attestor": attestor_block,
            "claims": claims,
            "meta": meta_cap,
            "req": req_cap,
            "comp": comp_cap,
            "e": e_cap,
            "witness": {
                "segments": segments,
                "digest": witness_digest,
                "tags": tags,
            },
        }
        if witness_full_info is not None:
            body_obj["witness"]["full"] = witness_full_info
        if policy_block:
            body_obj["policy"] = policy_block

        trunc_meta: Dict[str, Any] = {
            "fields": [t.get("path") for t in truncations if t.get("path")][: cfg.max_truncation_records],
            "sanitizer": {
                "req": {"trunc": req_info.get("truncations", [])[: cfg.max_truncation_records], "redact": req_info.get("redactions", [])[: cfg.max_truncation_records]},
                "comp": {"trunc": comp_info.get("truncations", [])[: cfg.max_truncation_records], "redact": comp_info.get("redactions", [])[: cfg.max_truncation_records]},
                "e": {"trunc": e_info.get("truncations", [])[: cfg.max_truncation_records], "redact": e_info.get("redactions", [])[: cfg.max_truncation_records]},
                "meta": {"trunc": meta_info.get("truncations", [])[: cfg.max_truncation_records], "redact": meta_info.get("redactions", [])[: cfg.max_truncation_records]},
            },
        }
        if truncations or req_info.get("truncated_paths") or comp_info.get("truncated_paths") or e_info.get("truncated_paths") or meta_info.get("truncated_paths"):
            body_obj["_tcd_trunc"] = trunc_meta

        body_bytes = _canonical_json_bytes(body_obj)

        # 8) oversize compaction
        if len(body_bytes) > cfg.max_body_bytes:
            if cfg.strict_mode:
                raise SerializationError("attestation body exceeds max_body_bytes in strict_mode")

            for key, ctx in (
                ("meta", "tcd:attest:meta"),
                ("req", "tcd:attest:req"),
                ("comp", "tcd:attest:comp"),
                ("e", "tcd:attest:e"),
            ):
                val = body_obj.get(key)
                vb = _canonical_json_bytes(val)
                body_obj[key] = _digest_only_ref(
                    cfg=cfg,
                    data_bytes=vb,
                    ctx=ctx,
                    kind="field",
                    reason="body_oversize",
                    extra={"path": key},
                )

            body_bytes = _canonical_json_bytes(body_obj)
            if len(body_bytes) > cfg.max_body_bytes:
                body_obj.pop("_tcd_trunc", None)
                body_obj.pop("policy", None)
                body_bytes = _canonical_json_bytes(body_obj)

            if len(body_bytes) > cfg.max_body_bytes:
                raise SerializationError("attestation body exceeds max_body_bytes after compaction")

        # 9) optional authenticity signature over UNSIGNED body
        auth_sig_block: Optional[Dict[str, Any]] = None
        unsigned_body_bytes = body_bytes
        if cfg.sign_func is not None and cfg.sig_alg:
            sig_alg_norm = str(cfg.sig_alg).strip()
            if cfg.allowed_sig_algs is not None and sig_alg_norm.lower() not in set(cfg.allowed_sig_algs):
                raise SigningError(f"sig_alg '{sig_alg_norm}' not allowed by policy")

            try:
                sig_raw = cfg.sign_func(unsigned_body_bytes)
            except Exception as e:
                raise SigningError(f"sign_func failed: {e}") from e

            if not isinstance(sig_raw, (bytes, bytearray)):
                raise SigningError("sign_func must return bytes")
            sig_bytes = bytes(sig_raw)
            if len(sig_bytes) < cfg.min_signature_bytes:
                raise SigningError("signature too short")
            if len(sig_bytes) > cfg.max_signature_bytes:
                raise SigningError("signature too large")

            auth_sig_block = {"alg": sig_alg_norm, "val": b64encode(sig_bytes).decode("ascii")}
            if cfg.sig_key_id:
                auth_sig_block["key_id"] = cfg.sig_key_id

            body_obj["auth_sig"] = auth_sig_block
            body_bytes = _canonical_json_bytes(body_obj)

            if len(body_bytes) > cfg.max_body_bytes:
                if cfg.strict_mode:
                    raise SerializationError("body exceeds max_body_bytes after adding signature in strict_mode")
                body_obj.pop("_tcd_trunc", None)
                body_obj.pop("policy", None)
                body_bytes = _canonical_json_bytes(body_obj)
            if len(body_bytes) > cfg.max_body_bytes:
                raise SerializationError("body exceeds max_body_bytes after adding signature")

        if cfg.strict_mode and cfg.require_sig_in_strict and auth_sig_block is None:
            raise SigningError("strict_mode requires authenticity signature block")

        # 10) FINAL head / detached integrity
        head = _compute_head_from_body(body_obj)
        head_secondary = None
        if cfg.secondary_hash_alg:
            head_secondary = _compute_head_from_body(
                body_obj,
                override_alg=cfg.secondary_hash_alg,
                override_ctx=cfg.secondary_hash_ctx,
                override_digest_size=cfg.secondary_digest_size,
            )

        receipt_sig = _integrity_hash(head, body_bytes)
        receipt_sig_secondary = _integrity_hash(head_secondary, body_bytes) if head_secondary else None

        verify_key = cfg.sig_key_id or (cfg.attestor_id if cfg.sign_func is not None else cfg.attestor_id + ":hash-only")
        verify_key_id = cfg.sig_key_id or verify_key
        verify_key_fp = _hash_handle_public(verify_key)

        body_str = body_bytes.decode("utf-8", errors="strict")
        body_digest = "sha256:" + hashlib.sha256(body_bytes).hexdigest()
        provenance_path_digest = hashlib.sha256(
            _canonical_json_bytes(
                {
                    "segments": segments,
                    "tags": tags,
                    "produced_by": claims.get("produced_by") or [],
                }
            )
        ).hexdigest()
        receipt_ref = _coalesce_text(claims.get("receipt_ref"), head, max_len=512) or head
        attestation_ref = _make_attestation_ref(
            head=head,
            receipt_ref=receipt_ref,
            candidate=claims.get("attestation_ref"),
        )

        out: Dict[str, Any] = {
            # schema identity
            "schema": cfg.receipt_schema,
            "schema_version": int(cfg.schema_version),
            "canonicalization_version": cfg.canonicalization_version,
            "receipt_kind": claims.get("receipt_kind") or cfg.receipt_kind,
            "event_type": claims.get("event_type") or cfg.default_event_type,
            # core receipt aliases
            "receipt": head,
            "head": head,
            "receipt_body": body_str,
            "body": body_str,
            "receipt_sig": receipt_sig,
            "sig": receipt_sig,
            "verify_key": verify_key,
            # receipt metadata
            "receipt_integrity": "sha256:tcd_attest_sig_v2",
            "body_kind": "canonical_json",
            "body_digest": body_digest,
            "body_schema": cfg.body_schema,
            "body_canonicalized": True,
            "sig_scheme": cfg.default_sig_scheme if auth_sig_block is not None else "integrity_only",
            "sig_alg": cfg.sig_alg,
            "sig_chain_id": None,
            "sig_key_id": cfg.sig_key_id,
            "verify_key_fp": verify_key_fp,
            "verify_key_id": verify_key_id,
            # pq / timing
            "pq_required": claims.get("pq_required"),
            "pq_ok": claims.get("pq_ok"),
            "pq_signature_required": claims.get("pq_signature_required"),
            "pq_signature_ok": claims.get("pq_signature_ok"),
            "ts": float(ts_ns) / 1_000_000_000.0,
            "ts_ns": int(ts_ns),
            "ts_unix_ns": int(ts_ns),
            # supply chain / policy / identity
            "build_id": claims.get("build_id"),
            "image_digest": claims.get("image_digest"),
            "attestation_id": attestation_ref,
            "env_fingerprint": claims.get("env_fingerprint"),
            "policy_ref": claims.get("policy_ref"),
            "policyset_ref": claims.get("policyset_ref"),
            "policy_digest": claims.get("policy_digest") or self._policy_digest,
            "cfg_fp": claims.get("cfg_fp"),
            "config_hash": claims.get("config_hash") or self._policy_digest,
            "stream_hash": claims.get("stream_hash"),
            "state_domain_id": claims.get("state_domain_id"),
            "adapter_registry_fp": claims.get("adapter_registry_fp"),
            "event_id": claims.get("event_id"),
            "decision_id": claims.get("decision_id"),
            "route_plan_id": claims.get("route_plan_id"),
            "route_id": claims.get("route_id"),
            "audit_ref": claims.get("audit_ref"),
            "receipt_ref": receipt_ref,
            "ledger_ref": claims.get("ledger_ref"),
            "attestation_ref": attestation_ref,
            "chain_namespace": claims.get("chain_namespace"),
            "chain_id": claims.get("chain_id"),
            "chain_seq": claims.get("chain_seq"),
            "prev_head_hex": claims.get("prev_head_hex"),
            "action": claims.get("action"),
            "reason": claims.get("reason"),
            "selected_source": claims.get("selected_source"),
            "statistical_guarantee_scope": claims.get("statistical_guarantee_scope"),
            "trigger": claims.get("trigger"),
            "allowed": claims.get("allowed"),
            "produced_by": list(claims.get("produced_by") or ["tcd.attest", cfg.attestor_id]),
            "provenance_path_digest": provenance_path_digest,
            # verification / integrity booleans are intentionally conservative on issue()
            "head_verified": None,
            "body_canonical_verified": None,
            "integrity_hash_verified": None,
            "signature_verified": None,
            "verify_key_allowed": None,
            "policy_binding_verified": None,
            "cfg_binding_verified": None,
            "integrity_ok": True,
            "integrity_errors": [],
            "normalization_warnings": [],
            "compat_warnings": [],
            "meta": dict(meta_cap) if isinstance(meta_cap, Mapping) else {},
            # governance defaults: issue() alone is NOT durable / storage-ready
            "prepare_ref": claims.get("prepare_ref"),
            "commit_ref": claims.get("commit_ref"),
            "outbox_ref": claims.get("outbox_ref"),
            "outbox_status": claims.get("outbox_status") or cfg.default_outbox_status,
            "outbox_dedupe_key": claims.get("outbox_dedupe_key"),
            "delivery_attempts": claims.get("delivery_attempts"),
            "ledger_stage": claims.get("ledger_stage") or cfg.default_ledger_stage,
            "payload_digest": claims.get("payload_digest"),
            "event_digest": claims.get("event_digest"),
            "receipt_surface_kind": claims.get("receipt_surface_kind") or cfg.default_surface_kind,
            "receipt_delivery_state": claims.get("receipt_delivery_state") or cfg.default_delivery_state,
            "evidence_durable": bool(claims.get("evidence_durable")) if claims.get("evidence_durable") is not None else bool(cfg.default_evidence_durable),
            "evidence_storage_ready": bool(claims.get("evidence_storage_ready")) if claims.get("evidence_storage_ready") is not None else bool(cfg.default_evidence_storage_ready),
        }

        if head_secondary is not None and receipt_sig_secondary is not None:
            out["receipt_secondary"] = head_secondary
            out["receipt_sig_secondary"] = receipt_sig_secondary

        out = _normalize_issue_payload(out)

        if cfg.self_check:
            ok, reason, details = verify_attestation_record_ex(
                receipt=head,
                receipt_body=body_str,
                receipt_sig=receipt_sig,
                verify_key=verify_key,
                require_witness_digest=True,
                strict_structure=cfg.self_check_strict_structure,
                require_canonical_body=cfg.self_check_require_canonical,
                require_sig=(cfg.strict_mode and cfg.require_sig_in_strict),
            )
            if not ok:
                raise AttestationError(f"self_check failed: {reason} {details}")

        return out

    # convenience helpers (additive)
    def to_receipt_view(self, payload: Mapping[str, Any]) -> Any:
        rv = _receipt_view_model(payload)
        return rv if rv is not None else dict(payload)

    def to_public_dict(self, payload: Mapping[str, Any], *, strict: bool = False) -> Dict[str, Any]:
        rv = _receipt_view_model(payload)
        if rv is not None and hasattr(rv, "to_public_dict"):
            with contextlib.suppress(Exception):
                return dict(rv.to_public_dict(strict=bool(strict)))
        head = payload.get("head") or payload.get("receipt")
        return {
            "schema": payload.get("schema"),
            "head": head,
            "receipt_ref": payload.get("receipt_ref") or head,
            "audit_ref": payload.get("audit_ref"),
            "attestation_ref": payload.get("attestation_ref"),
            "ledger_ref": payload.get("ledger_ref"),
            "prepare_ref": payload.get("prepare_ref"),
            "commit_ref": payload.get("commit_ref"),
            "outbox_ref": payload.get("outbox_ref"),
            "outbox_status": payload.get("outbox_status"),
            "ledger_stage": payload.get("ledger_stage"),
            "event_id": payload.get("event_id"),
            "decision_id": payload.get("decision_id"),
            "route_plan_id": payload.get("route_plan_id"),
            "policy_ref": payload.get("policy_ref"),
            "policyset_ref": payload.get("policyset_ref"),
            "cfg_fp": payload.get("cfg_fp"),
            "verify_key_id": payload.get("verify_key_id") or payload.get("sig_key_id"),
            "verify_key_fp": payload.get("verify_key_fp"),
            "receipt_integrity": payload.get("receipt_integrity"),
            "pq_signature_required": payload.get("pq_signature_required"),
            "pq_signature_ok": payload.get("pq_signature_ok"),
            "integrity_ok": payload.get("integrity_ok", True),
            "integrity_errors": list(payload.get("integrity_errors") or []),
        }

    def to_verification_dict(
        self,
        payload: Mapping[str, Any],
        *,
        strict: bool = False,
        include_verify_key: bool = True,
    ) -> Dict[str, Any]:
        rv = _receipt_view_model(payload)
        if rv is not None and hasattr(rv, "to_verification_dict"):
            with contextlib.suppress(Exception):
                return dict(rv.to_verification_dict(strict=bool(strict), include_verify_key=bool(include_verify_key)))
        return {
            "schema": payload.get("schema"),
            "head": payload.get("head") or payload.get("receipt"),
            "body": payload.get("body") or payload.get("receipt_body"),
            "sig": payload.get("sig") or payload.get("receipt_sig"),
            "verify_key": payload.get("verify_key") if include_verify_key else None,
            "verify_key_id": payload.get("verify_key_id") or payload.get("sig_key_id"),
            "verify_key_fp": payload.get("verify_key_fp"),
            "receipt_integrity": payload.get("receipt_integrity"),
            "body_kind": payload.get("body_kind"),
            "body_digest": payload.get("body_digest"),
            "receipt_ref": payload.get("receipt_ref"),
            "audit_ref": payload.get("audit_ref"),
            "attestation_ref": payload.get("attestation_ref"),
            "ledger_ref": payload.get("ledger_ref"),
            "prepare_ref": payload.get("prepare_ref"),
            "commit_ref": payload.get("commit_ref"),
            "outbox_ref": payload.get("outbox_ref"),
            "outbox_status": payload.get("outbox_status"),
            "ledger_stage": payload.get("ledger_stage"),
            "head_verified": payload.get("head_verified"),
            "body_canonical_verified": payload.get("body_canonical_verified"),
            "integrity_hash_verified": payload.get("integrity_hash_verified"),
            "signature_verified": payload.get("signature_verified"),
            "verify_key_allowed": payload.get("verify_key_allowed"),
            "policy_binding_verified": payload.get("policy_binding_verified"),
            "cfg_binding_verified": payload.get("cfg_binding_verified"),
            "integrity_ok": payload.get("integrity_ok", True),
            "integrity_errors": list(payload.get("integrity_errors") or []),
        }


# ---------------------------------------------------------------------------
# Head / integrity computation
# ---------------------------------------------------------------------------


def _compute_head_from_body(
    body_obj: Dict[str, Any],
    *,
    override_alg: Optional[str] = None,
    override_ctx: Optional[str] = None,
    override_digest_size: Optional[int] = None,
) -> str:
    """
    Derive receipt head from FINAL body.

    v=2 binds claims explicitly.
    v=1 fallback remains supported for older bodies.
    """
    v = int(body_obj.get("v", 1))
    ts_ns = int(body_obj.get("ts_ns"))
    nonce = body_obj.get("nonce")
    att = body_obj.get("attestor", {}) or {}
    witness = body_obj.get("witness", {}) or {}

    hash_alg = (override_alg or att.get("hash_alg") or "blake3").strip().lower()
    hash_ctx = (override_ctx or att.get("hash_ctx") or "tcd:attest").strip() or "tcd:attest"
    digest_size = int(override_digest_size or att.get("digest_size") or 32)

    attestor_subset = {
        "id": att.get("id"),
        "proc_id": att.get("proc_id"),
        "policy_digest": att.get("policy_digest"),
        "build_digest": att.get("build_digest"),
        "runtime_env_digest": att.get("runtime_env_digest"),
        "hw_root_id": att.get("hw_root_id"),
        "strict": bool(att.get("strict", False)),
        "hash_alg": hash_alg,
        "hash_ctx": hash_ctx,
        "digest_size": digest_size,
        "deployment_tier": att.get("deployment_tier"),
        "engine_version": att.get("engine_version"),
    }

    if v >= 2:
        claims = body_obj.get("claims") if isinstance(body_obj.get("claims"), dict) else {}
        claims_subset = {
            "receipt_kind": claims.get("receipt_kind"),
            "event_type": claims.get("event_type"),
            "event_id": claims.get("event_id"),
            "decision_id": claims.get("decision_id"),
            "route_plan_id": claims.get("route_plan_id"),
            "policy_ref": claims.get("policy_ref"),
            "policyset_ref": claims.get("policyset_ref"),
            "policy_digest": claims.get("policy_digest"),
            "cfg_fp": claims.get("cfg_fp"),
            "state_domain_id": claims.get("state_domain_id"),
            "adapter_registry_fp": claims.get("adapter_registry_fp"),
            "audit_ref": claims.get("audit_ref"),
            "stream_hash": claims.get("stream_hash"),
            "build_id": claims.get("build_id"),
            "image_digest": claims.get("image_digest"),
            "pq_required": claims.get("pq_required"),
            "pq_ok": claims.get("pq_ok"),
            "pq_signature_required": claims.get("pq_signature_required"),
            "pq_signature_ok": claims.get("pq_signature_ok"),
            "action": claims.get("action"),
            "allowed": claims.get("allowed"),
            "trigger": claims.get("trigger"),
            "statistical_guarantee_scope": claims.get("statistical_guarantee_scope"),
        }
        head_src = {
            "v": v,
            "ts_ns": ts_ns,
            "nonce": nonce,
            "attestor": attestor_subset,
            "claims": claims_subset,
            "meta": body_obj.get("meta"),
            "req": body_obj.get("req"),
            "comp": body_obj.get("comp"),
            "e": body_obj.get("e"),
            "witness_digest": witness.get("digest"),
            "witness_tags": witness.get("tags") or [],
        }
    else:
        head_src = {
            "v": v,
            "ts_ns": ts_ns,
            "nonce": nonce,
            "attestor": attestor_subset,
            "meta": body_obj.get("meta"),
            "req": body_obj.get("req"),
            "comp": body_obj.get("comp"),
            "e": body_obj.get("e"),
            "witness_digest": witness.get("digest"),
            "witness_tags": witness.get("tags") or [],
            "policy_digest": att.get("policy_digest"),
        }

    head_src_bytes = _canonical_json_bytes(head_src)
    return _hash_bytes(head_src_bytes, alg=hash_alg, ctx=hash_ctx, digest_size=digest_size)


def _integrity_hash(head: str, body_bytes: bytes) -> str:
    h = hashlib.sha256()
    h.update(b"tcd:attest_sig")
    h.update(head.encode("utf-8", errors="strict"))
    h.update(body_bytes)
    return h.hexdigest()


