def _m(v: Any) -> Mapping[str, Any]:
    return v if isinstance(v, Mapping) else {}


def _coalesce_text(*vals: Any, max_len: int = 256) -> Optional[str]:
    for v in vals:
        s = _safe_text(v, max_len=max_len)
        if s:
            return s
    return None


def _coalesce_bool(*vals: Any) -> Optional[bool]:
    for v in vals:
        b = _coerce_bool(v)
        if b is not None:
            return b
    return None


def _coalesce_float(*vals: Any) -> Optional[float]:
    for v in vals:
        f = _coerce_float(v)
        if f is not None:
            return f
    return None


def _coalesce_int(*vals: Any) -> Optional[int]:
    for v in vals:
        i = _coerce_int(v)
        if i is not None:
            return i
    return None


