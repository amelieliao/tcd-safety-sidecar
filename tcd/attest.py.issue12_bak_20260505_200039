def verify_attestation_record_ex(
    *,
    receipt: Optional[str] = None,
    receipt_body: Optional[str] = None,
    receipt_sig: Optional[str] = None,
    verify_key: Optional[str] = None,
    # aliases used by verify.py / service layers
    receipt_head_hex: Optional[str] = None,
    receipt_body_json: Optional[str] = None,
    receipt_sig_hex: Optional[str] = None,
    verify_key_hex: Optional[str] = None,
    # optional context hints
    req_obj: Any = None,
    comp_obj: Any = None,
    e_obj: Any = None,
    witness_segments: Optional[Sequence[Any]] = None,
    # budgets
    max_body_bytes: int = 256 * 1024,
    max_json_depth: int = 96,
    max_nodes: int = 100_000,
    max_list_items: int = 5_000,
    max_dict_items: int = 5_000,
    max_string_bytes: int = 64 * 1024,
    max_key_bytes: int = 8 * 1024,
    max_receipt_len: int = 256,
    max_receipt_sig_len: int = 256,
    # trust policy
    allowed_hash_algs: Optional[List[str]] = None,
    disallowed_hash_algs: Optional[List[str]] = None,
    allowed_attestor_ids: Optional[List[str]] = None,
    allowed_policy_digests: Optional[List[str]] = None,
    allowed_verify_keys: Optional[List[str]] = None,
    allowed_deployment_tiers: Optional[List[str]] = None,
    require_attestor_strict_flag: Optional[bool] = None,
    # structure
    require_witness_digest: bool = False,
    strict_structure: bool = False,
    require_canonical_body: bool = False,
    # signature verify
    require_sig: bool = False,
    verify_sig_func: Optional[Callable[[str, Optional[str], bytes, bytes], bool]] = None,
    # bindings
    expected_policy_ref: Optional[str] = None,
    expected_policyset_ref: Optional[str] = None,
    expected_policy_digest: Optional[str] = None,
    expected_cfg_fp: Optional[str] = None,
    expected_build_id: Optional[str] = None,
    expected_image_digest: Optional[str] = None,
    # hooks
    hooks: Optional[AttestorHooks] = None,
) -> Tuple[bool, str, Dict[str, Any]]:
    details: Dict[str, Any] = {}

    def fail(code: str, extra: Optional[Dict[str, Any]] = None) -> Tuple[bool, str, Dict[str, Any]]:
        if extra:
            details.update(extra)
        if hooks and hooks.on_verify_fail:
            with contextlib.suppress(Exception):
                hooks.on_verify_fail(code, dict(details))
        return False, code, details

    try:
        receipt = receipt or receipt_head_hex
        receipt_body = receipt_body or receipt_body_json
        receipt_sig = receipt_sig or receipt_sig_hex
        verify_key = verify_key or verify_key_hex

        if not isinstance(receipt, str) or not receipt:
            return fail(VR_SCHEMA, {"field": "receipt"})
        if not isinstance(receipt_sig, str) or not receipt_sig:
            return fail(VR_SCHEMA, {"field": "receipt_sig"})
        if not isinstance(receipt_body, str) or not receipt_body:
            return fail(VR_SCHEMA, {"field": "receipt_body"})

        if len(receipt) > max_receipt_len or not _is_hexish(receipt, max_len=max_receipt_len):
            return fail(VR_SCHEMA, {"field": "receipt", "reason": "bad_hex_or_len"})
        if len(receipt_sig) > max_receipt_sig_len or not _is_hexish(receipt_sig, max_len=max_receipt_sig_len):
            return fail(VR_SCHEMA, {"field": "receipt_sig", "reason": "bad_hex_or_len"})

        body_bytes = receipt_body.encode("utf-8", errors="strict")
        if len(body_bytes) > int(max_body_bytes):
            return fail(VR_BODY_TOO_LARGE, {"bytes": len(body_bytes), "max": int(max_body_bytes)})

        if not _json_bracket_depth_guard(receipt_body, max_depth=int(max_json_depth)):
            return fail(VR_JSON_TOO_DEEP, {"max_depth": int(max_json_depth)})
    except Exception as e:
        return fail(VR_INTERNAL, {"exc": str(e)})

    try:
        body_obj = json.loads(receipt_body)
    except Exception:
        return fail(VR_JSON_PARSE)

    if require_canonical_body:
        try:
            if _canonical_json_bytes(body_obj) != body_bytes:
                return fail(VR_NOT_CANONICAL)
        except Exception:
            return fail(VR_NOT_CANONICAL)

    ok_complex, cx = _measure_complexity(
        body_obj,
        max_nodes=int(max_nodes),
        max_list_items=int(max_list_items),
        max_dict_items=int(max_dict_items),
        max_string_bytes=int(max_string_bytes),
        max_key_bytes=int(max_key_bytes),
    )
    details["complexity"] = cx
    if not ok_complex:
        return fail(VR_COMPLEXITY)

    if not isinstance(body_obj, dict):
        return fail(VR_SCHEMA, {"reason": "body_not_dict"})

    try:
        v = int(body_obj.get("v", 1))
        ts_ns = int(body_obj.get("ts_ns"))
        nonce = body_obj.get("nonce")
        att = body_obj.get("attestor", {}) or {}
        witness = body_obj.get("witness", {}) or {}
        claims = body_obj.get("claims", {}) or {}
    except Exception:
        return fail(VR_SCHEMA)

    if strict_structure:
        if v not in {1, 2}:
            return fail(VR_SCHEMA, {"reason": "unsupported_version"})
        if not isinstance(nonce, str) or not nonce:
            return fail(VR_SCHEMA, {"field": "nonce"})
        if not isinstance(att, dict):
            return fail(VR_SCHEMA, {"field": "attestor"})
        if not isinstance(witness, dict):
            return fail(VR_SCHEMA, {"field": "witness"})
        if not isinstance(witness.get("segments"), list):
            return fail(VR_SCHEMA, {"field": "witness.segments"})
        if not isinstance(witness.get("tags"), list):
            return fail(VR_SCHEMA, {"field": "witness.tags"})
        if require_witness_digest and "digest" not in witness:
            return fail(VR_SCHEMA, {"field": "witness.digest", "reason": "required_missing"})
        if v >= 2 and claims is not None and not isinstance(claims, dict):
            return fail(VR_SCHEMA, {"field": "claims"})

    attestor_id = att.get("id")
    policy_digest = att.get("policy_digest")
    deployment_tier = att.get("deployment_tier")

    if allowed_attestor_ids is not None and str(attestor_id) not in {str(x) for x in allowed_attestor_ids if x}:
        return fail(VR_ATTESTOR_ID, {"attestor_id": attestor_id})
    if allowed_policy_digests is not None and str(policy_digest) not in {str(x) for x in allowed_policy_digests if x}:
        return fail(VR_ATTESTOR_POLICY, {"policy_digest": policy_digest})
    if allowed_deployment_tiers is not None and deployment_tier is not None:
        if str(deployment_tier) not in {str(x) for x in allowed_deployment_tiers if x}:
            return fail(VR_TIER, {"deployment_tier": deployment_tier})
    if require_attestor_strict_flag is not None:
        if bool(att.get("strict", False)) != bool(require_attestor_strict_flag):
            return fail(VR_ATTESTOR_POLICY, {"reason": "strict_flag_mismatch"})

    hash_alg = str(att.get("hash_alg") or "blake3").strip().lower()
    hash_ctx = str(att.get("hash_ctx") or "tcd:attest").strip() or "tcd:attest"
    digest_size = int(att.get("digest_size") or 32)
    details["hash_alg"] = hash_alg
    details["hash_ctx"] = hash_ctx
    details["digest_size"] = digest_size

    if hash_alg not in _SUPPORTED_HASH_ALGS:
        return fail(VR_HASH_ALG, {"hash_alg": hash_alg, "reason": "unsupported"})
    if disallowed_hash_algs is not None and hash_alg in {str(x).strip().lower() for x in disallowed_hash_algs if x}:
        return fail(VR_HASH_ALG, {"hash_alg": hash_alg, "reason": "disallowed"})
    if allowed_hash_algs is not None and hash_alg not in {str(x).strip().lower() for x in allowed_hash_algs if x}:
        return fail(VR_HASH_ALG, {"hash_alg": hash_alg, "reason": "not_allowed"})
    if not (1 <= digest_size <= 32):
        return fail(VR_HASH_ALG, {"digest_size": digest_size, "reason": "bad_digest_size"})

    # witness digest
    try:
        stored_witness_digest = witness.get("digest")
        if require_witness_digest and stored_witness_digest is None:
            return fail(VR_SCHEMA, {"field": "witness.digest"})
        segments_json = _canonical_json_bytes({"segments": witness.get("segments", [])})
        computed_witness_digest = _hash_bytes(
            segments_json,
            alg=hash_alg,
            ctx="tcd:attest:witness",
            digest_size=digest_size,
        )
        details["witness_digest_computed"] = computed_witness_digest
        if stored_witness_digest is not None and not secrets.compare_digest(str(stored_witness_digest), computed_witness_digest):
            return fail(VR_WITNESS_DIGEST)
    except PolicyError as e:
        return fail(VR_HASH_ALG, {"exc": str(e)})
    except Exception as e:
        return fail(VR_SCHEMA, {"exc": str(e)})

    # head
    try:
        computed_head = _compute_head_from_body(body_obj)
        details["head_verified"] = secrets.compare_digest(computed_head, receipt)
        if not details["head_verified"]:
            return fail(VR_HEAD_MISMATCH, {"computed": computed_head, "given": receipt})
    except PolicyError as e:
        return fail(VR_HASH_ALG, {"exc": str(e)})
    except Exception as e:
        return fail(VR_INTERNAL, {"exc": str(e)})

    # integrity
    try:
        computed_sig = _integrity_hash(computed_head, body_bytes)
        details["body_canonical_verified"] = True if require_canonical_body else None
        details["integrity_hash_verified"] = secrets.compare_digest(computed_sig, receipt_sig)
        if not details["integrity_hash_verified"]:
            return fail(VR_INTEGRITY)
    except Exception as e:
        return fail(VR_INTERNAL, {"exc": str(e)})

    # verify_key allow policy
    verify_key_id = _extract_claim_field(body_obj, "verify_key_id") or body_obj.get("verify_key_id") or body_obj.get("sig_key_id") or verify_key
    if allowed_verify_keys is not None:
        vk_allowed = str(verify_key_id) in {str(x) for x in allowed_verify_keys if x}
        details["verify_key_allowed"] = vk_allowed
        if not vk_allowed:
            return fail(VR_VERIFY_KEY, {"verify_key": verify_key_id})
    else:
        details["verify_key_allowed"] = None

    # expected bindings
    policy_ref = _extract_claim_field(body_obj, "policy_ref")
    policyset_ref = _extract_claim_field(body_obj, "policyset_ref")
    policy_digest_claim = _extract_claim_field(body_obj, "policy_digest")
    cfg_fp = _extract_claim_field(body_obj, "cfg_fp")
    build_id = _extract_claim_field(body_obj, "build_id")
    image_digest = _extract_claim_field(body_obj, "image_digest")

    details["policy_binding_verified"] = None
    if expected_policy_ref is not None or expected_policyset_ref is not None or expected_policy_digest is not None:
        policy_binding_ok = True
        if expected_policy_ref is not None and str(policy_ref) != str(expected_policy_ref):
            policy_binding_ok = False
        if expected_policyset_ref is not None and str(policyset_ref) != str(expected_policyset_ref):
            policy_binding_ok = False
        if expected_policy_digest is not None and str(policy_digest_claim) != str(expected_policy_digest):
            policy_binding_ok = False
        details["policy_binding_verified"] = policy_binding_ok
        if not policy_binding_ok:
            return fail(
                VR_POLICY_BINDING,
                {
                    "policy_ref": policy_ref,
                    "policyset_ref": policyset_ref,
                    "policy_digest": policy_digest_claim,
                },
            )

    details["cfg_binding_verified"] = None
    if expected_cfg_fp is not None:
        cfg_ok = str(cfg_fp) == str(expected_cfg_fp)
        details["cfg_binding_verified"] = cfg_ok
        if not cfg_ok:
            return fail(VR_CFG_BINDING, {"cfg_fp": cfg_fp})

    if expected_build_id is not None:
        build_ok = str(build_id) == str(expected_build_id)
        details["build_binding_verified"] = build_ok
        if not build_ok:
            return fail(VR_BUILD_BINDING, {"build_id": build_id})

    if expected_image_digest is not None:
        image_ok = str(image_digest) == str(expected_image_digest)
        details["image_binding_verified"] = image_ok
        if not image_ok:
            return fail(VR_IMAGE_BINDING, {"image_digest": image_digest})

    details["pq_required"] = _extract_claim_field(body_obj, "pq_required")
    details["pq_ok"] = _extract_claim_field(body_obj, "pq_ok")
    details["pq_signature_required"] = _extract_claim_field(body_obj, "pq_signature_required")
    details["pq_signature_ok"] = _extract_claim_field(body_obj, "pq_signature_ok")

    # authenticity signature in body (optional)
    auth_sig_obj = body_obj.get("auth_sig")
    if auth_sig_obj is None and isinstance(body_obj.get("sig"), Mapping):
        auth_sig_obj = body_obj.get("sig")  # legacy body-embedded signature support

    if require_sig:
        if auth_sig_obj is None:
            details["signature_verified"] = False
            return fail(VR_SIG_MISSING)

    if auth_sig_obj is not None:
        if not isinstance(auth_sig_obj, Mapping):
            details["signature_verified"] = False
            return fail(VR_SIG_BAD, {"reason": "sig_not_dict"})
        alg = auth_sig_obj.get("alg")
        val = auth_sig_obj.get("val")
        key_id = auth_sig_obj.get("key_id")
        if not isinstance(alg, str) or not alg.strip():
            details["signature_verified"] = False
            return fail(VR_SIG_BAD, {"field": "auth_sig.alg"})
        if key_id is not None and (not isinstance(key_id, str) or not _SAFE_ASCII_ID_RE.fullmatch(key_id)):
            details["signature_verified"] = False
            return fail(VR_SIG_BAD, {"field": "auth_sig.key_id"})
        if not isinstance(val, str) or not val or len(val) > 4 * 1024 * 1024 or not _BASE64_RE.fullmatch(val):
            details["signature_verified"] = False
            return fail(VR_SIG_BAD, {"field": "auth_sig.val"})
        try:
            sig_bytes = b64decode(val.encode("ascii"), validate=True)
        except Exception:
            details["signature_verified"] = False
            return fail(VR_SIG_BAD, {"field": "auth_sig.val", "reason": "b64decode"})
        if verify_sig_func is None:
            if require_sig:
                details["signature_verified"] = False
                return fail(VR_SIG_VERIFY_UNAVAILABLE)
            details["signature_verified"] = None
        else:
            try:
                unsigned = _unsigned_body_for_sig(body_obj)
                sig_ok = bool(verify_sig_func(str(alg), str(key_id) if key_id is not None else None, unsigned, sig_bytes))
            except Exception as e:
                details["signature_verified"] = False
                return fail(VR_SIG_BAD, {"reason": "verify_sig_func_exc", "exc": str(e)})
            details["signature_verified"] = sig_ok
            if not sig_ok:
                return fail(VR_SIG_BAD, {"reason": "sig_verify_failed"})
    else:
        details["signature_verified"] = None

    return True, VR_OK, details


def verify_attestation_record(
    *,
    receipt: str,
    receipt_body: str,
    receipt_sig: str,
    **kwargs: Any,
) -> bool:
    ok, _, _ = verify_attestation_record_ex(
        receipt=receipt,
        receipt_body=receipt_body,
        receipt_sig=receipt_sig,
        **kwargs,
    )
    return bool(ok)