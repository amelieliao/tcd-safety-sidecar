# ---------------------------------------------------------------------------
# Public helper: canonical KV hash
# ---------------------------------------------------------------------------


def canonical_kv_hash(obj: Dict[str, Any], *, ctx: str, label: str = "") -> str:
    if not isinstance(obj, dict):
        raise TypeError("canonical_kv_hash expects a dict")
    data = _canonical_json_bytes(obj)
    h = hashlib.sha256()
    h.update(ctx.encode("utf-8", errors="strict"))
    if label:
        h.update(b"\x1f")
        h.update(label.encode("utf-8", errors="strict"))
    h.update(data)
    return h.hexdigest()


_canonical_kv_hash = canonical_kv_hash

