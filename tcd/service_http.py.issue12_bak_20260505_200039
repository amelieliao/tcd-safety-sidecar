def _security_router_requested_from_env(cfg: "ServiceHttpConfig") -> bool:
    """
    Explicit opt-in switch for the HTTP factory path.

    SecurityRouter needs a PolicyStore. In the default uvicorn factory path there
    may be no external policy file, so a router request should also enable the
    built-in safe default policy store.
    """
    return bool(
        _coerce_bool(os.getenv("TCD_HTTP_SECURITY_ROUTER_ENABLE"), default=False)
        or _coerce_bool(os.getenv("TCD_SECURITY_ROUTER_ENABLE"), default=False)
        or _coerce_bool(os.getenv("TCD_SECURITY_ROUTER_REQUIRED"), default=False)
        or _coerce_bool(os.getenv("TCD_HTTP_REQUIRE_SECURITY_ROUTER"), default=False)
        or _coerce_bool(os.getenv("TCD_SECURITY_ROUTER_DURABLE_RECEIPTS"), default=False)
        or _coerce_bool(os.getenv("TCD_SECURITY_ROUTER_REQUIRE_LEDGER_WHEN_REQUIRED"), default=False)
        or _coerce_bool(os.getenv("TCD_SECURITY_ROUTER_LEDGER_REQUIRED_ON_DENY"), default=False)
        or _coerce_bool(os.getenv("TCD_SECURITY_ROUTER_REQUIRE_TERMINAL_GOVERNANCE_FOR_RECEIPT"), default=False)
        or _coerce_bool(os.getenv("TCD_SECURITY_ROUTER_REQUIRE_STORAGE_READY_FOR_RECEIPT"), default=False)
        or _coerce_bool(os.getenv("TCD_SECURITY_ROUTER_LOCAL_LEDGER_ENABLE"), default=False)
        or _coerce_bool(os.getenv("TCD_SECURITY_ROUTER_LOCAL_AUDIT_ENABLE"), default=False)
        or _coerce_bool(os.getenv("TCD_SECURITY_ROUTER_OUTBOX_ENABLE"), default=False)
        or bool(os.getenv("TCD_SECURITY_ROUTER_LEDGER_DB"))
        or bool(os.getenv("TCD_LEDGER_DB"))
        or bool(os.getenv("TCD_SECURITY_ROUTER_AUDIT_PATH"))
        or bool(os.getenv("TCD_SECURITY_ROUTER_OUTBOX_AUDIT_PATH"))
        or _coerce_bool(os.getenv("TCD_POLICY_STORE_ENABLE"), default=False)
        or bool(os.getenv("TCD_POLICIES_FILE"))
        or bool(os.getenv("TCD_POLICY_FILE"))
        or bool(os.getenv("TCD_POLICIES_PATH"))
        or bool(os.getenv("TCD_SECURITY_POLICIES_FILE"))
        or bool(os.getenv("TCD_POLICIES_JSON"))
        or bool(os.getenv("TCD_POLICY_JSON"))
        or bool(os.getenv("TCD_SECURITY_POLICIES_JSON"))
        or (
            bool(getattr(cfg, "strict_mode", False))
            and bool(getattr(cfg, "require_security_router_when_strict", False))
        )
    )


def _build_policy_store_from_env_compat(*, cfg: "ServiceHttpConfig") -> Optional[Any]:
    """
    Build PolicyStore for the default uvicorn factory path.

    This makes this command able to actually attach PolicyStore/SecurityRouter:

        uvicorn tcd.service_http:create_app --factory --host 0.0.0.0 --port 8080

    Supported env vars:
      - TCD_POLICY_STORE_ENABLE=1
      - TCD_POLICIES_FILE=/absolute/or/relative/policies.json
      - TCD_POLICY_FILE=/absolute/or/relative/policies.json
      - TCD_POLICIES_JSON='{"schema_version":1,"rules":[...]}'
      - TCD_POLICY_JSON='{"schema_version":1,"rules":[...]}'

    The helper is deliberately compatibility-oriented because PolicyStore factory
    names may vary across local versions. It tries from_file/from_env/from_json/
    from_dict and constructor fallbacks, and only accepts objects with .bind(...).
    """
    if PolicyStore is Any:
        return None

    enabled = bool(
        _coerce_bool(os.getenv("TCD_POLICY_STORE_ENABLE"), default=False)
        or _security_router_requested_from_env(cfg)
    )

    policy_file = (
        _safe_text(os.getenv("TCD_POLICIES_FILE"), max_len=4096)
        or _safe_text(os.getenv("TCD_POLICY_FILE"), max_len=4096)
        or _safe_text(os.getenv("TCD_POLICIES_PATH"), max_len=4096)
        or _safe_text(os.getenv("TCD_SECURITY_POLICIES_FILE"), max_len=4096)
    )

    policy_json_env = None
    policy_json = None
    for env_name in ("TCD_POLICIES_JSON", "TCD_POLICY_JSON", "TCD_SECURITY_POLICIES_JSON"):
        val = os.getenv(env_name)
        if val:
            policy_json_env = env_name
            policy_json = val
            break

    if policy_file or policy_json:
        enabled = True

    if not enabled:
        return None

    strict_validation = bool(cfg.strict_mode)
    strict_schema = bool(cfg.strict_mode)

    common_kwargs = {
        "strict_validation": strict_validation,
        "strict_schema": strict_schema,
        "on_load_error": "fail_closed",
        "fail_closed_on_any_error": strict_validation,
        "default_token_cost_divisor": float(cfg.tokens_divisor_default),
    }

    def _looks_like_policy_store(obj: Any) -> bool:
        return obj is not None and callable(getattr(obj, "bind", None))

    def _call_factory(fn: Any, *args: Any, **kwargs: Any) -> Any:
        if not callable(fn):
            return None
        try:
            return fn(*args, **kwargs)
        except TypeError:
            pass
        except Exception:
            raise
        try:
            return fn(*args, **_filtered_kwargs_for(fn, kwargs))
        except TypeError:
            pass
        except Exception:
            raise
        try:
            return fn(*args)
        except Exception:
            raise

    if enabled and not policy_file and not policy_json:
        default_rules = [
            {
                "name": "http_default_policy",
                "version": "1",
                "priority": 0,
                "match": {
                    "tenant": "*",
                    "user": "*",
                    "session": "*",
                    "model_id": "*",
                    "gpu_id": "*",
                    "task": "*",
                    "lang": "*",
                    "env": "*",
                    "trust_zone": "*",
                    "route": "*",
                    "data_class": "*",
                    "workload": "*",
                    "jurisdiction": "*",
                    "regulation": "*",
                    "client_app": "*",
                    "access_channel": "*"
                },
                "routing": {
                    "fallback_decoder": "cautious",
                    "action_hint": "degrade",
                    "route_profile": "inference"
                },
                "receipt": {
                    "enable_issue": True,
                    "enable_verify_metrics": True,
                    "attach_policy_refs": True,
                    "attach_match_context": False,
                    "profile": "http_default",
                    "crypto_profile": "local_hmac",
                    "match_context_level": "coarse"
                },
                "audit": {
                    "audit_label": "http",
                    "sample_rate": 1.0,
                    "log_level": "info",
                    "incident_class": "runtime",
                    "force_audit_on_violation": True,
                    "require_full_trace": False
                },
                "sre": {
                    "token_cost_divisor": float(cfg.tokens_divisor_default)
                },
                "decision": "allow",
                "enforcement": "advisory",
                "origin": "service_http_default_env",
                "policy_patch_id": "http-default-00000000",
                "change_ticket_id": "TCD-13"
            }
        ]
        try:
            obj = PolicyStore(default_rules, **_filtered_kwargs_for(PolicyStore, common_kwargs))
            if _looks_like_policy_store(obj):
                _LOG.info("PolicyStore loaded via service_http default fallback policy")
                return obj
        except Exception:
            _LOG.exception("PolicyStore default fallback policy failed")

    # 1) File-based factories.
    if policy_file:
        for name in ("from_file", "load_file", "from_path", "load_path"):
            fn = getattr(PolicyStore, name, None)
            if not callable(fn):
                continue
            try:
                obj = _call_factory(fn, policy_file, **common_kwargs)
                if _looks_like_policy_store(obj):
                    _LOG.info("PolicyStore loaded via PolicyStore.%s(%s)", name, policy_file)
                    return obj
            except Exception:
                _LOG.exception("PolicyStore.%s failed for %s", name, policy_file)

    # 2) Env-based factory.
    if policy_json_env:
        fn = getattr(PolicyStore, "from_env", None)
        if callable(fn):
            try:
                obj = _call_factory(fn, policy_json_env, **common_kwargs)
                if _looks_like_policy_store(obj):
                    _LOG.info("PolicyStore loaded via PolicyStore.from_env(%s)", policy_json_env)
                    return obj
            except Exception:
                _LOG.exception("PolicyStore.from_env failed for %s", policy_json_env)

    # 3) JSON/dict-based factories.
    parsed_json = None
    if policy_json:
        if len(policy_json.encode("utf-8", errors="ignore")) > 4 * 1024 * 1024:
            _LOG.error("PolicyStore JSON env too large; refusing to load")
            return None
        try:
            parsed_json = json.loads(policy_json)
        except Exception:
            _LOG.exception("PolicyStore JSON env parse failed")
            parsed_json = None

        for name in ("from_json", "load_json"):
            fn = getattr(PolicyStore, name, None)
            if not callable(fn):
                continue
            try:
                obj = _call_factory(fn, policy_json, **common_kwargs)
                if _looks_like_policy_store(obj):
                    _LOG.info("PolicyStore loaded via PolicyStore.%s(JSON)", name)
                    return obj
            except Exception:
                _LOG.exception("PolicyStore.%s failed from JSON string", name)

        if parsed_json is not None:
            for name in ("from_dict", "from_mapping", "from_spec", "from_config", "load_dict"):
                fn = getattr(PolicyStore, name, None)
                if not callable(fn):
                    continue
                try:
                    obj = _call_factory(fn, parsed_json, **common_kwargs)
                    if _looks_like_policy_store(obj):
                        _LOG.info("PolicyStore loaded via PolicyStore.%s(dict)", name)
                        return obj
                except Exception:
                    _LOG.exception("PolicyStore.%s failed from parsed JSON", name)

    # 4) Constructor fallbacks.
    if policy_file:
        try:
            obj = PolicyStore(policy_file)
            if _looks_like_policy_store(obj):
                _LOG.info("PolicyStore loaded via PolicyStore(policy_file)")
                return obj
        except Exception:
            pass

    if parsed_json is not None:
        try:
            obj = PolicyStore(parsed_json)
            if _looks_like_policy_store(obj):
                _LOG.info("PolicyStore loaded via PolicyStore(parsed_json)")
                return obj
        except Exception:
            pass

        if isinstance(parsed_json, Mapping):
            try:
                obj = PolicyStore(**parsed_json)
                if _looks_like_policy_store(obj):
                    _LOG.info("PolicyStore loaded via PolicyStore(**parsed_json)")
                    return obj
            except Exception:
                pass

    _LOG.error(
        "PolicyStore was requested but could not be built. "
        "Set TCD_POLICIES_FILE or TCD_POLICIES_JSON using a format supported by tcd.policies.PolicyStore."
    )
    return None


def _security_context_compat(
