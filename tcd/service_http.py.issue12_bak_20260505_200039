        chain_payload_factor=_coerce_int(os.getenv("TCD_VERIFY_CHAIN_PAYLOAD_FACTOR")) or _DEFAULT_VERIFY_CHAIN_FACTOR,
    ).normalized_copy()

    return cfg, verify_limits


